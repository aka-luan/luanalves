---
import "../styles/tokens.css";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Luan Alves | Tecnologia que cabe no seu negócio",
  description = "Base inicial do site luanalves.com.br em Astro."
} = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <div class="site-shell">
      <slot />
    </div>
  </body>
</html>
