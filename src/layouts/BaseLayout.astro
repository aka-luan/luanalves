---
import Analytics from '@vercel/analytics/astro';
import '../styles/fonts.css';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  namespace?: string;
  canonicalPath?: string;
  ogType?: 'website' | 'article' | 'profile';
  socialImage?: string;
  socialImageAlt?: string;
  schema?: unknown | unknown[];
}

const {
  title = 'Luan Alves | Desenvolvimento Web Profissional',
  description = 'Desenvolvedor web freelancer especializado em sites, blogs e landing pages que convertem. Atendimento direto, entrega no prazo. Solicite seu orçamento.',
  namespace = 'home',
  canonicalPath = '/',
  ogType = 'website',
  socialImage = '/assets/og-cover.webp',
  socialImageAlt = 'Luan Alves - Desenvolvimento Web Profissional',
  schema,
} = Astro.props;

const siteUrl = 'https://luanalves.com.br';
const toAbsoluteUrl = (path: string) =>
  path.startsWith('http') ? path : new URL(path, siteUrl).toString();
const canonicalUrl = toAbsoluteUrl(canonicalPath);
const socialImageUrl = toAbsoluteUrl(socialImage);
const baseSchema = [
  {
    '@context': 'https://schema.org',
    '@type': 'Person',
    '@id': `${siteUrl}/#person`,
    name: 'Luan Alves',
    jobTitle: 'Desenvolvedor Web Freelancer',
    description:
      'Desenvolvedor web especializado em sites institucionais, blogs e landing pages para pequenas e médias empresas em todo o Brasil.',
    url: siteUrl,
    image: socialImageUrl,
    sameAs: ['https://linkedin.com/in/aka-luan', 'https://github.com/aka-luan'],
    knowsAbout: [
      'Desenvolvimento Web',
      'SEO',
      'Landing Pages',
      'Design para Conversão',
    ],
    contactPoint: {
      '@type': 'ContactPoint',
      contactType: 'Atendimento ao Cliente',
      availableLanguage: 'Portuguese',
      contactOption: 'TollFree',
      url: 'https://wa.me/5591982890565',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'ProfessionalService',
    '@id': `${siteUrl}/#business`,
    name: 'Luan Alves — Desenvolvimento Web',
    description:
      'Criação de sites institucionais, blogs e landing pages profissionais para empresas em todo o Brasil. Atendimento remoto, entrega no prazo e suporte pós-lançamento.',
    url: siteUrl,
    image: socialImageUrl,
    founder: { '@id': `${siteUrl}/#person` },
    areaServed: {
      '@type': 'Country',
      name: 'Brasil',
    },
    availableChannel: {
      '@type': 'ServiceChannel',
      serviceUrl: 'https://wa.me/5591982890565',
      serviceType: 'WhatsApp',
    },
    hasOfferCatalog: {
      '@type': 'OfferCatalog',
      name: 'Serviços de Desenvolvimento Web',
      itemListElement: [
        {
          '@type': 'Offer',
          name: 'Site Institucional',
          description:
            'Site profissional para empresas com foco em autoridade de marca, SEO e experiência do usuário.',
          url: `${siteUrl}/site-institucional/`,
          seller: { '@id': `${siteUrl}/#business` },
        },
        {
          '@type': 'Offer',
          name: 'Blog Profissional',
          description:
            'Estrutura editorial otimizada para SEO com gestão simplificada de conteúdo.',
          url: `${siteUrl}/blog-profissional/`,
          seller: { '@id': `${siteUrl}/#business` },
        },
        {
          '@type': 'Offer',
          name: 'Landing Page',
          description:
            'Página de alta conversão para campanhas digitais, focada em geração de leads e velocidade.',
          url: `${siteUrl}/landing-page/`,
          seller: { '@id': `${siteUrl}/#business` },
        },
      ],
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    '@id': `${siteUrl}/#website`,
    name: 'Luan Alves',
    url: siteUrl,
    description:
      'Site profissional de Luan Alves, desenvolvedor web freelancer especializado em sites, blogs e landing pages.',
    publisher: { '@id': `${siteUrl}/#person` },
    inLanguage: 'pt-BR',
  },
];

const pageSchema = schema ? (Array.isArray(schema) ? schema : [schema]) : [];
const schemaGraph = {
  '@context': 'https://schema.org',
  '@graph': [...baseSchema, ...pageSchema],
};
---

<!doctype html>
<html lang='pt-BR' class='dark'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>{title}</title>
    <meta name='description' content={description} />
    <link rel='canonical' href={canonicalUrl} />

    <meta property='og:type' content={ogType} />
    <meta property='og:url' content={canonicalUrl} />
    <meta property='og:title' content={title} />
    <meta property='og:description' content={description} />
    <meta property='og:image' content={socialImageUrl} />
    <meta property='og:image:alt' content={socialImageAlt} />
    <meta property='og:image:width' content='1200' />
    <meta property='og:image:height' content='630' />
    <meta property='og:locale' content='pt_BR' />
    <meta property='og:site_name' content='Luan Alves' />

    <meta name='twitter:card' content='summary_large_image' />
    <meta name='twitter:title' content={title} />
    <meta name='twitter:description' content={description} />
    <meta name='twitter:image' content={socialImageUrl} />
    <meta name='twitter:image:alt' content={socialImageAlt} />
    <meta name='theme-color' content='#131313' />

    <script type='application/ld+json' set:html={JSON.stringify(schemaGraph)} />

    <link rel='icon' type='image/svg+xml' href='/favicon.svg' />
    <script is:inline>
      document.documentElement.classList.add('js');
      if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        document.documentElement.classList.add('motion-enabled');
      }
    </script>
  </head>
  <body data-page='home' data-barba='wrapper'>
    <div data-barba='container' data-barba-namespace={namespace}>
      <slot />
    </div>
    <Analytics />
    <script>
      import '../scripts/page-transitions';
    </script>
  </body>
</html>
