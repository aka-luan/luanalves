---
import '../styles/global.css';
---
<!DOCTYPE html>
<html class="dark no-js" lang="pt-br">
<head>
  <meta charset="utf-8" />
  <meta content="width=device-width, initial-scale=1.0" name="viewport" />
  <title>Luan Alves | Tecnologia com Propósito</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Manrope:wght@200;300;400;500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
  <!-- Remove no-js class immediately so GSAP can set initial states before paint -->
  <script is:inline>document.documentElement.classList.remove('no-js');</script>
</head>
<body class="font-body text-on-surface antialiased selection:bg-primary-container selection:text-on-primary-container">
  <slot />

  <script>
    import { initHero } from '../scripts/gsap/hero.js';
    import { initReveals } from '../scripts/gsap/reveals.js';

    // Respect prefers-reduced-motion
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (!prefersReduced) {
      // Wait for DOM to be fully ready
      document.addEventListener('DOMContentLoaded', () => {
        initHero();
        initReveals();
      });

      // If DOM already loaded (e.g. Astro view transitions)
      if (document.readyState !== 'loading') {
        initHero();
        initReveals();
      }
    }
  </script>
</body>
</html>
