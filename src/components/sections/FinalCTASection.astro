---
import Button from "../ui/Button.astro";
import Eyebrow from "../ui/Eyebrow.astro";
---

<section class="final-cta section-shell" id="contact" aria-labelledby="contact-title" data-section="contact">
  <div class="page-shell final-cta__panel" data-animate="reveal" data-reveal="fade-up">
    <Eyebrow>CTA final</Eyebrow>
    <h2 id="contact-title" class="section-title">Vamos conversar?</h2>
    <p class="final-cta__copy">
      Se você quer organizar processos, construir um sistema ou integrar ferramentas sem complicar sua operação,
      eu posso ajudar.
    </p>
    <Button href="mailto:contato@luanalves.com.br" variant="primary" size="large">
      Falar comigo
    </Button>
  </div>
</section>
