---
import GridCard from "../ui/GridCard.astro";
import SectionHeading from "../ui/SectionHeading.astro";

const steps = [
  {
    number: "01",
    title: "Entendimento",
    copy: "Mergulho profundo nos desafios e objetivos reais do seu negócio."
  },
  {
    number: "02",
    title: "Direção",
    copy: "Definição da arquitetura e das ferramentas ideais para o seu contexto."
  },
  {
    number: "03",
    title: "Construção",
    copy: "Desenvolvimento com foco em usabilidade, performance e leitura clara do problema."
  },
  {
    number: "04",
    title: "Entrega",
    copy: "Acompanhamento na entrada em operação e suporte para evolução contínua."
  }
];
---

<section
  class="process section-shell"
  id="process"
  aria-labelledby="process-title"
  data-section="process"
  data-sticky="true"
>
  <div class="page-shell">
    <SectionHeading
      eyebrow="Processo"
      title="O caminho da clareza."
      id="process-title"
      meta="Etapas do projeto"
      split={true}
    />

    <ol class="process-grid">
      {
        steps.map((step) => (
          <GridCard as="li" className="process-card" index={step.number} indexClass="process-card__number">
            <h3>{step.title}</h3>
            <p>{step.copy}</p>
          </GridCard>
        ))
      }
    </ol>
  </div>
</section>
