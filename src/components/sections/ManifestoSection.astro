---
import Eyebrow from "../ui/Eyebrow.astro";

const paragraphs = [
  "Eu ajudo a transformar necessidades técnicas em projetos que façam sentido na prática, do site à automação.",
  "Tecnologia boa não complica a rotina. Ela reduz atrito, organiza operação e cria espaço para o negócio crescer."
];
---

<section class="manifesto section-shell" id="manifesto" aria-labelledby="manifesto-title" data-section="manifesto">
  <div class="page-shell manifesto__layout">
    <div>
      <Eyebrow>Manifesto</Eyebrow>
      <h2 id="manifesto-title" class="section-title" data-animate="reveal" data-reveal="fade-up">
        Empresas não precisam de tecnologia difícil. Precisam de clareza.
      </h2>
    </div>
    <div class="manifesto__copy" data-animate="reveal" data-reveal="fade-up">
      {paragraphs.map((paragraph) => <p>{paragraph}</p>)}
    </div>
  </div>
</section>
