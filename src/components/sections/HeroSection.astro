---
import Button from "../ui/Button.astro";
import Eyebrow from "../ui/Eyebrow.astro";

const signals = [
  {
    title: "Código limpo",
    copy: "Estrutura sustentável para não virar retrabalho depois."
  },
  {
    title: "Integração real",
    copy: "Conecta o que você já usa antes de propor outra ferramenta."
  },
  {
    title: "Performance",
    copy: "Soluções leves, compreensíveis e prontas para crescer."
  },
  {
    title: "Direção clara",
    copy: "Técnico o bastante para resolver, humano o bastante para explicar."
  }
];
---

<section
  class="hero section-shell"
  id="hero"
  aria-labelledby="hero-title"
  data-section="hero"
>
  <div class="hero__glow" aria-hidden="true" data-parallax="true"></div>
  <div class="page-shell hero__layout">
    <div class="hero__content" data-animate="reveal" data-reveal="fade-up">
      <Eyebrow>Tecnologia clara para pequenas empresas</Eyebrow>
      <h1 id="hero-title" class="hero__title" data-animate="reveal" data-reveal="fade-up">
        Tecnologia que cabe no seu <span>negócio</span>
      </h1>
      <p class="hero__lead" data-animate="reveal" data-reveal="fade-up">
        Sistemas sob medida para pequenas empresas que querem crescer sem depender de planilha.
      </p>
      <div class="hero__actions" data-animate="reveal" data-reveal="fade-up">
        <Button href="#services" variant="primary">Ver projetos</Button>
        <Button href="#contact">Falar comigo</Button>
      </div>
    </div>

    <aside
      class="hero__panel"
      aria-label="Princípios de trabalho"
      data-animate="reveal"
      data-reveal="fade-up"
    >
      {
        signals.map((signal) => (
          <div class="hero__signal" data-animate="reveal" data-reveal="fade-up">
            <span class="hero__signal-line"></span>
            <strong>{signal.title}</strong>
            <p>{signal.copy}</p>
          </div>
        ))
      }
    </aside>
  </div>
</section>
