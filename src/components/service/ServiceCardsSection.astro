---
import type { ServiceCard } from '../../data/servicePages';

interface Props {
  id: string;
  eyebrow: string;
  title: string;
  accent: string;
  copy: string;
  items: ServiceCard[];
  motionName?: string;
}

const {
  id,
  eyebrow,
  title,
  accent,
  copy,
  items,
  motionName = id,
} = Astro.props;
const titleParts = title.split(accent);
const titleDensity = title.length > 64 ? 'long' : 'default';
---

<section
  class='service-cards'
  id={id}
  aria-labelledby={`${id}-title`}
  data-motion-section={motionName}
  data-title-density={titleDensity}>
  <div class='service-cards__glow' aria-hidden='true'></div>
  <div class='service-cards__inner'>
    <div class='service-cards__copy editorial-copy editorial-copy--center'>
      <p class='editorial-eyebrow' data-motion-heading data-motion-hidden='y-sm'>{eyebrow}</p>
      <h2
        class='editorial-title editorial-title--compact'
        id={`${id}-title`}
        data-motion-heading
        data-motion-hidden='y-md'>
        {titleParts[0]}<em>{accent}</em>{titleParts[1]}
      </h2>
      <p class='editorial-lead' data-motion-copy data-motion-hidden='y-md'>{copy}</p>
    </div>

    <div class='service-cards__grid premium-card-grid'>
      {
        items.map((item, index) => (
          <article
            class='service-cards__card premium-card'
            data-motion-item={motionName}
            data-motion-hidden='y-card'>
            <span class='premium-card__number'>{String(index + 1).padStart(2, '0')}</span>
            <span class='service-cards__icon icon-chip' aria-hidden='true'>
              <span class='material-symbols-outlined'>{item.icon}</span>
            </span>
            <h3>{item.title}</h3>
            <p>{item.copy}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .service-cards {
    position: relative;
    padding: clamp(6.4rem, 7.4vw, 7.65rem) clamp(1.5rem, 6.25vw, 5.85rem)
      clamp(5rem, 6.2vw, 6.2rem);
    overflow: hidden;
    scroll-margin-top: 5.7rem;
  }

  .service-cards::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -4;
    background:
      radial-gradient(circle at 50% 20%, rgba(218, 176, 101, 0.13), transparent 28rem),
      linear-gradient(115deg, #101111 0%, #171716 50%, #0c0d0d 100%);
  }

  .service-cards__glow {
    position: absolute;
    inset: 0;
    z-index: -3;
    background:
      linear-gradient(180deg, rgba(7, 7, 7, 0.44), rgba(7, 7, 7, 0.12) 42%, rgba(7, 7, 7, 0.42)),
      radial-gradient(ellipse at 82% 64%, rgba(229, 196, 135, 0.09), transparent 30rem);
    pointer-events: none;
  }

  .service-cards__inner {
    display: grid;
    gap: clamp(2.4rem, 4vw, 3.5rem);
    width: min(100%, 84.8rem);
    margin: 0 auto;
  }

  .service-cards__copy {
    max-width: 64rem;
    margin-inline: auto;
  }

  .service-cards[data-title-density='long'] .editorial-title {
    max-width: 18ch;
    font-size: clamp(2.65rem, 3.75vw, 3.8rem);
    line-height: 1.04;
  }

  .service-cards__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .service-cards__card {
    display: grid;
    align-content: start;
    min-height: 20rem;
    padding: 1.55rem;
  }

  .service-cards__card:hover,
  .service-cards__card:focus-within {
    transform: translateY(-3px);
  }

  .service-cards__icon {
    margin-top: 2rem;
  }

  @media (max-width: 1100px) {
    .service-cards__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 900px) {
    .service-cards {
      padding: 5.5rem 1.15rem 4rem;
    }

    .service-cards[data-title-density='long'] .editorial-title {
      font-size: clamp(2.45rem, 7.8vw, 3.45rem);
    }
  }

  @media (max-width: 560px) {
    .service-cards {
      padding: 4.65rem 0.9rem 3.65rem;
    }

    .service-cards__inner {
      gap: 2rem;
    }

    .service-cards[data-title-density='long'] .editorial-title {
      font-size: clamp(1.98rem, 8.1vw, 2.56rem);
      line-height: 1.06;
    }

    .service-cards__grid {
      grid-template-columns: 1fr;
      gap: 0.85rem;
    }

    .service-cards__card {
      min-height: 0;
      padding: 1.25rem 1.15rem;
    }

    .service-cards__icon {
      margin-top: 1.35rem;
    }
  }
</style>
