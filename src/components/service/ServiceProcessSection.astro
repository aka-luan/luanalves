---
import type { ServiceCard } from '../../data/servicePages';

interface Props {
  eyebrow: string;
  title: string;
  accent: string;
  copy: string;
  items: ServiceCard[];
}

const { eyebrow, title, accent, copy, items } = Astro.props;
const titleParts = title.split(accent);
const titleDensity = title.length > 64 ? 'long' : 'default';
---

<section
  class='service-process'
  id='processo'
  aria-labelledby='process-title'
  data-motion-section='process'
  data-title-density={titleDensity}>
  <div class='service-process__inner'>
    <div class='service-process__copy editorial-copy'>
      <p class='editorial-eyebrow' data-motion-heading data-motion-hidden='y-sm'>{eyebrow}</p>
      <h2 class='editorial-title' id='process-title' data-motion-heading data-motion-hidden='y-md'>
        {titleParts[0]}<em>{accent}</em>{titleParts[1]}
      </h2>
      <p class='editorial-lead' data-motion-copy data-motion-hidden='y-md'>{copy}</p>
    </div>

    <div class='service-process__timeline' aria-label='Etapas do projeto'>
      {
        items.map((item, index) => (
          <article class='service-process-step' data-motion-item='process' data-motion-hidden='x-left'>
            <span class='service-process-step__number'>{String(index + 1).padStart(2, '0')}</span>
            <span class='service-process-step__marker' aria-hidden='true'>
              <span class='material-symbols-outlined'>{item.icon}</span>
            </span>
            <div class='service-process-step__copy'>
              <h3>{item.title}</h3>
              <p>{item.copy}</p>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .service-process {
    position: relative;
    padding: clamp(6.4rem, 7vw, 7.4rem) clamp(1.5rem, 6.25vw, 5.85rem);
    overflow: hidden;
    scroll-margin-top: 5.7rem;
  }

  .service-process::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -2;
    background:
      radial-gradient(circle at 74% 24%, rgba(218, 176, 101, 0.14), transparent 28rem),
      linear-gradient(115deg, #101111 0%, #171716 48%, #0c0d0d 100%);
  }

  .service-process__inner {
    display: grid;
    grid-template-columns: minmax(18rem, 0.9fr) minmax(0, 1.1fr);
    gap: clamp(2rem, 5vw, 5rem);
    width: min(100%, 84.8rem);
    margin: 0 auto;
  }

  .service-process__copy {
    max-width: 29rem;
  }

  .service-process[data-title-density='long'] .editorial-title {
    max-width: 17ch;
    font-size: clamp(2.6rem, 3.6vw, 3.65rem);
    line-height: 1.04;
  }

  .service-process__timeline {
    position: relative;
    display: grid;
    gap: 1.4rem;
  }

  .service-process__timeline::before {
    content: '';
    position: absolute;
    top: 1.5rem;
    bottom: 1.5rem;
    left: 5.15rem;
    width: 1px;
    background: linear-gradient(180deg, rgba(223, 189, 121, 0.48), rgba(229, 218, 207, 0.08));
  }

  .service-process-step {
    position: relative;
    display: grid;
    grid-template-columns: 3rem 3.2rem minmax(0, 1fr);
    gap: 1rem;
    align-items: start;
  }

  .service-process-step__number {
    color: rgba(223, 189, 121, 0.68);
    font-family: 'Newsreader', serif;
    font-size: 1.55rem;
    font-style: italic;
    font-weight: 600;
  }

  .service-process-step__marker {
    position: relative;
    z-index: 1;
    display: grid;
    place-items: center;
    width: 3.2rem;
    height: 3.2rem;
    border: 1px solid rgba(229, 196, 135, 0.4);
    border-radius: 999px;
    color: #dfbd79;
    background: #121312;
  }

  .service-process-step__copy {
    padding: 1.25rem 1.35rem;
    border: 1px solid rgba(229, 218, 207, 0.14);
    border-radius: 0.35rem;
    background: rgba(16, 17, 16, 0.74);
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      background-color 180ms ease,
      box-shadow 180ms ease;
  }

  .service-process-step:hover .service-process-step__copy,
  .service-process-step:focus-within .service-process-step__copy {
    transform: translateX(0.18rem);
    border-color: rgba(229, 196, 135, 0.28);
    background: rgba(20, 21, 20, 0.84);
    box-shadow: 0 18px 42px rgba(0, 0, 0, 0.16);
  }

  .service-process-step h3 {
    margin: 0;
    color: #f5f2ef;
    font-family: 'Newsreader', serif;
    font-size: 1.6rem;
    font-weight: 600;
    letter-spacing: -0.04em;
    line-height: 1.06;
    text-wrap: balance;
  }

  .service-process-step p {
    margin: 0.8rem 0 0;
    color: rgba(226, 218, 208, 0.74);
    font-size: 0.98rem;
    font-weight: 300;
    line-height: 1.62;
  }

  @media (max-width: 900px) {
    .service-process {
      padding: 6.5rem 1.15rem 4.5rem;
    }

    .service-process__inner {
      grid-template-columns: 1fr;
    }

    .service-process__copy {
      justify-items: center;
      text-align: center;
    }

    .service-process .editorial-title {
      margin-inline: auto;
    }

    .service-process[data-title-density='long'] .editorial-title {
      font-size: clamp(2.45rem, 7.8vw, 3.45rem);
    }
  }

  @media (max-width: 560px) {
    .service-process {
      padding-inline: 0.9rem;
    }

    .service-process[data-title-density='long'] .editorial-title {
      font-size: clamp(1.98rem, 8.1vw, 2.56rem);
      line-height: 1.06;
    }

    .service-process__timeline::before {
      left: 4.45rem;
    }

    .service-process-step {
      grid-template-columns: 2.55rem 2.8rem minmax(0, 1fr);
      gap: 0.72rem;
    }

    .service-process-step__marker {
      width: 2.8rem;
      height: 2.8rem;
    }

    .service-process-step__copy {
      padding: 1.1rem;
    }
  }
</style>
