---
import type { ServiceCard } from '../../data/servicePages';

interface Props {
  eyebrow: string;
  title: string;
  accent: string;
  copy: string;
  items: ServiceCard[];
}

const { eyebrow, title, accent, copy, items } = Astro.props;
const titleParts = title.split(accent);
const titleDensity = title.length > 64 ? 'long' : 'default';
---

<section
  class='service-audience'
  id='para-quem'
  aria-labelledby='audience-title'
  data-motion-section='audience'
  data-title-density={titleDensity}>
  <div class='service-audience__inner'>
    <div class='service-audience__copy editorial-copy'>
      <p class='editorial-eyebrow' data-motion-heading data-motion-hidden='y-sm'>{eyebrow}</p>
      <h2 class='editorial-title' id='audience-title' data-motion-heading data-motion-hidden='y-md'>
        {titleParts[0]}<em>{accent}</em>{titleParts[1]}
      </h2>
      <p class='editorial-lead' data-motion-copy data-motion-hidden='y-md'>{copy}</p>
    </div>

    <div class='service-audience__grid premium-card-grid'>
      {
        items.map((item) => (
          <article class='service-audience-card premium-card' data-motion-item='audience' data-motion-hidden='x-left'>
            <span class='service-audience-card__icon icon-chip' aria-hidden='true'>
              <span class='material-symbols-outlined'>{item.icon}</span>
            </span>
            <h3>{item.title}</h3>
            <p>{item.copy}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .service-audience {
    position: relative;
    padding: clamp(6.4rem, 7vw, 7.4rem) clamp(1.5rem, 6.25vw, 5.85rem);
    overflow: hidden;
    scroll-margin-top: 5.7rem;
  }

  .service-audience::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -2;
    background:
      radial-gradient(ellipse at 16% 68%, rgba(229, 196, 135, 0.1), transparent 32rem),
      linear-gradient(115deg, #0d0e0e 0%, #151514 52%, #101111 100%);
  }

  .service-audience__inner {
    display: grid;
    grid-template-columns: minmax(18rem, 0.9fr) minmax(0, 1.1fr);
    gap: clamp(2rem, 5vw, 5rem);
    align-items: start;
    width: min(100%, 84.8rem);
    margin: 0 auto;
  }

  .service-audience__copy {
    max-width: 29rem;
  }

  .service-audience[data-title-density='long'] .editorial-title {
    max-width: 17ch;
    font-size: clamp(2.6rem, 3.6vw, 3.65rem);
    line-height: 1.04;
  }

  .service-audience__grid {
  }

  .service-audience-card {
    display: grid;
    grid-template-columns: 3.4rem minmax(0, 1fr);
    column-gap: 1.1rem;
    padding: 1.35rem;
  }

  .service-audience-card:hover,
  .service-audience-card:focus-within {
    transform: translateX(0.18rem);
  }

  .service-audience-card__icon {
    grid-row: span 2;
    width: 3.4rem;
    height: 3.4rem;
  }

  .service-audience-card h3 {
    margin-top: 0;
    font-size: 1.62rem;
  }

  .service-audience-card p {
    margin-top: 0.7rem;
  }

  @media (max-width: 900px) {
    .service-audience {
      padding: 6.5rem 1.15rem 4.5rem;
    }

    .service-audience__inner {
      grid-template-columns: 1fr;
    }

    .service-audience__copy {
      justify-items: center;
      text-align: center;
    }

    .service-audience .editorial-title {
      margin-inline: auto;
    }

    .service-audience[data-title-density='long'] .editorial-title {
      font-size: clamp(2.45rem, 7.8vw, 3.45rem);
    }
  }

  @media (max-width: 560px) {
    .service-audience {
      padding-inline: 0.9rem;
    }

    .service-audience[data-title-density='long'] .editorial-title {
      font-size: clamp(1.98rem, 8.1vw, 2.56rem);
      line-height: 1.06;
    }

    .service-audience-card {
      grid-template-columns: 3.2rem 1fr;
      padding: 1.25rem;
    }

    .service-audience-card__icon {
      width: 3.2rem;
      height: 3.2rem;
    }
  }
</style>
