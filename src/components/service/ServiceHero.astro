---
import Breadcrumbs from '../Breadcrumbs.astro';
import type { ServicePageContent } from '../../data/servicePages';

interface Props {
  page: ServicePageContent;
}

const { page } = Astro.props;
const { hero } = page;
const titleParts = hero.title.split(hero.accent);
const titleDensity = hero.title.length > 64 ? 'long' : 'default';
const hiddenHeroEyebrowSlugs = new Set([
  'site-institucional',
  'landing-page',
  'blog-profissional',
  'criacao-de-sites-belem',
]);
const showEyebrow = !hiddenHeroEyebrowSlugs.has(page.slug);
const breadcrumbItems = [
  { label: 'Início', href: '/' },
  { label: 'Criação de Sites', href: '/criacao-de-sites/' },
  { label: page.serviceName },
];
---

<section
  class='service-hero'
  id='solucao'
  aria-labelledby='service-hero-title'
  data-motion='hero'
  data-service={page.slug}
  data-title-density={titleDensity}>
  <div class='service-hero__glow' aria-hidden='true' data-motion-glow></div>
  <div class='service-hero__grain' aria-hidden='true'></div>

  <div class='service-hero__inner'>
    <div class='service-hero__copy'>
      <Breadcrumbs items={breadcrumbItems} />

      {
        showEyebrow && (
          <p
            class='service-eyebrow'
            data-motion-hero-eyebrow
            data-motion-hidden='y-sm'>
            {hero.eyebrow}
          </p>
        )
      }

      <h1
        id='service-hero-title'
        data-motion-hero-title
        data-motion-hidden='y-lg'>
        {titleParts[0]}<em>{hero.accent}</em>{titleParts[1]}
      </h1>

      <p class='service-lead' data-motion-hero-copy data-motion-hidden='y-md'>
        {hero.copy}
      </p>

      <div class='service-actions' data-motion-hero-actions>
        <a
          class='service-button service-button--solid'
          href={page.whatsappHref}
          target='_blank'
          rel='noreferrer'
          data-motion-hidden='y-sm'>
          {hero.ctaLabel}
        </a>
        <a
          class='service-button service-button--outline'
          href={hero.secondaryHref}
          data-motion-hidden='y-sm'>
          {hero.secondaryLabel}
        </a>
      </div>

      <div class='service-features' aria-label='Diferenciais'>
        {
          hero.features.map((item) => (
            <article
              class='service-feature'
              data-motion-item='hero-feature'
              data-motion-hidden='y-sm'>
              <span class='service-feature__icon' aria-hidden='true'>
                <span class='material-symbols-outlined'>{item.icon}</span>
              </span>
              <strong>{item.title}</strong>
              <p>{item.copy}</p>
            </article>
          ))
        }
      </div>
    </div>

    <div
      class='service-hero__media'
      aria-hidden='true'
      data-motion-item='hero-media'
      data-motion-hidden='scale'>
      <div class='service-orbit'></div>
      <img
        src={hero.image}
        alt=''
        width='1448'
        height='1086'
        decoding='async'
        fetchpriority='high'
      />
    </div>
  </div>
</section>

<style>
  .service-hero {
    position: relative;
    min-height: 100svh;
    padding: clamp(7.2rem, 9.7vw, 9.1rem) clamp(1.5rem, 6.25vw, 5.85rem) 3.2rem;
    isolation: isolate;
    overflow: hidden;
  }

  .service-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -3;
    background:
      linear-gradient(
        to right,
        rgba(255, 255, 255, 0.025) 1px,
        transparent 1px
      ),
      linear-gradient(
        to bottom,
        rgba(255, 255, 255, 0.018) 1px,
        transparent 1px
      );
    background-size: 4rem 4rem;
    mask-image: radial-gradient(circle at 62% 42%, black, transparent 68%);
    opacity: 0.11;
  }

  .service-hero__glow {
    position: absolute;
    inset: 0;
    z-index: -2;
    background:
      linear-gradient(
        90deg,
        rgba(8, 8, 8, 0.9),
        rgba(8, 8, 8, 0.22) 56%,
        rgba(8, 8, 8, 0.54)
      ),
      radial-gradient(
        circle at 64% 53%,
        rgba(235, 194, 116, 0.2),
        transparent 32rem
      );
    pointer-events: none;
  }

  .service-hero__grain {
    position: absolute;
    inset: 0;
    z-index: -1;
    opacity: 0.34;
    pointer-events: none;
    background-image:
      linear-gradient(125deg, rgba(255, 255, 255, 0.035), transparent 22%),
      radial-gradient(
        circle at 20% 20%,
        rgba(255, 255, 255, 0.025) 0 1px,
        transparent 1px
      );
    background-size:
      auto,
      3px 3px;
    mix-blend-mode: overlay;
  }

  .service-hero__inner {
    display: grid;
    grid-template-columns: minmax(27rem, 0.78fr) minmax(32rem, 1.22fr);
    align-items: center;
    gap: clamp(1rem, 3vw, 3rem);
    width: min(100%, 84.8rem);
    min-height: calc(100svh - 12.3rem);
    margin: 0 auto;
  }

  .service-hero__copy {
    position: relative;
    z-index: 2;
    display: grid;
    min-width: 0;
    justify-items: start;
    align-content: center;
  }

  .service-eyebrow {
    margin: 0 0 1.55rem;
    color: #d9ae5f;
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.26em;
    text-transform: uppercase;
  }

  .service-hero h1 {
    max-width: 12.8ch;
    margin: 0;
    color: #f5f2ef;
    font-family: 'Newsreader', serif;
    font-size: clamp(3.55rem, 4.7vw, 5.05rem);
    font-weight: 600;
    letter-spacing: -0.05em;
    line-height: 0.98;
    text-wrap: balance;
  }

  .service-hero[data-title-density='long'] h1 {
    max-width: 15.2ch;
    font-size: clamp(3.15rem, 4.15vw, 4.45rem);
    line-height: 1.01;
  }

  .service-hero[data-service='site-institucional'] {
    padding-top: clamp(7rem, 8.7vw, 8.35rem);
  }

  .service-hero[data-service='site-institucional']::before {
    mask-image: radial-gradient(circle at 55% 44%, black, transparent 65%);
  }

  .service-hero[data-service='site-institucional'] .service-hero__glow {
    background:
      linear-gradient(
        90deg,
        rgba(8, 8, 8, 0.92),
        rgba(8, 8, 8, 0.36) 49%,
        rgba(8, 8, 8, 0.6)
      ),
      radial-gradient(
        ellipse at 55% 52%,
        rgba(235, 194, 116, 0.2),
        transparent 34rem
      ),
      radial-gradient(
        ellipse at 42% 58%,
        rgba(223, 189, 121, 0.1),
        transparent 26rem
      );
  }

  .service-hero[data-service='site-institucional'] .service-hero__inner {
    grid-template-columns: minmax(29rem, 0.92fr) minmax(34rem, 1.08fr);
    gap: clamp(0.8rem, 2.1vw, 2.25rem);
    min-height: calc(100svh - 11.4rem);
  }

  .service-hero[data-service='site-institucional'] .service-hero__copy {
    padding-top: clamp(0rem, 1.2vw, 0.75rem);
  }

  .service-hero[data-service='site-institucional'] h1 {
    max-width: 12.2ch;
    font-size: clamp(3.28rem, 4.28vw, 4.58rem);
    line-height: 0.95;
  }

  .service-hero[data-service='site-institucional'] .service-lead {
    max-width: 31.6rem;
    color: rgba(236, 229, 219, 0.87);
    line-height: 1.64;
  }

  .service-hero[data-service='site-institucional'] .service-actions {
    margin-top: 2.05rem;
  }

  .service-hero[data-service='landing-page'] .service-hero__glow {
    background:
      linear-gradient(
        90deg,
        rgba(8, 8, 8, 0.92),
        rgba(8, 8, 8, 0.34) 50%,
        rgba(8, 8, 8, 0.58)
      ),
      radial-gradient(
        ellipse at 56% 50%,
        rgba(235, 194, 116, 0.2),
        transparent 33rem
      ),
      radial-gradient(
        ellipse at 42% 60%,
        rgba(223, 189, 121, 0.08),
        transparent 25rem
      );
  }

  .service-hero[data-service='landing-page'] .service-hero__inner {
    grid-template-columns: minmax(29rem, 0.91fr) minmax(34rem, 1.09fr);
    gap: clamp(0.85rem, 2vw, 2.15rem);
    min-height: calc(100svh - 11.7rem);
  }

  .service-hero[data-service='landing-page'][data-title-density='long'] h1 {
    max-width: 14.2ch;
    font-size: clamp(2.92rem, 3.82vw, 4.08rem);
    line-height: 0.98;
  }

  .service-hero[data-service='landing-page'] .service-lead {
    max-width: 31.8rem;
    color: rgba(236, 229, 219, 0.87);
    line-height: 1.63;
  }

  .service-hero[data-service='landing-page'] .service-actions {
    gap: 0.75rem;
    margin-top: 1.95rem;
  }

  .service-hero h1 em {
    display: block;
    color: #dfbd79;
    font-style: italic;
    font-weight: 600;
  }

  .service-lead {
    max-width: 33.5rem;
    margin: 1.2rem 0 0;
    color: rgba(226, 218, 208, 0.82);
    font-size: clamp(1.02rem, 1.18vw, 1.1rem);
    font-weight: 300;
    line-height: 1.68;
    text-wrap: pretty;
  }

  .service-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 2.35rem;
  }

  .service-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3.45rem;
    padding: 1rem 1.45rem;
    border: 1px solid rgba(230, 222, 211, 0.2);
    color: #f5f2ef;
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.22em;
    line-height: 1.35;
    text-align: center;
    text-transform: uppercase;
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      color 180ms ease,
      background-color 180ms ease,
      box-shadow 180ms ease;
  }

  .service-button:hover,
  .service-button:focus-visible {
    transform: translateY(-2px);
  }

  .service-button:active {
    transform: scale(0.96);
  }

  .service-button--solid {
    max-width: 25rem;
    border-color: #d9b66d;
    background: linear-gradient(180deg, #edcf8b, #cfa967);
    color: #382600;
    box-shadow: 0 20px 42px rgba(207, 169, 103, 0.16);
  }

  .service-button--outline:hover,
  .service-button--outline:focus-visible {
    border-color: rgba(229, 196, 135, 0.55);
    background: rgba(229, 196, 135, 0.055);
    color: #e5c487;
  }

  .service-features {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1px;
    width: min(100%, 40rem);
    margin-top: clamp(3rem, 5vw, 4.5rem);
    border: 1px solid rgba(229, 218, 207, 0.11);
    background: rgba(229, 218, 207, 0.08);
  }

  .service-feature {
    display: grid;
    gap: 0.7rem;
    min-width: 0;
    padding: 1.1rem;
    background: rgba(13, 14, 14, 0.76);
  }

  .service-feature__icon {
    display: grid;
    place-items: center;
    width: 2.85rem;
    height: 2.85rem;
    border: 1px solid rgba(229, 196, 135, 0.5);
    border-radius: 999px;
    color: #d9ae5f;
    background: rgba(12, 12, 12, 0.24);
  }

  .service-feature strong {
    color: #f5f2ef;
    font-family: 'Newsreader', serif;
    font-size: 1.25rem;
    letter-spacing: -0.032em;
    line-height: 1.05;
    text-wrap: balance;
  }

  .service-feature p {
    margin: 0;
    color: rgba(226, 218, 208, 0.76);
    font-size: 0.9rem;
    font-weight: 300;
    line-height: 1.45;
  }

  .service-hero__media {
    position: relative;
    z-index: 1;
    min-width: 0;
  }

  .service-hero[data-service='site-institucional'] .service-hero__media {
    isolation: isolate;
    transform: translate(-0.7rem, -0.9rem);
  }

  .service-hero[data-service='landing-page'] .service-hero__media {
    isolation: isolate;
    transform: translate(-0.85rem, -0.75rem);
  }

  .service-hero[data-service='landing-page'] .service-orbit {
    top: 8%;
    left: 10%;
    width: 52%;
    opacity: 0.72;
  }

  .service-hero[data-service='site-institucional'] .service-hero__media::before {
    content: none;
  }

  .service-orbit {
    position: absolute;
    top: 6%;
    left: 12%;
    z-index: -1;
    width: 56%;
    aspect-ratio: 1;
    border: 1px solid rgba(211, 169, 98, 0.28);
    border-radius: 999px;
    box-shadow: 0 0 90px rgba(211, 169, 98, 0.14);
  }

  .service-hero__media img {
    width: min(100%, 48rem);
    height: auto;
    margin-inline: auto;
    filter: drop-shadow(0 34px 70px rgba(0, 0, 0, 0.28));
  }

  .service-hero[data-service='site-institucional'] .service-hero__media img {
    width: min(90%, 41rem);
    filter:
      drop-shadow(0 2.2rem 4.8rem rgba(0, 0, 0, 0.34))
      drop-shadow(0 0 2.4rem rgba(223, 189, 121, 0.08));
  }

  .service-hero[data-service='landing-page'] .service-hero__media img {
    width: min(96%, 45rem);
    filter:
      drop-shadow(0 2.35rem 5rem rgba(0, 0, 0, 0.34))
      drop-shadow(0 0 2.4rem rgba(223, 189, 121, 0.09));
  }

  @media (max-width: 900px) {
    .service-hero {
      padding: 7rem 1.15rem 3rem;
    }

    .service-hero__inner {
      grid-template-columns: 1fr;
      min-height: auto;
      gap: 2.5rem;
    }

    .service-hero__copy {
      justify-items: center;
      text-align: center;
    }

    .service-hero h1 {
      max-width: 13ch;
      font-size: clamp(3rem, 9.4vw, 4.5rem);
    }

    .service-hero[data-title-density='long'] h1 {
      max-width: 16ch;
      font-size: clamp(2.75rem, 8.4vw, 3.9rem);
    }

    .service-lead {
      max-width: 38rem;
    }

    .service-actions {
      justify-content: center;
      width: min(100%, 36rem);
    }

    .service-button {
      flex: 1 1 14rem;
      min-width: 0;
    }

    .service-features {
      width: min(100%, 38rem);
    }

    .service-hero[data-service='site-institucional'] {
      padding-top: 7rem;
    }

    .service-hero[data-service='site-institucional'] .service-hero__inner {
      grid-template-columns: 1fr;
      gap: 1.8rem;
      min-height: auto;
    }

    .service-hero[data-service='site-institucional'] h1 {
      max-width: 13ch;
      font-size: clamp(2.82rem, 8.9vw, 4.05rem);
      line-height: 0.98;
    }

    .service-hero[data-service='site-institucional'] .service-lead {
      max-width: 35rem;
    }

    .service-hero[data-service='site-institucional'] .service-actions {
      margin-top: 1.9rem;
    }

    .service-hero[data-service='site-institucional'] .service-hero__media {
      width: min(100%, 37rem);
      margin: 0 auto -0.5rem;
      transform: none;
    }

    .service-hero[data-service='landing-page'] {
      padding-top: 7rem;
    }

    .service-hero[data-service='landing-page'] .service-hero__inner {
      grid-template-columns: 1fr;
      gap: 1.15rem;
      min-height: auto;
    }

    .service-hero[data-service='landing-page'] .service-hero__copy {
      display: contents;
      text-align: center;
    }

    .service-hero[data-service='landing-page'] :global(.breadcrumbs),
    .service-hero[data-service='landing-page'] h1,
    .service-hero[data-service='landing-page'] .service-lead,
    .service-hero[data-service='landing-page'] .service-actions,
    .service-hero[data-service='landing-page'] .service-features,
    .service-hero[data-service='landing-page'] .service-hero__media {
      justify-self: center;
    }

    .service-hero[data-service='landing-page'] :global(.breadcrumbs) {
      order: 1;
    }

    .service-hero[data-service='landing-page'] h1 {
      order: 2;
    }

    .service-hero[data-service='landing-page'] .service-lead {
      order: 3;
    }

    .service-hero[data-service='landing-page'] .service-actions {
      order: 4;
    }

    .service-hero[data-service='landing-page'] .service-hero__media {
      order: 5;
    }

    .service-hero[data-service='landing-page'] .service-features {
      order: 6;
    }

    .service-hero[data-service='landing-page'][data-title-density='long'] h1 {
      max-width: 15ch;
      font-size: clamp(2.68rem, 8.4vw, 3.78rem);
      line-height: 1;
    }

    .service-hero[data-service='landing-page'] .service-lead {
      max-width: 34.5rem;
      margin-top: 0;
      line-height: 1.62;
    }

    .service-hero[data-service='landing-page'] .service-actions {
      gap: 0.75rem;
      margin-top: 0.45rem;
    }

    .service-hero[data-service='landing-page'] .service-hero__media {
      width: min(100%, 38rem);
      margin: -0.65rem auto -0.45rem;
      transform: none;
    }
  }

  @media (max-width: 560px) {
    .service-hero {
      padding-inline: 0.9rem;
    }

    .service-eyebrow {
      margin-bottom: 1.25rem;
      font-size: 0.64rem;
      letter-spacing: 0.2em;
    }

    .service-hero h1 {
      max-width: min(12.6ch, 100%);
      font-size: clamp(2.42rem, 10.4vw, 3.25rem);
      letter-spacing: -0.045em;
      line-height: 1;
    }

    .service-hero[data-title-density='long'] h1 {
      max-width: min(15.8ch, 100%);
      font-size: clamp(2.14rem, 8.8vw, 2.86rem);
      line-height: 1.04;
    }

    .service-lead {
      font-size: 1rem;
      line-height: 1.68;
    }

    .service-actions {
      display: grid;
      grid-template-columns: 1fr;
    }

    .service-button {
      width: 100%;
      padding-inline: 1rem;
      font-size: 0.64rem;
      letter-spacing: 0.17em;
      white-space: normal;
    }

    .service-features {
      grid-template-columns: 1fr;
    }

    .service-feature {
      grid-template-columns: 2.85rem 1fr;
      column-gap: 0.9rem;
      text-align: left;
    }

    .service-feature__icon {
      grid-row: span 2;
    }

    .service-hero[data-service='site-institucional'] h1 {
      max-width: min(11.8ch, 100%);
      font-size: clamp(2.28rem, 9.8vw, 3.06rem);
      line-height: 1;
    }

    .service-hero[data-service='site-institucional'] .service-lead {
      font-size: 0.98rem;
      line-height: 1.62;
    }

    .service-hero[data-service='site-institucional'] .service-actions {
      margin-top: 1.65rem;
    }

    .service-hero[data-service='site-institucional'] .service-hero__media {
      width: min(100%, 31rem);
      margin-top: -0.35rem;
    }

    .service-hero[data-service='landing-page'][data-title-density='long'] h1 {
      max-width: min(14.4ch, 100%);
      font-size: clamp(2.18rem, 8.5vw, 2.72rem);
      line-height: 1.04;
    }

    .service-hero[data-service='landing-page'] .service-lead {
      max-width: 100%;
      margin-top: 0;
      font-size: 0.98rem;
      line-height: 1.62;
    }

    .service-hero[data-service='landing-page'] .service-actions {
      gap: 0.72rem;
      margin-top: 0.35rem;
    }

    .service-hero[data-service='landing-page'] .service-hero__media {
      width: min(100%, 31rem);
      margin-top: -0.85rem;
    }

    .service-hero[data-service='landing-page'] .service-features {
      width: min(100%, 31rem);
    }

    .service-hero[data-service='landing-page'] .service-feature {
      grid-template-columns: 2.45rem 1fr;
      column-gap: 0.78rem;
      min-height: 0;
      padding: 0.92rem 1rem;
    }

    .service-hero[data-service='landing-page'] .service-feature__icon {
      width: 2.45rem;
      height: 2.45rem;
    }

    .service-hero[data-service='landing-page'] .service-feature strong {
      font-size: 1.14rem;
    }

    .service-hero[data-service='landing-page'] .service-feature p {
      font-size: 0.86rem;
      line-height: 1.42;
    }
  }
</style>
