---
import FaqSection from '../FaqSection.astro';
import HomeCta from '../HomeCta.astro';
import PortfolioShowcase from '../PortfolioShowcase.astro';
import SiteFooter from '../SiteFooter.astro';
import SiteNav from '../SiteNav.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { featuredPortfolioProjects } from '../../data/site';
import { getInsightPath, publishedInsights } from '../../data/insights';
import {
  getServicePageSchema,
  type ServicePageContent,
} from '../../data/servicePages';
import ServiceAudienceSection from './ServiceAudienceSection.astro';
import ServiceCardsSection from './ServiceCardsSection.astro';
import ServiceHero from './ServiceHero.astro';
import ServiceProcessSection from './ServiceProcessSection.astro';

interface Props {
  page: ServicePageContent;
}

const { page } = Astro.props;
const relatedInsights = publishedInsights.slice(0, 2);
---

<BaseLayout
  namespace={page.namespace}
  title={page.title}
  description={page.description}
  canonicalPath={page.canonicalPath}
  schema={getServicePageSchema(page)}>
  <main class='service-page'>
    <SiteNav
      whatsappHref={page.whatsappHref}
      brandHref='/'
      brandAriaLabel='Luan Alves, página inicial'
    />

    <ServiceHero page={page} />

    <ServiceCardsSection
      id='beneficios'
      eyebrow={page.benefits.eyebrow}
      title={page.benefits.title}
      accent={page.benefits.accent}
      copy={page.benefits.copy}
      items={page.benefits.items}
      motionName='benefits'
    />

    <ServiceAudienceSection
      eyebrow={page.audience.eyebrow}
      title={page.audience.title}
      accent={page.audience.accent}
      copy={page.audience.copy}
      items={page.audience.items}
    />

    <ServiceProcessSection
      eyebrow={page.process.eyebrow}
      title={page.process.title}
      accent={page.process.accent}
      copy={page.process.copy}
      items={page.process.items}
    />

    <ServiceCardsSection
      id='incluso'
      eyebrow={page.included.eyebrow}
      title={page.included.title}
      accent={page.included.accent}
      copy={page.included.copy}
      items={page.included.items}
      motionName='included'
    />

    <ServiceCardsSection
      id='diferenciais'
      eyebrow={page.differentials.eyebrow}
      title={page.differentials.title}
      accent={page.differentials.accent}
      copy={page.differentials.copy}
      items={page.differentials.items}
      motionName='differentials'
    />

    <PortfolioShowcase
      projects={featuredPortfolioProjects}
      copy='Projetos reais usados como referência de acabamento, performance e presença digital profissional.'
      moreHref='/portfolio/'
    />

    <section class='service-reading' aria-labelledby='service-reading-title'>
      <div class='service-reading__inner'>
        <div class='service-reading__copy'>
          <p class='editorial-eyebrow'>Leituras relacionadas</p>
          <h2 id='service-reading-title'>
            Conteúdo para avançar com mais clareza.
          </h2>
          <p>
            Se você ainda está comparando formatos, escopo ou momento ideal de
            publicar, estes conteúdos ajudam a tomar a decisão com menos ruído.
          </p>
        </div>

        <div class='service-reading__grid'>
          {
            relatedInsights.map((post) => (
              <a class='service-reading__card' href={getInsightPath(post)}>
                <span class='service-reading__badge'>{post.category}</span>
                <strong>{post.title}</strong>
                <p>{post.excerpt}</p>
                <span class='service-reading__meta'>
                  {post.date} · {post.readTime}
                </span>
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <FaqSection items={page.faq} />

    <HomeCta
      whatsappHref={page.whatsappHref}
      title={page.cta.title}
      copy={page.cta.copy}
      buttonLabel={page.cta.buttonLabel}
    />
  </main>

  <SiteFooter brandHref='/' />
</BaseLayout>

<style>
  :global(body) {
    background: #0f1010;
  }

  :global(html),
  :global(body) {
    overflow-x: clip;
  }

  .service-page {
    min-height: 100svh;
    overflow-x: hidden;
    background:
      radial-gradient(
        circle at 73% 42%,
        rgba(218, 176, 101, 0.18),
        transparent 27rem
      ),
      radial-gradient(
        circle at 43% 103%,
        rgba(229, 196, 135, 0.09),
        transparent 28rem
      ),
      linear-gradient(115deg, rgba(7, 8, 8, 0.99) 0%, #151514 52%, #0d0e0e 100%);
    color: #f4f1ee;
  }

  .service-reading {
    padding: clamp(4.2rem, 5vw, 5.4rem) 1.15rem 0;
  }

  .service-reading__inner {
    display: grid;
    gap: 2rem;
    width: min(100%, 82rem);
    margin: 0 auto;
  }

  .service-reading__copy {
    display: grid;
    gap: 0.9rem;
    max-width: 40rem;
  }

  .service-reading__eyebrow {
    margin: 0;
    color: #dfbd79;
    font-size: 0.68rem;
    font-weight: 900;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .service-reading__copy h2 {
    margin: 0;
    color: #f4f1ee;
    font-family: 'Newsreader', serif;
    font-size: clamp(2.5rem, 4.6vw, 4rem);
    font-weight: 600;
    letter-spacing: -0.045em;
    line-height: 1;
    text-wrap: balance;
  }

  .service-reading__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .service-reading__card {
    display: grid;
    gap: 0.8rem;
    min-width: 0;
    padding: 1.3rem;
    border: 1px solid rgba(229, 218, 207, 0.14);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.018), transparent 40%),
      rgba(16, 17, 16, 0.7);
    box-shadow:
      inset 0 0 0 1px rgba(255, 255, 255, 0.012),
      0 22px 52px rgba(0, 0, 0, 0.16);
    transition:
      border-color 180ms ease,
      transform 180ms ease,
      box-shadow 180ms ease;
  }

  .service-reading__card:hover,
  .service-reading__card:focus-visible {
    border-color: rgba(229, 196, 135, 0.42);
    transform: translateY(-3px);
    box-shadow:
      inset 0 0 0 1px rgba(255, 255, 255, 0.018),
      0 28px 60px rgba(0, 0, 0, 0.2);
  }

  .service-reading__badge,
  .service-reading__meta {
    color: #dfbd79;
    font-size: 0.62rem;
    font-weight: 900;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .service-reading__card strong {
    color: #f4f1ee;
    font-family: 'Newsreader', serif;
    font-size: clamp(1.45rem, 2.3vw, 1.85rem);
    font-weight: 600;
    letter-spacing: -0.04em;
    line-height: 1.08;
    text-wrap: balance;
  }

  .service-reading__card p {
    margin: 0;
    color: rgba(226, 218, 208, 0.78);
    line-height: 1.65;
  }

  @media (max-width: 900px) {
    .service-reading__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
