---
interface InsightFaqItem {
  question: string;
  answer: string;
}

interface Props {
  items: InsightFaqItem[];
  id?: string;
  openFirst?: boolean;
}

const {
  items,
  id = 'faq',
  openFirst = true,
} = Astro.props;
---

<section class='insight-faq' id={id} aria-label='Perguntas frequentes'>
  <div class='insight-faq__list'>
    {
      items.map((item, index) => (
        <details class='insight-faq__item' open={openFirst && index === 0}>
          <summary>
            <span class='insight-faq__question'>{item.question}</span>
            <span class='insight-faq__toggle' aria-hidden='true'>
              <svg width='14' height='14' viewBox='0 0 14 14' fill='none'>
                <path
                  d='M2 5l5 5 5-5'
                  stroke='currentColor'
                  stroke-width='1.5'
                  stroke-linecap='round'
                  stroke-linejoin='round'></path>
              </svg>
            </span>
          </summary>
          <p>{item.answer}</p>
        </details>
      ))
    }

    <div class='insight-faq__cta'>
      <div class='insight-faq__cta-copy'>
        <p class='insight-faq__cta-title'>Ainda tem dúvidas?</p>
        <p class='insight-faq__cta-text'>
          Tiro sua dúvida direto no WhatsApp, sem enrolação.
        </p>
      </div>

      <a
        class='button button-outline button-compact'
        href='https://wa.me/5591982890565'
        target='_blank'
        rel='noopener noreferrer'>
        <span class='material-symbols-outlined' aria-hidden='true'>chat</span>
        Falar comigo
      </a>
    </div>
  </div>
</section>

<style>
  .insight-faq {
    margin: 2rem 0;
  }

  .insight-faq__list {
    display: grid;
    gap: 0;
  }

  .insight-faq__item {
    border-bottom: 0.5px solid rgba(77, 70, 58, 0.34);
    background: transparent;
  }

  .insight-faq__item:first-child {
    border-top: 0.5px solid rgba(77, 70, 58, 0.34);
  }

  .insight-faq__item:hover,
  .insight-faq__item:focus-within {
    border-color: rgba(229, 196, 135, 0.32);
  }

  .insight-faq__item summary {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 1.2rem;
    gap: 1rem;
    align-items: start;
    min-height: 3.5rem;
    padding: 1rem 1rem 0.95rem;
    cursor: pointer;
    list-style: none;
  }

  .insight-faq__item summary::-webkit-details-marker {
    display: none;
  }

  .insight-faq__question {
    color: var(--text);
    font-family: 'Newsreader', serif;
    font-size: clamp(1.35rem, 2.1vw, 1.72rem);
    font-weight: 600;
    letter-spacing: -0.035em;
    line-height: 1.1;
    text-wrap: balance;
  }

  .insight-faq__toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.2rem;
    height: 1.2rem;
    margin-top: 0.1rem;
    color: var(--primary);
    transition: transform 180ms ease;
  }

  .insight-faq__toggle svg {
    display: block;
  }

  .insight-faq__item[open] .insight-faq__toggle {
    transform: rotate(180deg);
  }

  .insight-faq__item > p {
    margin: 0;
    padding: 0 1rem 1rem;
    color: var(--muted);
    font-size: clamp(0.98rem, 1.2vw, 1.05rem);
    line-height: 1.76;
    text-wrap: pretty;
  }

  .insight-faq__cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 1.25rem;
    padding: 1rem;
    border: 0.5px solid rgba(77, 70, 58, 0.34);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.016), transparent 52%),
      var(--surface-elevated);
  }

  .insight-faq__cta-copy {
    display: grid;
    gap: 0.35rem;
  }

  .insight-faq__cta-title,
  .insight-faq__cta-text {
    margin: 0;
  }

  .insight-faq__cta-title {
    color: var(--text);
    font-family: 'Newsreader', serif;
    font-size: clamp(1.35rem, 2.1vw, 1.72rem);
    font-weight: 600;
    letter-spacing: -0.035em;
    line-height: 1.1;
  }

  .insight-faq__cta-text {
    color: var(--muted);
    font-size: clamp(0.94rem, 1.12vw, 1rem);
    line-height: 1.72;
    text-wrap: pretty;
  }

  .insight-faq__cta :global(.button) {
    flex: 0 0 auto;
  }

  .insight-faq__cta :global(.material-symbols-outlined) {
    font-size: 1rem;
  }

  @media (max-width: 620px) {
    .insight-faq__item summary {
      gap: 0.85rem;
      padding: 0.95rem 0.95rem 0.9rem;
    }

    .insight-faq__question {
      font-size: 1.26rem;
    }

    .insight-faq__item > p {
      padding: 0 0.95rem 0.95rem;
    }

    .insight-faq__cta {
      align-items: stretch;
      flex-direction: column;
      padding: 0.95rem;
    }

    .insight-faq__cta :global(.button) {
      width: 100%;
    }
  }
</style>
