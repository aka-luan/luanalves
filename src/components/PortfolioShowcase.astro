---
import { projects as defaultProjects } from '../data/site';

interface ProjectItem {
  title: string;
  subtitle: string;
  image: string;
  alt: string;
  url?: string;
  href?: string;
  position?: string;
}

interface Props {
  projects?: ProjectItem[];
  id?: string;
  eyebrow?: string;
  title?: string;
  copy?: string;
  moreHref?: string;
  moreLabel?: string;
  motion?: boolean;
}

const {
  projects = defaultProjects,
  id = 'portfolio',
  eyebrow = 'Portfólio',
  title = 'Projetos selecionados.',
  copy = 'Alguns sites já desenvolvidos para empresas reais, com diferentes objetivos e estilos.',
  moreHref = '/#portfolio',
  moreLabel = 'Ver portfólio completo',
  motion = true,
} = Astro.props;

const defaultPositions = ['center 44%', 'center 50%', 'center 47%'];
const sectionMotionAttrs = motion ? { 'data-motion-section': 'portfolio' } : {};
const eyebrowMotionAttrs = motion
  ? { 'data-motion-heading': '', 'data-motion-hidden': 'y-sm' }
  : {};
const titleMotionAttrs = motion
  ? { 'data-motion-heading': '', 'data-motion-hidden': 'y-md' }
  : {};
const copyMotionAttrs = motion
  ? { 'data-motion-copy': '', 'data-motion-hidden': 'y-md' }
  : {};
const moreMotionAttrs = motion
  ? { 'data-motion-item': 'project', 'data-motion-hidden': 'y-sm' }
  : {};
---

<section
  class='portfolio-showcase'
  id={id}
  aria-labelledby={`${id}-title`}
  {...sectionMotionAttrs}>
  <div class='portfolio-showcase__glow' aria-hidden='true'></div>

  <div class='portfolio-showcase__inner'>
    <div class='portfolio-showcase__copy'>
      <p class='creation-eyebrow portfolio-showcase__eyebrow' {...eyebrowMotionAttrs}>{eyebrow}</p>

      <h2 id={`${id}-title`} {...titleMotionAttrs}>
        {
          title === 'Projetos selecionados.' ? (
            <>
              <span>Projetos</span>
              <em>selecionados.</em>
            </>
          ) : (
            title
          )
        }
      </h2>

      <p {...copyMotionAttrs}>{copy}</p>
    </div>

    <div class='portfolio-showcase__grid' aria-label='Projetos selecionados'>
      {
        projects.map((item, index) => {
          const cardMotionAttrs = motion
            ? {
                'data-motion-item': 'project',
                'data-motion-hidden': index % 2 === 0 ? 'x-left' : 'x-right',
              }
            : {};

          return (
            <a
              class='portfolio-showcase__card'
              href={item.url ?? item.href}
              target='_blank'
              rel='noreferrer'
              {...cardMotionAttrs}>
              <span class='portfolio-showcase__media'>
                <img
                  src={item.image}
                  alt={item.alt}
                  width='900'
                  height='650'
                  style={`object-position: ${
                    item.position ?? defaultPositions[index] ?? 'center'
                  };`}
                  loading='lazy'
                  decoding='async'
                  data-motion-image={motion ? '' : undefined}
                />
              </span>

              <span class='portfolio-showcase__meta'>
                <span>
                  <strong>{item.title}</strong>
                  <small>{item.subtitle}</small>
                </span>

                <span class='portfolio-showcase__arrow' aria-hidden='true'>
                  north_east
                </span>
              </span>
            </a>
          );
        })
      }
    </div>

    <a class='portfolio-showcase__more' href={moreHref} {...moreMotionAttrs}>
      {moreLabel}
      <span class='material-symbols-outlined' aria-hidden='true'>
        north_east
      </span>
    </a>
  </div>
</section>

<style>
  .portfolio-showcase {
    position: relative;
    padding: clamp(6.4rem, 7.4vw, 7.65rem) clamp(1.5rem, 6.25vw, 5.85rem)
      clamp(5.3rem, 6.4vw, 6.45rem);
    overflow: hidden;
  }

  .portfolio-showcase::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -4;
    background:
      radial-gradient(
        circle at 50% 23%,
        rgba(218, 176, 101, 0.16),
        transparent 28rem
      ),
      radial-gradient(
        ellipse at 18% 74%,
        rgba(229, 196, 135, 0.08),
        transparent 30rem
      ),
      linear-gradient(115deg, #101111 0%, #171716 48%, #0c0d0d 100%);
  }

  .portfolio-showcase__glow {
    position: absolute;
    inset: 0;
    z-index: -3;
    background:
      linear-gradient(
        180deg,
        rgba(7, 7, 7, 0.52),
        rgba(7, 7, 7, 0.08) 42%,
        rgba(7, 7, 7, 0.46)
      ),
      radial-gradient(
        ellipse at 50% 18%,
        rgba(229, 196, 135, 0.11),
        transparent 28rem
      );
    pointer-events: none;
  }

  .portfolio-showcase__inner {
    display: grid;
    justify-items: center;
    width: min(100%, 84.8rem);
    margin: 0 auto;
  }

  .portfolio-showcase__copy {
    display: grid;
    justify-items: center;
    max-width: 68rem;
    text-align: center;
  }

  .portfolio-showcase__eyebrow {
    margin-bottom: 1.45rem;
  }

  .portfolio-showcase__copy h2 {
    margin: 0;
    color: #f5f2ef;
    font-family: 'Newsreader', serif;
    font-size: clamp(3.55rem, 4.9vw, 5rem);
    font-weight: 600;
    letter-spacing: -0.058em;
    line-height: 0.96;
    text-wrap: balance;
    white-space: nowrap;
  }

  .portfolio-showcase__copy h2 span,
  .portfolio-showcase__copy h2 em {
    display: inline;
  }

  .portfolio-showcase__copy h2 em {
    color: #dfbd79;
    font-style: italic;
    font-weight: 600;
  }

  .portfolio-showcase__copy > p {
    max-width: 30.5rem;
    margin: 1.55rem 0 0;
    color: rgba(226, 218, 208, 0.78);
    font-size: clamp(1rem, 1.12vw, 1.08rem);
    font-weight: 300;
    line-height: 1.48;
    text-wrap: pretty;
  }

  .portfolio-showcase__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(1rem, 1.8vw, 1.35rem);
    width: 100%;
    margin-top: clamp(2.45rem, 3.45vw, 3.2rem);
  }

  .portfolio-showcase__card {
    display: grid;
    grid-template-rows: minmax(0, 1fr) auto;
    min-width: 0;
    overflow: hidden;
    border: 1px solid rgba(229, 218, 207, 0.18);
    border-radius: 0.45rem;
    background:
      linear-gradient(145deg, rgba(255, 255, 255, 0.03), transparent 42%),
      rgba(16, 17, 16, 0.68);
    box-shadow:
      inset 0 0 0 1px rgba(255, 255, 255, 0.012),
      0 28px 62px rgba(0, 0, 0, 0.18);
    transition:
      border-color 220ms ease,
      transform 220ms ease,
      box-shadow 220ms ease;
  }

  .portfolio-showcase__card:hover,
  .portfolio-showcase__card:focus-visible {
    border-color: rgba(229, 196, 135, 0.48);
    transform: translateY(-0.35rem);
    box-shadow:
      inset 0 0 0 1px rgba(255, 255, 255, 0.018),
      0 34px 72px rgba(0, 0, 0, 0.24);
  }

  .portfolio-showcase__card:active {
    transform: translateY(-0.15rem) scale(0.96);
  }

  .portfolio-showcase__media {
    position: relative;
    display: block;
    aspect-ratio: 1.25 / 1;
    overflow: hidden;
    background: #121312;
  }

  .portfolio-showcase__media::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, transparent 62%, rgba(0, 0, 0, 0.18)),
      radial-gradient(circle at 50% 100%, rgba(223, 189, 121, 0.08), transparent 50%);
    opacity: 0.42;
    pointer-events: none;
  }

  .portfolio-showcase__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 1;
    filter: saturate(1.04) contrast(1.04) brightness(1.06);
    transform: scale(1.01);
    transition:
      opacity 260ms ease,
      filter 260ms ease,
      transform 700ms ease;
  }

  .portfolio-showcase__card:hover .portfolio-showcase__media img,
  .portfolio-showcase__card:focus-visible .portfolio-showcase__media img {
    opacity: 1;
    filter: saturate(1.08) contrast(1.06) brightness(1.08);
    transform: scale(1.055);
  }

  .portfolio-showcase__meta {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 2.5rem;
    gap: 1rem;
    align-items: end;
    min-height: 7.7rem;
    padding: clamp(1.4rem, 2vw, 1.75rem);
  }

  .portfolio-showcase__meta strong {
    display: block;
    color: #f5f2ef;
    font-family: 'Newsreader', serif;
    font-size: clamp(1.82rem, 2.25vw, 2.18rem);
    font-weight: 600;
    letter-spacing: -0.055em;
    line-height: 1;
    text-wrap: balance;
  }

  .portfolio-showcase__meta small {
    display: block;
    margin-top: 0.86rem;
    color: #dfbd79;
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.26em;
    line-height: 1.35;
    text-transform: uppercase;
  }

  .portfolio-showcase__arrow,
  .portfolio-showcase__more .material-symbols-outlined {
    color: #dfbd79;
    font-family: 'Material Symbols Outlined';
    font-size: 1.8rem;
    font-weight: normal;
    font-style: normal;
    line-height: 1;
    letter-spacing: normal;
    text-transform: none;
    white-space: nowrap;
    word-wrap: normal;
    direction: ltr;
    font-feature-settings: 'liga';
    -webkit-font-feature-settings: 'liga';
    -webkit-font-smoothing: antialiased;
    transition: transform 220ms ease;
  }

  .portfolio-showcase__card:hover .portfolio-showcase__arrow,
  .portfolio-showcase__card:focus-visible .portfolio-showcase__arrow,
  .portfolio-showcase__more:hover .material-symbols-outlined,
  .portfolio-showcase__more:focus-visible .material-symbols-outlined {
    transform: translate(0.16rem, -0.16rem);
  }

  .portfolio-showcase__more {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    min-width: min(100%, 19.5rem);
    min-height: 3.55rem;
    margin-top: clamp(2.1rem, 3.1vw, 2.9rem);
    padding: 1rem 1.65rem;
    border: 1px solid rgba(229, 218, 207, 0.18);
    color: #dfbd79;
    font-size: 0.74rem;
    font-weight: 800;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    transition:
      border-color 180ms ease,
      background-color 180ms ease,
      transform 180ms ease;
  }

  .portfolio-showcase__more:hover,
  .portfolio-showcase__more:focus-visible {
    border-color: rgba(229, 196, 135, 0.5);
    background: rgba(229, 196, 135, 0.055);
    transform: translateY(-2px);
  }

  @media (max-width: 900px) {
    .portfolio-showcase {
      padding: 6.5rem 1.15rem 4.8rem;
    }

    .portfolio-showcase__copy h2 {
      font-size: clamp(3.15rem, 10.6vw, 5rem);
      white-space: normal;
    }

    .portfolio-showcase__copy h2 span,
    .portfolio-showcase__copy h2 em {
      display: block;
    }

    .portfolio-showcase__grid {
      grid-template-columns: 1fr;
      width: min(100%, 44rem);
      margin-top: 2.9rem;
    }

    .portfolio-showcase__media {
      aspect-ratio: 1.45 / 1;
    }

    .portfolio-showcase__meta {
      min-height: 6.9rem;
    }
  }

  @media (max-width: 560px) {
    .portfolio-showcase {
      padding-inline: 0.9rem;
    }

    .portfolio-showcase__eyebrow {
      margin-bottom: 1.35rem;
      font-size: 0.64rem;
      letter-spacing: 0.2em;
    }

    .portfolio-showcase__copy h2 {
      font-size: clamp(2.55rem, 12vw, 3.7rem);
      letter-spacing: -0.055em;
    }

    .portfolio-showcase__copy > p {
      font-size: 1rem;
      line-height: 1.55;
    }

    .portfolio-showcase__grid {
      gap: 1rem;
      margin-top: 2.4rem;
    }

    .portfolio-showcase__media {
      aspect-ratio: 1.2 / 1;
    }

    .portfolio-showcase__meta {
      grid-template-columns: minmax(0, 1fr) 2rem;
      min-height: 6.6rem;
      padding: 1.25rem;
    }

    .portfolio-showcase__meta strong {
      font-size: 1.72rem;
    }

    .portfolio-showcase__meta small {
      margin-top: 0.72rem;
      font-size: 0.64rem;
      letter-spacing: 0.18em;
    }

    .portfolio-showcase__more {
      width: 100%;
      min-width: 0;
      margin-top: 2.35rem;
      padding-inline: 1rem;
      font-size: 0.66rem;
      letter-spacing: 0.2em;
    }
  }
</style>
