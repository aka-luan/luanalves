---
---
<section class="min-h-screen flex flex-col justify-center px-8 md:px-20 pt-48 pb-32 relative overflow-hidden" data-section="hero">
  <div class="absolute top-[-10%] right-[-10%] w-[800px] h-[800px] bg-primary-container/5 blur-[160px] rounded-full -z-10">
  </div>
  <div class="max-w-[1440px] mx-auto w-full">
    <h1 class="font-headline text-huge font-bold hero-title mb-8 uppercase">
      <div class="overflow-hidden"><div class="hero-title-line inline-block">Tecnologia</div></div>
      <div class="overflow-hidden"><div class="hero-title-line inline-block">que cabe no</div></div>
      <div class="overflow-hidden"><div class="hero-title-line inline-block"><span class="text-glow italic text-primary-fixed">seu negócio</span></div></div>
    </h1>
    <p class="font-body text-2xl text-on-surface-variant max-w-2xl mb-16 hero-subheadline opacity-0">
      Sistemas sob medida para pequenas empresas que querem crescer sem depender de planilha.
    </p>

    <div class="flex flex-col md:flex-row md:items-center justify-between gap-12 border-t border-white/10 pt-16">
      <div class="flex flex-wrap gap-6">
        <button class="hero-cta group relative px-12 py-5 rounded-full font-bold text-lg overflow-hidden transition-all duration-[var(--duration-base)] ease-[var(--ease-out)] opacity-0">
          <span class="relative z-10 text-on-primary">Ver projetos</span>
          <div class="absolute inset-0 bg-primary-container group-hover:scale-105 transition-transform duration-[var(--duration-base)] ease-[var(--ease-out)]">
          </div>
        </button>
        <button class="hero-cta group px-12 py-5 rounded-full font-bold text-lg border border-outline-variant hover:border-primary transition-all duration-[var(--duration-base)] ease-[var(--ease-out)] opacity-0">
          <span class="text-on-surface-variant group-hover:text-primary transition-colors duration-[var(--duration-base)]">Falar comigo</span>
        </button>
      </div>
      
      <!-- Stagger nos cards de serviços (micro scale) -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-x-12 gap-y-8">
        <div class="flex flex-col gap-2 group cursor-default hero-feature" data-reveal="fade-up">
          <div class="h-px w-8 bg-primary/40 group-hover:w-full transition-all duration-[var(--duration-slow)] ease-[var(--ease-out)]"></div>
          <div class="flex items-center gap-3">
            <span class="material-symbols-outlined text-primary text-xl" style="font-variation-settings: 'wght' 200">terminal</span>
            <span class="font-label text-[10px] uppercase tracking-[0.25em] text-on-surface-variant font-medium">Clean Code</span>
          </div>
        </div>
        <div class="flex flex-col gap-2 group cursor-default hero-feature" data-reveal="fade-up">
          <div class="h-px w-8 bg-primary/40 group-hover:w-full transition-all duration-[var(--duration-slow)] ease-[var(--ease-out)]"></div>
          <div class="flex items-center gap-3">
            <span class="material-symbols-outlined text-primary text-xl" style="font-variation-settings: 'wght' 200">architecture</span>
            <span class="font-label text-[10px] uppercase tracking-[0.25em] text-on-surface-variant font-medium">Editorial UI</span>
          </div>
        </div>
        <div class="flex flex-col gap-2 group cursor-default hero-feature" data-reveal="fade-up">
          <div class="h-px w-8 bg-primary/40 group-hover:w-full transition-all duration-[var(--duration-slow)] ease-[var(--ease-out)]"></div>
          <div class="flex items-center gap-3">
            <span class="material-symbols-outlined text-primary text-xl" style="font-variation-settings: 'wght' 200">bolt</span>
            <span class="font-label text-[10px] uppercase tracking-[0.25em] text-on-surface-variant font-medium">Performance</span>
          </div>
        </div>
        <div class="flex flex-col gap-2 group cursor-default hero-feature" data-reveal="fade-up">
          <div class="h-px w-8 bg-primary/40 group-hover:w-full transition-all duration-[var(--duration-slow)] ease-[var(--ease-out)]"></div>
          <div class="flex items-center gap-3">
            <span class="material-symbols-outlined text-primary text-xl" style="font-variation-settings: 'wght' 200">strategy</span>
            <span class="font-label text-[10px] uppercase tracking-[0.25em] text-on-surface-variant font-medium">Strategy</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Fallback for no-js */
  html.no-js .hero-title-line,
  html.no-js .hero-subheadline,
  html.no-js .hero-cta,
  html.no-js .hero-feature {
    opacity: 1 !important;
    transform: none !important;
  }
</style>
