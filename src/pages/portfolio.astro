---
import SiteFooter from '../components/SiteFooter.astro';
import SiteNav from '../components/SiteNav.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { navigation, projects } from '../data/site';

const siteUrl = 'https://luanalves.com.br';
const whatsappHref =
  'https://wa.me/5591982890565?text=Ol%C3%A1%2C%20Luan!%20Vi%20seu%20portf%C3%B3lio%20e%20quero%20solicitar%20um%20or%C3%A7amento%20para%20um%20site.';

const filters = [
  { label: 'Todos', href: '#portfolio-grid', current: true },
  { label: 'Site Institucional', href: '#site-institucional' },
  { label: 'Landing Page', href: '#landing-page' },
  { label: 'Blog Profissional', href: '#blog-profissional' },
];

const metrics = [
  { value: '12+', label: 'Projetos' },
  { value: '05+', label: 'Anos' },
  { value: '100%', label: 'Entregues' },
];

const slugify = (value: string) =>
  value
    .normalize('NFD')
    .replace(/[\u0300-\u036f]/g, '')
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/(^-|-$)/g, '');

const portfolioSchema = [
  {
    '@type': 'BreadcrumbList',
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        name: 'Início',
        item: siteUrl,
      },
      {
        '@type': 'ListItem',
        position: 2,
        name: 'Portfólio',
        item: `${siteUrl}/portfolio/`,
      },
    ],
  },
  {
    '@type': 'CollectionPage',
    '@id': `${siteUrl}/portfolio/#collection`,
    name: 'Portfólio de Sites Profissionais',
    description:
      'Projetos reais de sites institucionais, landing pages e blogs profissionais desenvolvidos por Luan Alves.',
    url: `${siteUrl}/portfolio/`,
    inLanguage: 'pt-BR',
    mainEntity: {
      '@id': `${siteUrl}/portfolio/#projects`,
    },
  },
  {
    '@type': 'ItemList',
    '@id': `${siteUrl}/portfolio/#projects`,
    name: 'Projetos de portfólio',
    itemListElement: projects.map((project, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      item: {
        '@type': 'CreativeWork',
        name: project.title,
        description: project.summary ?? project.description,
        url: project.externalUrl ?? project.url,
        creator: { '@id': `${siteUrl}/#person` },
        about: project.serviceType,
      },
    })),
  },
];
---

<BaseLayout
  namespace='portfolio'
  title='Portfólio de Sites Profissionais | Luan Alves'
  description='Portfólio com projetos reais de sites institucionais, landing pages e blogs profissionais desenvolvidos com SEO técnico, conversão e código limpo.'
  canonicalPath='/portfolio/'
  schema={portfolioSchema}>
  <main class='portfolio-page' id='top'>
    <SiteNav
      items={navigation}
      whatsappHref={whatsappHref}
      brandHref='/'
      brandAriaLabel='Luan Alves, página inicial'
      motion={false}
    />

    <section class='portfolio-hero' aria-labelledby='portfolio-title'>
      <div class='portfolio-hero__grid hero-grid' aria-hidden='true'></div>
      <div class='portfolio-hero__inner'>
        <nav class='portfolio-breadcrumb' aria-label='Breadcrumb'>
          <a href='/'>Início</a>
          <span aria-hidden='true'>/</span>
          <span>Portfólio</span>
        </nav>

        <div class='portfolio-hero__copy'>
          <h1 id='portfolio-title'>Projetos entregues para empresas reais.</h1>
          <p>
            Sites institucionais, blogs editoriais e landing pages desenvolvidos
            com código limpo, SEO técnico e foco em conversão.
          </p>
        </div>

        <dl class='portfolio-metrics' aria-label='Números do portfólio'>
          {
            metrics.map((metric) => (
              <div>
                <dt>{metric.value}</dt>
                <dd>{metric.label}</dd>
              </div>
            ))
          }
        </dl>
      </div>
    </section>

    <section
      class='portfolio-work'
      aria-labelledby='portfolio-work-title'>
      <div class='portfolio-work__inner'>
        <h2 id='portfolio-work-title' class='sr-only'>Projetos do portfólio</h2>

        <nav class='portfolio-filters' aria-label='Filtrar projetos por serviço'>
          {
            filters.map((filter) => (
              <a
                href={filter.href}
                aria-current={filter.current ? 'true' : undefined}>
                {filter.label}
              </a>
            ))
          }
        </nav>

        <div class='portfolio-grid' id='portfolio-grid'>
          {
            projects.map((project) => {
              const serviceId = slugify(project.serviceType ?? project.subtitle);
              const projectUrl = project.externalUrl ?? project.url;
              const tags = project.tags ?? [];

              return (
                <article
                  class='portfolio-card'
                  id={serviceId}
                  style={`--project-color: ${project.themeColor ?? '#2d2359'};`}>
                  <div class='portfolio-card__mockup' aria-hidden='true'>
                    <div class='mock-browser'>
                      <div class='mock-browser__top'>
                        <span></span>
                        <span></span>
                        <span></span>
                        <i></i>
                      </div>
                      <div class='mock-browser__hero'></div>
                      <div class='mock-browser__line'></div>
                      <div class='mock-browser__line mock-browser__line--short'></div>
                      <div class='mock-browser__blocks'>
                        <span></span>
                        <span></span>
                        <span></span>
                      </div>
                    </div>
                  </div>

                  <div class='portfolio-card__body'>
                    <p class='portfolio-card__type'>{project.serviceType}</p>
                    <h3>{project.title}</h3>
                    <p class='portfolio-card__summary'>
                      {project.summary ?? project.description}
                    </p>

                    <ul class='portfolio-card__tags' aria-label='Tags técnicas'>
                      {tags.map((tag) => <li>{tag}</li>)}
                    </ul>

                    <a href={projectUrl} target='_blank' rel='noreferrer'>
                      <span class='material-symbols-outlined' aria-hidden='true'>
                        north_east
                      </span>
                      Ver projeto
                    </a>
                  </div>
                </article>
              );
            })
          }
        </div>

        <aside class='portfolio-cta' aria-labelledby='portfolio-cta-title'>
          <div>
            <h2 id='portfolio-cta-title'>Tem um projeto em mente?</h2>
            <p>
              Me conta a ideia. Respondo em até 24 horas, de Belém para o Brasil
              todo.
            </p>
          </div>
          <a href={whatsappHref} target='_blank' rel='noreferrer'>
            Falar no WhatsApp
            <span class='material-symbols-outlined' aria-hidden='true'>
              arrow_forward
            </span>
          </a>
        </aside>
      </div>
    </section>
  </main>

  <SiteFooter links={navigation} brandHref='/' motion={false} />
</BaseLayout>

<style>
  :global(html),
  :global(body) {
    overflow-x: clip;
  }

  .portfolio-page {
    min-height: 100svh;
    background:
      radial-gradient(circle at 50% 0%, rgba(229, 196, 135, 0.08), transparent 30rem),
      linear-gradient(180deg, #101010 0%, #141414 44%, #101010 100%);
    color: var(--text);
  }

  .portfolio-hero {
    position: relative;
    overflow: hidden;
    padding: clamp(8rem, 11vw, 10rem) 0 clamp(2.6rem, 5vw, 4rem);
    border-bottom: 1px solid rgba(77, 70, 58, 0.32);
  }

  .portfolio-hero__grid {
    position: absolute;
    inset: 0;
    opacity: 0.42;
    pointer-events: none;
  }

  .portfolio-hero__inner,
  .portfolio-work__inner {
    position: relative;
    z-index: 1;
    width: min(1120px, calc(100vw - 3rem));
    margin: 0 auto;
  }

  .portfolio-breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    margin-bottom: clamp(2.4rem, 5vw, 3.5rem);
    color: var(--subtle);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }

  .portfolio-breadcrumb a {
    color: var(--muted);
    transition: color 180ms ease;
  }

  .portfolio-breadcrumb a:hover,
  .portfolio-breadcrumb a:focus-visible {
    color: var(--primary);
  }

  .portfolio-hero__copy {
    max-width: 44rem;
  }

  .portfolio-hero h1 {
    max-width: 12ch;
    margin: 0;
    color: #f5f2ef;
    font-family: 'Newsreader', serif;
    font-size: clamp(3.2rem, 7.2vw, 5.6rem);
    font-weight: 600;
    letter-spacing: -0.05em;
    line-height: 0.98;
    text-wrap: balance;
  }

  .portfolio-hero__copy p {
    max-width: 40rem;
    margin: 1.35rem 0 0;
    color: rgba(226, 218, 208, 0.72);
    font-size: clamp(1rem, 1.45vw, 1.15rem);
    font-weight: 300;
    line-height: 1.68;
    text-wrap: pretty;
  }

  .portfolio-metrics {
    display: flex;
    flex-wrap: wrap;
    gap: clamp(1.55rem, 4vw, 2.6rem);
    margin: clamp(2.1rem, 4.8vw, 3rem) 0 0;
  }

  .portfolio-metrics div {
    min-width: 4.8rem;
  }

  .portfolio-metrics dt {
    color: #f5f2ef;
    font-size: clamp(1.45rem, 3vw, 1.9rem);
    font-weight: 800;
    line-height: 1;
  }

  .portfolio-metrics dd {
    margin: 0.35rem 0 0;
    color: var(--subtle);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .portfolio-work {
    padding: 0 0 clamp(3.8rem, 7vw, 5.6rem);
  }

  .portfolio-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    padding: clamp(1.25rem, 2.4vw, 1.65rem) 0;
    border-bottom: 1px solid rgba(77, 70, 58, 0.32);
  }

  .portfolio-filters a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.8rem;
    padding: 0.65rem 1.1rem;
    border: 1px solid rgba(229, 218, 207, 0.24);
    color: #f2ede7;
    font-size: 0.88rem;
    font-weight: 800;
    line-height: 1.2;
    transition:
      border-color 180ms ease,
      background-color 180ms ease,
      color 180ms ease,
      transform 180ms ease;
  }

  .portfolio-filters a[aria-current='true'],
  .portfolio-filters a:hover,
  .portfolio-filters a:focus-visible {
    border-color: rgba(229, 196, 135, 0.58);
    background: rgba(229, 196, 135, 0.08);
    color: var(--primary);
  }

  .portfolio-filters a:hover {
    transform: translateY(-2px);
  }

  .portfolio-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(1rem, 2vw, 1.5rem);
    padding-top: clamp(2rem, 4.6vw, 3rem);
  }

  .portfolio-card {
    --project-color: #2d2359;
    display: grid;
    grid-template-rows: auto 1fr;
    min-width: 0;
    overflow: hidden;
    border: 1px solid rgba(229, 218, 207, 0.16);
    background: rgba(28, 27, 27, 0.88);
    box-shadow: var(--shadow-soft);
    transition:
      border-color 220ms ease,
      transform 220ms ease,
      box-shadow 220ms ease;
  }

  .portfolio-card:hover,
  .portfolio-card:focus-within {
    border-color: rgba(229, 196, 135, 0.42);
    transform: translateY(-0.3rem);
    box-shadow: 0 30px 70px rgba(0, 0, 0, 0.28);
  }

  .portfolio-card__mockup {
    padding: 1rem;
    background:
      radial-gradient(circle at 50% 100%, color-mix(in srgb, var(--project-color) 34%, transparent), transparent 70%),
      #111111;
  }

  .mock-browser {
    display: grid;
    gap: 0.42rem;
    min-height: 9.25rem;
    padding: 0.72rem;
    border: 1px solid rgba(229, 218, 207, 0.12);
    background: #111211;
  }

  .mock-browser__top {
    display: grid;
    grid-template-columns: repeat(3, 0.32rem) 1fr;
    gap: 0.34rem;
    align-items: center;
  }

  .mock-browser__top span {
    width: 0.32rem;
    height: 0.32rem;
    border-radius: 999px;
  }

  .mock-browser__top span:nth-child(1) {
    background: #ff6d5e;
  }

  .mock-browser__top span:nth-child(2) {
    background: #ffc84d;
  }

  .mock-browser__top span:nth-child(3) {
    background: #43d464;
  }

  .mock-browser__top i {
    display: block;
    height: 0.78rem;
    margin-left: 0.26rem;
    background: rgba(255, 255, 255, 0.08);
  }

  .mock-browser__hero {
    height: 2.2rem;
    margin-top: 0.6rem;
    background: var(--project-color);
  }

  .mock-browser__line {
    height: 0.34rem;
    background: rgba(255, 255, 255, 0.07);
  }

  .mock-browser__line--short {
    width: 68%;
  }

  .mock-browser__blocks {
    display: grid;
    grid-template-columns: 1.1fr 0.8fr 0.8fr;
    gap: 0.32rem;
    margin-top: 0.35rem;
  }

  .mock-browser__blocks span {
    height: 2rem;
    background: color-mix(in srgb, var(--project-color) 70%, #111211);
  }

  .portfolio-card__body {
    display: grid;
    align-content: start;
    padding: 1.35rem;
  }

  .portfolio-card__type {
    margin: 0;
    color: var(--subtle);
    font-size: 0.68rem;
    font-weight: 900;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .portfolio-card h3 {
    margin: 0.65rem 0 0;
    color: #f5f2ef;
    font-size: 1.15rem;
    font-weight: 850;
    letter-spacing: -0.02em;
    line-height: 1.16;
  }

  .portfolio-card__summary {
    margin: 0.65rem 0 0;
    color: rgba(226, 218, 208, 0.7);
    font-size: 0.9rem;
    line-height: 1.55;
    text-wrap: pretty;
  }

  .portfolio-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.42rem;
    margin: 1rem 0 0;
    padding: 0;
    list-style: none;
  }

  .portfolio-card__tags li {
    display: inline-flex;
    align-items: center;
    min-height: 1.45rem;
    padding: 0.22rem 0.48rem;
    border: 1px solid rgba(229, 218, 207, 0.16);
    background: rgba(255, 255, 255, 0.05);
    color: rgba(226, 218, 208, 0.72);
    font-size: 0.64rem;
    font-weight: 800;
  }

  .portfolio-card__body > a {
    display: inline-flex;
    align-items: center;
    gap: 0.42rem;
    width: fit-content;
    margin-top: 1.15rem;
    color: #f5f2ef;
    font-size: 0.78rem;
    font-weight: 900;
    transition:
      color 180ms ease,
      transform 180ms ease;
  }

  .portfolio-card__body > a .material-symbols-outlined {
    font-size: 1rem;
    color: var(--primary);
    transition: transform 180ms ease;
  }

  .portfolio-card__body > a:hover,
  .portfolio-card__body > a:focus-visible {
    color: var(--primary);
    transform: translateY(-1px);
  }

  .portfolio-card__body > a:hover .material-symbols-outlined,
  .portfolio-card__body > a:focus-visible .material-symbols-outlined {
    transform: translate(0.12rem, -0.12rem);
  }

  .portfolio-cta {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 1.5rem;
    align-items: center;
    margin-top: clamp(2rem, 4vw, 3rem);
    padding: clamp(1.6rem, 3vw, 2.25rem);
    border: 1px solid rgba(229, 218, 207, 0.16);
    background: rgba(32, 31, 31, 0.92);
    box-shadow: var(--shadow-soft);
  }

  .portfolio-cta h2 {
    margin: 0;
    color: #f5f2ef;
    font-size: clamp(1.35rem, 2.5vw, 1.85rem);
    letter-spacing: -0.03em;
  }

  .portfolio-cta p {
    max-width: 42rem;
    margin: 0.45rem 0 0;
    color: rgba(226, 218, 208, 0.68);
    line-height: 1.55;
  }

  .portfolio-cta > a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
    min-height: 3.25rem;
    padding: 0.85rem 1.45rem;
    background: #ebe4dc;
    color: #1b1a18;
    font-size: 0.9rem;
    font-weight: 900;
    white-space: nowrap;
    transition:
      background-color 180ms ease,
      transform 180ms ease;
  }

  .portfolio-cta > a:hover,
  .portfolio-cta > a:focus-visible {
    background: var(--primary);
    transform: translateY(-2px);
  }

  .portfolio-cta .material-symbols-outlined {
    font-size: 1.1rem;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 900px) {
    .portfolio-grid {
      grid-template-columns: 1fr;
      width: min(100%, 36rem);
    }

    .portfolio-cta {
      grid-template-columns: 1fr;
    }

    .portfolio-cta > a {
      width: fit-content;
    }
  }

  @media (max-width: 560px) {
    .portfolio-hero {
      padding-top: 7.2rem;
    }

    .portfolio-hero__inner,
    .portfolio-work__inner {
      width: calc(100vw - 1.5rem);
    }

    .portfolio-breadcrumb {
      gap: 0.45rem;
      margin-bottom: 2rem;
      font-size: 0.6rem;
      letter-spacing: 0.16em;
    }

    .portfolio-hero h1 {
      font-size: clamp(2.8rem, 13.5vw, 3.7rem);
    }

    .portfolio-hero__copy p {
      font-size: 1rem;
      line-height: 1.62;
    }

    .portfolio-metrics {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 0.85rem;
    }

    .portfolio-metrics div {
      min-width: 0;
    }

    .portfolio-metrics dd {
      font-size: 0.58rem;
      letter-spacing: 0.12em;
    }

    .portfolio-filters {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.6rem;
    }

    .portfolio-filters a {
      min-height: 2.75rem;
      padding-inline: 0.65rem;
      font-size: 0.76rem;
      text-align: center;
    }

    .portfolio-grid {
      width: 100%;
      gap: 1rem;
    }

    .portfolio-card__mockup,
    .portfolio-card__body {
      padding: 1rem;
    }

    .mock-browser {
      min-height: 8.3rem;
    }

    .portfolio-card__summary {
      font-size: 0.88rem;
    }

    .portfolio-cta {
      padding: 1.25rem;
    }

    .portfolio-cta > a {
      width: 100%;
      white-space: normal;
    }
  }
</style>
