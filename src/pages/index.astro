---
import LandingMotion from '../components/LandingMotion.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  navigation,
  trustItems,
  services,
  projects,
  reasons,
} from '../data/site';

const whatsappHref =
  'https://wa.me/5591982890565?text=Ol%C3%A1%2C%20Luan!%20Estou%20interessado%20em%20criar%20um%20site%20profissional%20para%20meu%20neg%C3%B3cio.%20Podemos%20conversar%3F';
const currentYear = new Date().getFullYear();
const projectModalData = JSON.stringify(projects);
---

<BaseLayout>
  <div class='page-loader' data-loader aria-hidden='true'>
    <div class='page-loader__backdrop hero-grid' aria-hidden='true'></div>
    <div class='page-loader__inner'>
      <span class='page-loader__label' data-loader-label
        >Desenvolvimento Web Profissional</span
      >
      <div class='page-loader__brand' data-loader-brand>
        <span>Luan Alves</span>
        <span class='brand-dot' aria-hidden='true'></span>
      </div>
      <div class='page-loader__track' data-loader-progress>
        <span
          class='page-loader__line page-loader__line--base'
          aria-hidden='true'></span>
        <span
          class='page-loader__line page-loader__line--fill'
          data-loader-progress-fill
          aria-hidden='true'></span>
      </div>
    </div>
  </div>

  <nav
    class='site-nav'
    data-motion-nav
    data-motion-hidden='nav'
    data-header-nav
    data-mobile-nav>
    <input
      class='nav-toggle'
      type='checkbox'
      id='site-nav-toggle'
      aria-label='Abrir menu'
    />

    <div class='nav-mobile-bar' data-mobile-nav-bar>
      <a
        class='brand'
        href='#top'
        aria-label='Ir para o topo'
        data-header-brand>
        <span class='brand-stack' data-brand-stack aria-hidden='true'>
          <span class='brand-text' data-brand-label>Luan Alves</span>
        </span>
        <span class='brand-dot' aria-hidden='true'></span>
      </a>

      <label
        class='nav-toggle-button'
        for='site-nav-toggle'
        aria-label='Abrir menu de navegação'>
        <svg
          class='nav-toggle-icon'
          aria-hidden='true'
          viewBox='0 0 32 32'
          fill='none'
          stroke='currentColor'
          stroke-width='2.5'
          stroke-linecap='round'
          stroke-linejoin='round'>
          <path
            class='nav-toggle-icon__curve'
            d='M27 10 13 10C10.8 10 9 8.2 9 6 9 3.5 10.8 2 13 2 15.2 2 17 3.8 17 6L17 26C17 28.2 18.8 30 21 30 23.2 30 25 28.2 25 26 25 23.8 23.2 22 21 22L7 22'
          ></path>
          <path class='nav-toggle-icon__line' d='M7 16 27 16'></path>
        </svg>
      </label>
    </div>

    <div class='nav-menu' data-mobile-nav-menu>
      <div class='nav-links'>
        {navigation.map((item) => <a href={item.href}>{item.label}</a>)}
      </div>

      <a
        class='button button-outline button-compact'
        href={whatsappHref}
        target='_blank'
        rel='noreferrer'>
        Falar no WhatsApp
      </a>

      <div class='mobile-menu-content' data-mobile-menu-content>
        <nav class='mobile-menu-nav' aria-label='Menu mobile'>
          {
            navigation.map((item, index) => (
              <a
                class='mobile-menu-link'
                href={item.href}
                data-mobile-menu-link>
                <span class='mobile-menu-index'>
                  {String(index + 1).padStart(2, '0')}
                </span>
                <span class='mobile-menu-copy'>
                  <span>{item.label}</span>
                </span>
              </a>
            ))
          }
        </nav>

        <div class='mobile-menu-footer'>
          <a
            class='mobile-menu-cta'
            href={whatsappHref}
            target='_blank'
            rel='noreferrer'>
            <span>Falar no WhatsApp</span>
            <span class='material-symbols-outlined'>arrow_right_alt</span>
          </a>

          <div class='mobile-menu-meta'>
            <div class='mobile-menu-secondary-links'>
              <a href={whatsappHref} target='_blank' rel='noreferrer'
                >WhatsApp</a
              >
              <a href='#portfolio' data-mobile-menu-link>Portfólio</a>
              <a href='#contato' data-mobile-menu-link>Contato</a>
            </div>
            <p>© {currentYear} Luan Alves. Web editorial.</p>
          </div>
        </div>
      </div>
    </div>
  </nav>

  <main id='top'>
    <section class='hero section hero-grid' data-motion='hero'>
      <div class='hero-glow' aria-hidden='true' data-motion-glow></div>
      <div class='container hero-content'>
        <h2 class='eyebrow' data-motion-hero-eyebrow data-motion-hidden='y-sm'>
          Desenvolvedor Web Profissional
        </h2>
        <h1 class='hero-title'>
          <span data-motion-hero-title data-motion-hidden='y-lg'>
            Seu negócio merece um <span>site que vende.</span>
          </span>
        </h1>
        <p class='hero-copy' data-motion-hero-copy data-motion-hidden='y-md'>
          Crio sites institucionais, blogs e landing pages profissionais para
          pequenas e médias empresas em todo o Brasil. Design estratégico,
          código limpo e SEO desde o primeiro dia.
        </p>

        <div class='hero-actions' data-motion-hero-actions>
          <a
            class='button button-solid'
            href={whatsappHref}
            target='_blank'
            rel='noreferrer'
            data-motion-hidden='y-sm'>
            Solicitar orçamento
          </a>
          <a
            class='button button-ghost'
            href='#portfolio'
            data-motion-hidden='y-sm'>
            Ver portfólio
          </a>
        </div>
      </div>
    </section>

    <section class='trust-bar' data-motion-section='trust'>
      <div class='container trust-grid'>
        {
          trustItems.map((item, index) => (
            <article
              class:list={['trust-item', index === 1 && 'trust-item-bordered']}
              data-motion-item='trust'
              data-motion-hidden='y-sm'>
              <div class='trust-icon'>
                <span class='material-symbols-outlined'>{item.icon}</span>
              </div>
              <p>
                {item.title}
                <br />
                {item.subtitle}
              </p>
            </article>
          ))
        }
      </div>
    </section>

    <section class='section' id='servicos' data-motion-section='services'>
      <div class='container'>
        <div class='section-heading'>
          <span class='eyebrow' data-motion-heading data-motion-hidden='y-sm'
            >Soluções</span
          >
          <h2 data-motion-heading data-motion-hidden='y-md'>
            Criação de sites profissionais para empresas
          </h2>
        </div>

        <div class='card-grid'>
          {
            services.map((service) => (
              <article
                class='service-card'
                data-motion-item='service'
                data-motion-hidden='y-card'>
                <div class='service-icon'>
                  <span class='material-symbols-outlined'>{service.icon}</span>
                </div>
                <h3>{service.title}</h3>
                <p>{service.description}</p>
                <div class='card-rule' />
                <ul class='service-list'>
                  {service.bullets.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section
      class='section section-surface'
      id='portfolio'
      data-motion-section='portfolio'>
      <div class='container'>
        <div class='section-heading section-heading-spread'>
          <div>
            <span class='eyebrow' data-motion-heading data-motion-hidden='y-sm'
              >Curadoria</span
            >
            <h2 data-motion-heading data-motion-hidden='y-md'>
              Projetos entregues para empresas reais
            </h2>
          </div>
        </div>

        <div class='project-grid'>
          {
            projects.map((project, index) => (
              <button
                type='button'
                class='project-card'
                data-project-trigger
                data-project-id={project.id}
                data-motion-item='project'
                data-motion-hidden={index % 2 === 0 ? 'x-left' : 'x-right'}
                aria-haspopup='dialog'
                aria-label={`Abrir modal do projeto ${project.title}`}>
                <div class='project-media' data-project-origin>
                  <img
                    src={project.image}
                    alt={project.alt}
                    loading='lazy'
                    data-motion-image
                  />
                </div>
                <div class='project-meta'>
                  <div>
                    <h3>{project.title}</h3>
                    <p>{project.subtitle}</p>
                  </div>
                  <span class='project-meta-action' aria-hidden='true'>
                    <span class='material-symbols-outlined'>north_east</span>
                  </span>
                </div>
              </button>
            ))
          }
        </div>
      </div>
    </section>

    <section class='section why-section' data-motion-section='why'>
      <div class='why-grid-accent hero-grid' aria-hidden='true'></div>
      <div class='container why-layout'>
        <div>
          <span class='eyebrow' data-motion-heading data-motion-hidden='y-sm'
            >Diferenciais</span
          >
          <h2 data-motion-heading data-motion-hidden='y-md'>
            Por que contratar um desenvolvedor web freelancer?
          </h2>
          <p class='why-copy' data-motion-copy data-motion-hidden='y-md'>
            Ao contratar diretamente, você tem acesso ao profissional que vai
            criar o seu site — sem camadas de agência, sem ruído na comunicação
            e sem custo inflado.
          </p>

          <div class='reason-grid'>
            {
              reasons.map((reason) => (
                <article
                  class='reason-item'
                  data-motion-item='reason'
                  data-motion-hidden='y-sm'>
                  <span class='material-symbols-outlined reason-check'>
                    check_circle
                  </span>
                  <div>
                    <h3>{reason.title}</h3>
                    <p>{reason.subtitle}</p>
                  </div>
                </article>
              ))
            }
          </div>
        </div>

        <div
          class='experience-panel'
          data-motion-experience
          data-motion-hidden='scale'>
          <div class='experience-card'>
            <span class='experience-number'>05+</span>
            <span class='experience-label'>Anos de experiência</span>
          </div>
          <div class='experience-corner' aria-hidden='true'></div>
        </div>
      </div>
    </section>

    <section class='section' id='contato' data-motion-section='cta'>
      <div class='container'>
        <div class='cta-panel' data-motion-panel data-motion-hidden='y-lg'>
          <div
            class='cta-accent'
            aria-hidden='true'
            data-motion-accent
            data-motion-hidden='scale-x'>
          </div>
          <h2 data-motion-heading>
            Pronto para ter um site profissional que aparece no Google?
          </h2>
          <p data-motion-copy>
            Me conte sobre o seu projeto. Atendo empresas em Belém e em todo o
            Brasil de forma 100% remota — com a agilidade de um freelancer e a
            qualidade de uma agência. Respondo em até 24 horas.
          </p>
          <a
            class='button button-solid button-large'
            href={whatsappHref}
            target='_blank'
            rel='noreferrer'
            data-motion-button
            data-motion-hidden='y-sm'>
            <span class='material-symbols-outlined'>forum</span>
            Falar no WhatsApp
          </a>
        </div>
      </div>
    </section>
  </main>

  <div class='project-modal' data-project-modal aria-hidden='true' hidden>
    <button
      class='project-modal-backdrop'
      type='button'
      data-project-modal-backdrop
      aria-label='Fechar modal do projeto'></button>

    <div
      class='project-modal-shell'
      data-project-modal-panel
      role='dialog'
      aria-modal='true'
      aria-labelledby='project-modal-title'>
      <div class='project-modal-head'>
        <p class='project-modal-kicker' data-project-modal-kicker></p>
        <button
          class='project-modal-close'
          type='button'
          data-project-modal-close
          aria-label='Fechar modal do projeto'>
          <span class='material-symbols-outlined'>close</span>
        </button>
      </div>

      <div class='project-modal-layout'>
        <div class='project-modal-primary'>
          <div class='project-modal--card'>
            <div class='project-modal-video-frame'>
              <video
                data-project-modal-video
                playsinline
                muted
                loop
                controls
                preload='none'
                poster=''>
                <source
                  data-project-modal-video-source
                  src=''
                  type='video/mp4'
                />
              </video>
              <span class='project-modal-video-badge'>Autoplay</span>
            </div>
          </div>

          <div class='project-modal-copy'>
            <h3 id='project-modal-title' data-project-modal-title></h3>
            <p data-project-modal-description></p>

            <div class='project-modal-actions'>
              <a
                class='button button-solid button-compact'
                data-project-modal-link
                href=''>
                Visitar projeto
              </a>
              <span class='project-modal-note'
                >Case expandido com placeholders prontos para substituir.</span
              >
            </div>
          </div>
        </div>

        <aside class='project-modal-secondary'>
          <div class='project-modal-hero' data-project-modal-hero>
            <img data-project-modal-hero-image src='' alt='' />
          </div>

          <div class='project-modal-gallery'>
            <div class='project-modal-gallery-heading'>
              <span>Galeria</span>
              <span data-project-modal-gallery-count>1 / 3</span>
            </div>

            <div class='project-modal-gallery-stage'>
              <button
                class='project-modal-gallery-view'
                type='button'
                data-project-modal-gallery-open
                aria-label='Abrir imagem da galeria'>
                <span class='project-modal-gallery-overlay'></span>
                <img
                  data-project-modal-gallery-image
                  src=''
                  alt=''
                  loading='lazy'
                />
                <span class='project-modal-gallery-zoom'>Abrir</span>
              </button>

              <button
                class='project-modal-gallery-nav'
                type='button'
                data-project-modal-gallery-next
                aria-label='Próxima imagem da galeria'>
                <span class='material-symbols-outlined'>east</span>
              </button>

              <button
                class='project-modal-gallery-nav project-modal-gallery-nav--left'
                type='button'
                data-project-modal-gallery-prev
                aria-label='Imagem anterior da galeria'>
                <span class='material-symbols-outlined'>west</span>
              </button>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </div>

  <div class='project-lightbox' data-project-lightbox aria-hidden='true' hidden>
    <button
      class='project-lightbox-backdrop'
      type='button'
      data-project-lightbox-backdrop
      aria-label='Fechar imagem ampliada'></button>
    <div class='project-lightbox-shell'>
      <button
        class='project-lightbox-close'
        type='button'
        data-project-lightbox-close
        aria-label='Fechar imagem ampliada'>
        <span class='material-symbols-outlined'>close</span>
      </button>
      <img data-project-lightbox-image src='' alt='' />
    </div>
  </div>

  <footer class='site-footer' data-motion-section='footer'>
    <div class='container footer-layout'>
      <a
        class='brand brand-footer'
        href='#top'
        data-motion-item='footer'
        data-motion-hidden='y-sm'>
        Luan Alves
        <span class='brand-dot' aria-hidden='true'></span>
      </a>

      <div
        class='footer-links'
        data-motion-item='footer'
        data-motion-hidden='y-sm'>
        {navigation.map((item) => <a href={item.href}>{item.label}</a>)}
        <a href={whatsappHref} target='_blank' rel='noreferrer'>WhatsApp</a>
      </div>

      <p
        class='footer-copy'
        data-motion-item='footer'
        data-motion-hidden='y-sm'>
        Luan Alves © {currentYear}
      </p>
    </div>
  </footer>

  <LandingMotion />
  <script
    type='application/json'
    data-project-modal-data
    set:html={projectModalData}
  />
</BaseLayout>

<style>
  .nav-toggle {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  .nav-toggle-button {
    display: none;
  }

  .nav-mobile-bar,
  .nav-menu {
    display: flex;
    align-items: center;
    gap: inherit;
  }

  .nav-mobile-bar {
    align-items: center;
    gap: 1rem;
  }

  .mobile-menu-content {
    display: none;
  }

  @media (max-width: 767px) {
    .site-nav {
      position: fixed;
      display: flex;
      flex-direction: column;
      align-items: stretch;
      justify-content: flex-start;
      gap: 1rem;
      overflow: hidden;
      min-height: 0;
    }

    .nav-mobile-bar {
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      width: 100%;
      flex: 0 0 auto;
    }

    .brand {
      flex: 1 1 auto;
      min-width: 0;
    }

    .nav-toggle-button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 2.9rem;
      height: 2.9rem;
      padding: 0.45rem;
      border: 1px solid rgba(153, 143, 129, 0.24);
      border-radius: 999px;
      background: rgba(14, 14, 14, 0.72);
      color: var(--text);
      cursor: pointer;
      backdrop-filter: blur(16px);
      transition:
        border-color 180ms ease,
        color 180ms ease,
        transform 180ms ease,
        background-color 180ms ease;
    }

    .nav-toggle-button:hover {
      color: var(--primary);
      border-color: rgba(229, 196, 135, 0.4);
    }

    .nav-toggle-button:active {
      transform: scale(0.98);
    }

    .nav-toggle-icon {
      width: 1.3rem;
      height: 1.3rem;
      overflow: visible;
      transition: transform 0.5s ease-in-out;
    }

    .nav-toggle-icon__curve,
    .nav-toggle-icon__line {
      transition:
        stroke-dasharray 0.5s ease-in-out,
        stroke-dashoffset 0.5s ease-in-out;
    }

    .nav-toggle-icon__curve {
      stroke-dasharray: 12 63;
    }

    .nav-menu {
      display: none;
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      width: 100%;
      min-height: 0;
      overflow: hidden;
    }

    .mobile-menu-content {
      display: none;
      flex: 1 1 auto;
      min-height: 0;
      padding-top: 1.35rem;
      overflow-y: auto;
      overflow-x: hidden;
      scrollbar-width: none;
      -ms-overflow-style: none;
    }

    .mobile-menu-content::-webkit-scrollbar {
      display: none;
    }

    .nav-links,
    .nav-menu > .button {
      display: none;
    }

    .mobile-menu-nav {
      display: flex;
      flex-direction: column;
      gap: 1.6rem;
      margin: auto 0;
      padding: 1.25rem 0 2rem;
    }

    .mobile-menu-link {
      display: grid;
      gap: 0.35rem;
      padding-bottom: 0.85rem;
      border-bottom: 1px solid rgba(77, 70, 58, 0.18);
    }

    .mobile-menu-index {
      color: var(--subtle);
      font-size: 0.62rem;
      font-weight: 700;
      letter-spacing: 0.3em;
      text-transform: uppercase;
    }

    .mobile-menu-copy {
      display: inline-flex;
      align-items: center;
      gap: 0.75rem;
      font-family: 'Newsreader', serif;
      font-size: clamp(2.8rem, 12vw, 4.4rem);
      font-style: italic;
      line-height: 0.95;
      color: var(--muted);
      transition:
        color 220ms ease,
        transform 220ms ease;
    }

    .mobile-menu-dot {
      width: 0.5rem;
      height: 0.5rem;
      border-radius: 999px;
      background: var(--primary);
      flex: 0 0 auto;
    }

    .mobile-menu-link:hover .mobile-menu-copy,
    .mobile-menu-link:focus-visible .mobile-menu-copy {
      color: var(--primary);
      transform: translateX(0.35rem);
    }

    .mobile-menu-footer {
      display: grid;
      gap: 1.5rem;
      padding-top: 1.75rem;
    }

    .mobile-menu-cta {
      display: inline-flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      width: 100%;
      padding: 1.15rem 1.25rem;
      border: 1px solid rgba(200, 169, 110, 0.8);
      color: var(--primary);
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      transition:
        background-color 220ms ease,
        color 220ms ease,
        border-color 220ms ease;
    }

    .mobile-menu-cta:hover {
      background: var(--primary-strong);
      border-color: var(--primary-strong);
      color: var(--primary-ink);
    }

    .mobile-menu-meta {
      display: grid;
      gap: 1rem;
      padding-top: 1.25rem;
      border-top: 1px solid rgba(77, 70, 58, 0.14);
    }

    .mobile-menu-secondary-links {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem 1.5rem;
    }

    .mobile-menu-secondary-links a,
    .mobile-menu-meta p {
      color: var(--subtle);
      font-size: 0.62rem;
      font-weight: 700;
      letter-spacing: 0.22em;
      text-transform: uppercase;
    }

    .mobile-menu-meta p {
      margin: 0;
      color: rgba(153, 143, 129, 0.5);
    }

    .site-nav.is-menu-open .nav-toggle-button {
      color: var(--primary);
      border-color: rgba(229, 196, 135, 0.48);
      background: rgba(14, 14, 14, 0.9);
    }

    .site-nav.is-menu-open .nav-toggle-icon {
      transform: rotate(-45deg);
    }

    .site-nav.is-menu-open .nav-toggle-icon__curve {
      stroke-dasharray: 20 300;
      stroke-dashoffset: -32.42px;
    }

    .site-nav.is-menu-active .nav-menu {
      display: flex;
    }

    .site-nav.is-menu-active .mobile-menu-content {
      display: flex;
      flex-direction: column;
    }

    .site-nav.is-menu-active .nav-menu,
    .site-nav.is-menu-active .nav-mobile-bar {
      width: 100%;
    }

    .site-nav.is-menu-active .nav-menu,
    .site-nav.is-menu-active .nav-menu .mobile-menu-content {
      min-height: 0;
    }

    .site-nav.is-menu-active .nav-menu .mobile-menu-content {
      overflow-y: auto;
    }

    .site-nav.is-menu-active {
      background: rgba(14, 14, 14, 0.96);
      border-color: rgba(77, 70, 58, 0.34);
      box-shadow: 0 18px 36px rgba(0, 0, 0, 0.28);
      backdrop-filter: blur(18px);
    }

    :global(body.menu-open) {
      overflow: hidden;
    }
  }

  @media (max-width: 420px) {
    .site-nav.is-menu-active {
      padding-inline: 1rem;
    }

    .mobile-menu-copy {
      font-size: clamp(2.35rem, 13vw, 3.2rem);
    }
  }
</style>

<script>
  import gsap from 'gsap';

  const menuToggle = document.querySelector('#site-nav-toggle');
  const mobileNav = document.querySelector('[data-mobile-nav]');
  const mobileNavBar = document.querySelector('[data-mobile-nav-bar]');
  const mobileNavMenu = document.querySelector('[data-mobile-nav-menu]');
  const mobileMenuContent = document.querySelector(
    '[data-mobile-menu-content]',
  );
  const mobileLinks = document.querySelectorAll('[data-mobile-menu-link]');
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
  let menuTween;
  let menuOpenHeight = 0;

  const isMobileViewport = () => window.innerWidth <= 767;
  const setScrollLock = (locked) => {
    document.body.classList.toggle('menu-open', locked);
  };

  const clearMenuTween = () => {
    menuTween?.kill();
    menuTween = undefined;
  };

  const syncToggle = (open) => {
    if (menuToggle instanceof HTMLInputElement) {
      menuToggle.checked = open;
    }
  };

  const setMenuOpenClass = (open) => {
    if (mobileNav instanceof HTMLElement) {
      mobileNav.classList.toggle('is-menu-open', open);
    }
  };

  const setMenuActiveClass = (active) => {
    if (mobileNav instanceof HTMLElement) {
      mobileNav.classList.toggle('is-menu-active', active);
    }
  };

  const resetDesktopMenuState = () => {
    if (
      !(mobileNav instanceof HTMLElement) ||
      !(mobileNavMenu instanceof HTMLElement) ||
      !(mobileMenuContent instanceof HTMLElement)
    ) {
      return;
    }

    clearMenuTween();
    syncToggle(false);
    setMenuActiveClass(false);
    setMenuOpenClass(false);
    setScrollLock(false);
    gsap.set([mobileNav, mobileNavMenu, mobileMenuContent], {
      clearProps: 'all',
    });
  };

  const animateMenu = (open, immediate = false) => {
    if (
      !(menuToggle instanceof HTMLInputElement) ||
      !(mobileNav instanceof HTMLElement) ||
      !(mobileNavBar instanceof HTMLElement) ||
      !(mobileNavMenu instanceof HTMLElement) ||
      !(mobileMenuContent instanceof HTMLElement)
    ) {
      return;
    }

    if (!isMobileViewport()) {
      resetDesktopMenuState();
      return;
    }

    clearMenuTween();

    if (reduceMotion.matches || immediate) {
      syncToggle(open);
      setMenuActiveClass(open);
      setMenuOpenClass(open);
      setScrollLock(open);

      if (open) {
        gsap.set(mobileNavMenu, { display: 'flex' });
        gsap.set(mobileNavMenu, { height: 'auto' });
        gsap.set(mobileMenuContent, { display: 'flex', autoAlpha: 1, y: 0 });
      } else {
        gsap.set(mobileMenuContent, { autoAlpha: 0 });
        gsap.set(mobileMenuContent, { clearProps: 'all' });
        gsap.set(mobileNavMenu, { clearProps: 'all' });
      }

      return;
    }

    const getOpenMenuHeight = () => {
      gsap.set(mobileNavMenu, { display: 'flex', height: 'auto' });
      gsap.set(mobileMenuContent, {
        display: 'flex',
        clearProps: 'all',
        maxHeight: 'none',
      });

      const navTop = mobileNav.getBoundingClientRect().top;
      const availableHeight = Math.max(
        window.innerHeight - navTop - mobileNavBar.offsetHeight - 24,
        160,
      );
      const contentHeight = mobileMenuContent.scrollHeight;
      const targetHeight = Math.max(
        Math.min(contentHeight, availableHeight),
        160,
      );

      gsap.set(mobileMenuContent, { maxHeight: targetHeight });
      return targetHeight;
    };

    if (open) {
      syncToggle(true);
      setMenuActiveClass(true);
      setMenuOpenClass(true);
      setScrollLock(true);
      menuOpenHeight = getOpenMenuHeight();

      gsap.set(mobileNavMenu, { display: 'flex', height: 0 });
      gsap.set(mobileMenuContent, {
        display: 'flex',
        autoAlpha: 0,
        y: 24,
        maxHeight: menuOpenHeight,
      });

      menuTween = gsap.timeline({
        defaults: { ease: 'power3.inOut' },
      });

      menuTween
        .to(mobileNavMenu, {
          height: menuOpenHeight,
          duration: 0.42,
        })
        .to(
          mobileMenuContent,
          {
            autoAlpha: 1,
            y: 0,
            duration: 0.26,
            ease: 'power2.out',
            clearProps: 'y',
          },
          0.1,
        );

      return;
    }

    syncToggle(false);
    setMenuOpenClass(false);
    gsap.set(mobileNavMenu, { height: mobileNavMenu.offsetHeight });

    menuTween = gsap.timeline({
      defaults: { ease: 'power3.inOut' },
      onComplete: () => {
        setMenuActiveClass(false);
        setScrollLock(false);
        gsap.set(mobileMenuContent, { clearProps: 'all' });
        gsap.set(mobileNavMenu, { clearProps: 'all' });
      },
    });

    menuTween
      .to(mobileMenuContent, {
        autoAlpha: 0,
        y: 18,
        duration: 0.16,
        ease: 'power2.in',
      })
      .to(
        mobileNavMenu,
        {
          height: 0,
          duration: 0.34,
        },
        0,
      );
  };

  if (menuToggle instanceof HTMLInputElement) {
    menuToggle.addEventListener('change', () => {
      animateMenu(menuToggle.checked);
    });

    mobileLinks.forEach((link) => {
      link.addEventListener('click', () => {
        animateMenu(false);
      });
    });

    document.addEventListener('keydown', (event) => {
      if (
        event.key === 'Escape' &&
        mobileNav instanceof HTMLElement &&
        mobileNav.classList.contains('is-menu-active')
      ) {
        animateMenu(false);
      }
    });

    window.addEventListener('resize', () => {
      if (!isMobileViewport()) {
        resetDesktopMenuState();
        return;
      }

      if (
        mobileNav instanceof HTMLElement &&
        mobileNav.classList.contains('is-menu-active')
      ) {
        menuOpenHeight = Math.max(
          Math.min(
            mobileMenuContent instanceof HTMLElement
              ? mobileMenuContent.scrollHeight
              : 0,
            Math.max(
              window.innerHeight -
                mobileNav.getBoundingClientRect().top -
                mobileNavBar.offsetHeight -
                24,
              160,
            ),
          ),
          160,
        );
        gsap.set(mobileNavMenu, { height: menuOpenHeight });
        if (mobileMenuContent instanceof HTMLElement) {
          gsap.set(mobileMenuContent, { maxHeight: menuOpenHeight });
        }
      }
    });

    document.addEventListener('astro:before-swap', () => {
      syncToggle(false);
      setMenuActiveClass(false);
      setMenuOpenClass(false);
      setScrollLock(false);
      clearMenuTween();
    });

    animateMenu(menuToggle.checked, true);
  }
</script>
