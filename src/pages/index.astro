---
import LandingMotion from "../components/LandingMotion.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { navigation, trustItems, services, projects, reasons } from "../data/site";

const whatsappHref = "https://wa.me/5511999999999";
const currentYear = new Date().getFullYear();
---

<BaseLayout>
  <div class="page-loader" data-loader aria-hidden="true">
    <div class="page-loader__backdrop hero-grid" aria-hidden="true"></div>
    <div class="page-loader__inner">
      <span class="page-loader__label" data-loader-label>Desenvolvimento Web Profissional</span>
      <div class="page-loader__brand" data-loader-brand>
        <span>Luan Alves</span>
        <span class="brand-dot" aria-hidden="true"></span>
      </div>
      <div class="page-loader__track" data-loader-progress>
        <span class="page-loader__line page-loader__line--base" aria-hidden="true"></span>
        <span class="page-loader__line page-loader__line--fill" data-loader-progress-fill aria-hidden="true"></span>
      </div>
    </div>
  </div>

  <nav class="site-nav" data-motion-nav data-motion-hidden="nav" data-header-nav>
    <a class="brand" href="#top" aria-label="Ir para o topo" data-header-brand>
      <span class="brand-stack" data-brand-stack aria-hidden="true">
        <span class="brand-text" data-brand-label>Luan Alves</span>
      </span>
      <span class="brand-dot" aria-hidden="true"></span>
    </a>

    <input class="nav-toggle" type="checkbox" id="site-nav-toggle" aria-label="Abrir menu" />
    <label class="nav-toggle-button" for="site-nav-toggle" aria-label="Abrir menu de navegação">
      <span></span>
      <span></span>
      <span></span>
    </label>

    <div class="nav-menu">
      <div class="nav-links">
        {
          navigation.map((item) => (
            <a href={item.href}>{item.label}</a>
          ))
        }
      </div>

      <a class="button button-outline button-compact" href={whatsappHref} target="_blank" rel="noreferrer">
        Falar no WhatsApp
      </a>
    </div>
  </nav>

  <main id="top">
    <section class="hero section hero-grid" data-motion="hero">
      <div class="hero-glow" aria-hidden="true" data-motion-glow></div>
      <div class="container hero-content">
        <span class="eyebrow" data-motion-hero-eyebrow data-motion-hidden="y-sm">
          Desenvolvimento Web Profissional
        </span>
        <h1 class="hero-title">
          <span data-motion-hero-title data-motion-hidden="y-lg">
            Seu negócio merece um <span>site que vende.</span>
          </span>
        </h1>
        <p class="hero-copy" data-motion-hero-copy data-motion-hidden="y-md">
          Crio sites, lojas virtuais e landing pages que transmitem credibilidade e convertem
          visitantes em clientes através de design estratégico e código impecável.
        </p>

        <div class="hero-actions" data-motion-hero-actions>
          <a
            class="button button-solid"
            href={whatsappHref}
            target="_blank"
            rel="noreferrer"
            data-motion-hidden="y-sm"
          >
            Solicitar orçamento
          </a>
          <a class="button button-ghost" href="#portfolio" data-motion-hidden="y-sm">
            Ver portfólio
          </a>
        </div>
      </div>
    </section>

    <section class="trust-bar" data-motion-section="trust">
      <div class="container trust-grid">
        {
          trustItems.map((item, index) => (
            <article
              class:list={["trust-item", index === 1 && "trust-item-bordered"]}
              data-motion-item="trust"
              data-motion-hidden="y-sm"
            >
              <div class="trust-icon">
                <span class="material-symbols-outlined">{item.icon}</span>
              </div>
              <p>
                {item.title}
                <br />
                {item.subtitle}
              </p>
            </article>
          ))
        }
      </div>
    </section>

    <section class="section" id="servicos" data-motion-section="services">
      <div class="container">
        <div class="section-heading">
          <span class="eyebrow" data-motion-heading data-motion-hidden="y-sm">Soluções</span>
          <h2 data-motion-heading data-motion-hidden="y-md">O que eu entrego</h2>
        </div>

        <div class="card-grid">
          {
            services.map((service) => (
              <article class="service-card" data-motion-item="service" data-motion-hidden="y-card">
                <div class="service-icon">
                  <span class="material-symbols-outlined">{service.icon}</span>
                </div>
                <h3>{service.title}</h3>
                <p>{service.description}</p>
                <div class="card-rule"></div>
                <ul class="service-list">
                  {service.bullets.map((item) => <li>{item}</li>)}
                </ul>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="section section-surface" id="portfolio" data-motion-section="portfolio">
      <div class="container">
        <div class="section-heading section-heading-spread">
          <div>
            <span class="eyebrow" data-motion-heading data-motion-hidden="y-sm">Curadoria</span>
            <h2 data-motion-heading data-motion-hidden="y-md">Projetos Realizados</h2>
          </div>
        </div>

        <div class="project-grid">
          {
            projects.map((project, index) => (
              <article
                class="project-card"
                data-motion-item="project"
                data-motion-hidden={index % 2 === 0 ? "x-left" : "x-right"}
              >
                <div class="project-media">
                  <img src={project.image} alt={project.alt} loading="lazy" data-motion-image />
                </div>
                <div class="project-meta">
                  <div>
                    <h3>{project.title}</h3>
                    <p>{project.subtitle}</p>
                  </div>
                  <a href="#contato" aria-label={`Abrir contato para ${project.title}`}>
                    <span class="material-symbols-outlined">north_east</span>
                  </a>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="section why-section" data-motion-section="why">
      <div class="why-grid-accent hero-grid" aria-hidden="true"></div>
      <div class="container why-layout">
        <div>
          <span class="eyebrow" data-motion-heading data-motion-hidden="y-sm">Diferenciais</span>
          <h2 data-motion-heading data-motion-hidden="y-md">Por que confiar seu projeto a mim?</h2>
          <p class="why-copy" data-motion-copy data-motion-hidden="y-md">
            Mais do que apenas um site, eu entrego uma ferramenta de negócios. Cada linha de código
            e cada pixel é pensado para que sua presença digital seja sua melhor vendedora.
          </p>

          <div class="reason-grid">
            {
              reasons.map((reason) => (
                <article class="reason-item" data-motion-item="reason" data-motion-hidden="y-sm">
                  <span class="material-symbols-outlined reason-check">check_circle</span>
                  <div>
                    <h3>{reason.title}</h3>
                    <p>{reason.subtitle}</p>
                  </div>
                </article>
              ))
            }
          </div>
        </div>

        <div class="experience-panel" data-motion-experience data-motion-hidden="scale">
          <div class="experience-card">
            <span class="experience-number">05+</span>
            <span class="experience-label">Anos de experiência</span>
          </div>
          <div class="experience-corner" aria-hidden="true"></div>
        </div>
      </div>
    </section>

    <section class="section" id="contato" data-motion-section="cta">
      <div class="container">
        <div class="cta-panel" data-motion-panel data-motion-hidden="y-lg">
          <div class="cta-accent" aria-hidden="true" data-motion-accent data-motion-hidden="scale-x"></div>
          <h2 data-motion-heading>Pronto para ter um site profissional?</h2>
          <p data-motion-copy>
            Me conte sobre seu projeto e vamos elevar o nível da sua presença digital. Respondo em
            até 24 horas.
          </p>
          <a
            class="button button-solid button-large"
            href={whatsappHref}
            target="_blank"
            rel="noreferrer"
            data-motion-button
            data-motion-hidden="y-sm"
          >
            <span class="material-symbols-outlined">forum</span>
            Falar no WhatsApp
          </a>
        </div>
      </div>
    </section>
  </main>

  <footer class="site-footer" data-motion-section="footer">
    <div class="container footer-layout">
      <a class="brand brand-footer" href="#top" data-motion-item="footer" data-motion-hidden="y-sm">
        Luan Alves
        <span class="brand-dot" aria-hidden="true"></span>
      </a>

      <div class="footer-links" data-motion-item="footer" data-motion-hidden="y-sm">
        {
          navigation.map((item) => (
            <a href={item.href}>{item.label}</a>
          ))
        }
        <a href={whatsappHref} target="_blank" rel="noreferrer">WhatsApp</a>
      </div>

      <p class="footer-copy" data-motion-item="footer" data-motion-hidden="y-sm">
        Luan Alves © {currentYear}
      </p>
    </div>
  </footer>

  <LandingMotion />
</BaseLayout>

<style>
  .nav-toggle {
    display: none;
  }

  .nav-toggle-button {
    display: none;
  }

  .nav-menu {
    display: flex;
    align-items: center;
    gap: inherit;
  }

  @media (max-width: 767px) {
    .site-nav {
      position: relative;
      flex-wrap: wrap;
      align-items: center;
      justify-content: space-between;
      gap: 0.75rem;
      width: 100%;
      max-width: 100%;
      overflow-x: clip;
    }

    .brand {
      flex: 1 1 auto;
      min-width: 0;
    }

    .nav-toggle-button {
      display: inline-flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 0.25rem;
      width: 2.75rem;
      height: 2.75rem;
      padding: 0.5rem;
      border: 1px solid currentColor;
      border-radius: 999px;
      cursor: pointer;
      flex-shrink: 0;
    }

    .nav-toggle-button span {
      display: block;
      width: 1.1rem;
      height: 2px;
      background: currentColor;
      border-radius: 999px;
      transition: transform 0.2s ease, opacity 0.2s ease;
    }

    .nav-menu {
      display: none;
      width: 100%;
      flex-direction: column;
      align-items: stretch;
      gap: 0.75rem;
      padding-top: 0.5rem;
    }

    .nav-toggle:checked + .nav-toggle-button + .nav-menu {
      display: flex;
    }

    .nav-toggle:checked + .nav-toggle-button span:nth-child(1) {
      transform: translateY(6px) rotate(45deg);
    }

    .nav-toggle:checked + .nav-toggle-button span:nth-child(2) {
      opacity: 0;
    }

    .nav-toggle:checked + .nav-toggle-button span:nth-child(3) {
      transform: translateY(-6px) rotate(-45deg);
    }

    .nav-links {
      display: flex;
      flex-direction: column;
      align-items: stretch;
      gap: 0.5rem;
      width: 100%;
    }

    .nav-links a,
    .site-nav .button {
      width: 100%;
      max-width: 100%;
      box-sizing: border-box;
    }

    button,
    a.button,
    .button {
      padding: 0.5rem 1rem;
      font-size: 0.875rem;
    }
  }
</style>
