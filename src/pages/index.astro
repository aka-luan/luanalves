---
import HomeCta from '../components/HomeCta.astro';
import ProjectPortfolio from '../components/ProjectPortfolio.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SiteNav from '../components/SiteNav.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  navigation,
  trustItems,
  services,
  projects,
  reasons,
} from '../data/site';

const whatsappHref =
  'https://wa.me/5591982890565?text=Ol%C3%A1%2C%20Luan!%20Estou%20interessado%20em%20criar%20um%20site%20profissional%20para%20meu%20neg%C3%B3cio.%20Podemos%20conversar%3F';
const projectModalData = JSON.stringify(projects);
---

<BaseLayout>
  <div class='page-loader' data-loader aria-hidden='true'>
    <div class='page-loader__backdrop hero-grid' aria-hidden='true'></div>
    <div class='page-loader__inner'>
      <span class='page-loader__label' data-loader-label
        >Desenvolvimento Web Profissional</span
      >
      <div class='page-loader__brand' data-loader-brand>
        <span>Luan Alves</span>
        <span class='brand-dot' aria-hidden='true'></span>
      </div>
      <div class='page-loader__track' data-loader-progress>
        <span
          class='page-loader__line page-loader__line--base'
          aria-hidden='true'></span>
        <span
          class='page-loader__line page-loader__line--fill'
          data-loader-progress-fill
          aria-hidden='true'></span>
      </div>
    </div>
  </div>

  <SiteNav items={navigation} whatsappHref={whatsappHref} />

  <main id='top'>
    <section class='hero section hero-grid' data-motion='hero'>
      <div class='hero-glow' aria-hidden='true' data-motion-glow></div>
      <div class='container hero-content'>
        <h2 class='eyebrow' data-motion-hero-eyebrow data-motion-hidden='y-sm'>
          Desenvolvedor Web Profissional
        </h2>
        <h1 class='hero-title'>
          <span data-motion-hero-title data-motion-hidden='y-lg'>
            Seu negócio merece um <span>site que vende.</span>
          </span>
        </h1>
        <p class='hero-copy' data-motion-hero-copy data-motion-hidden='y-md'>
          Crio sites institucionais, blogs e landing pages profissionais para
          pequenas e médias empresas em todo o Brasil. Design estratégico,
          código limpo e SEO desde o primeiro dia.
        </p>

        <div class='hero-actions' data-motion-hero-actions>
          <a
            class='button button-solid'
            href={whatsappHref}
            target='_blank'
            rel='noreferrer'
            data-motion-hidden='y-sm'>
            Solicitar orçamento
          </a>
          <a
            class='button button-ghost'
            href='/portfolio/'
            data-motion-hidden='y-sm'>
            Ver portfólio
          </a>
        </div>
      </div>
    </section>

    <section class='trust-bar' data-motion-section='trust'>
      <div class='container trust-grid'>
        {
          trustItems.map((item, index) => (
            <article
              class:list={['trust-item', index === 1 && 'trust-item-bordered']}
              data-motion-item='trust'
              data-motion-hidden='y-sm'>
              <div class='trust-icon'>
                <span class='material-symbols-outlined'>{item.icon}</span>
              </div>
              <p>
                {item.title}
                <br />
                {item.subtitle}
              </p>
            </article>
          ))
        }
      </div>
    </section>

    <section class='section' id='servicos' data-motion-section='services'>
      <div class='container'>
        <div class='section-heading'>
          <span class='eyebrow' data-motion-heading data-motion-hidden='y-sm'
            >Soluções</span
          >
          <h2 data-motion-heading data-motion-hidden='y-md'>
            Criação de sites profissionais para empresas
          </h2>
        </div>

        <div class='card-grid'>
          {
            services.map((service) => (
              <article
                class='service-card'
                data-motion-item='service'
                data-motion-hidden='y-card'>
                <div class='service-icon'>
                  <span class='material-symbols-outlined'>{service.icon}</span>
                </div>
                <h3>{service.title}</h3>
                <p>{service.description}</p>
                <div class='card-rule' />
                <ul class='service-list'>
                  {service.bullets.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
              </article>
            ))
          }
        </div>

        <div class='services-more' data-motion-item='service' data-motion-hidden='y-sm'>
          <p>
            Veja detalhes do processo, formatos de entrega e benefícios da
            criação de sites profissionais.
          </p>
          <a class='button button-outline button-compact' href='/criacao-de-sites/'>
            Conhecer criação de sites
          </a>
        </div>
      </div>
    </section>

    <ProjectPortfolio projects={projects} mode='modal' />

    <section class='section why-section' data-motion-section='why'>
      <div class='why-grid-accent hero-grid' aria-hidden='true'></div>
      <div class='container why-layout'>
        <div>
          <span class='eyebrow' data-motion-heading data-motion-hidden='y-sm'
            >Diferenciais</span
          >
          <h2 data-motion-heading data-motion-hidden='y-md'>
            Por que contratar um desenvolvedor web freelancer?
          </h2>
          <p class='why-copy' data-motion-copy data-motion-hidden='y-md'>
            Ao contratar diretamente, você tem acesso ao profissional que vai
            criar o seu site — sem camadas de agência, sem ruído na comunicação
            e sem custo inflado.
          </p>

          <div class='reason-grid'>
            {
              reasons.map((reason) => (
                <article
                  class='reason-item'
                  data-motion-item='reason'
                  data-motion-hidden='y-sm'>
                  <span class='material-symbols-outlined reason-check'>
                    check_circle
                  </span>
                  <div>
                    <h3>{reason.title}</h3>
                    <p>{reason.subtitle}</p>
                  </div>
                </article>
              ))
            }
          </div>
        </div>

        <div
          class='experience-panel'
          data-motion-experience
          data-motion-hidden='scale'>
          <div class='experience-card'>
            <span class='experience-number'>05+</span>
            <span class='experience-label'>Anos de experiência</span>
          </div>
          <div class='experience-corner' aria-hidden='true'></div>
        </div>
      </div>
    </section>

    <HomeCta whatsappHref={whatsappHref} />
  </main>

  <div class='project-modal' data-project-modal aria-hidden='true' hidden>
    <button
      class='project-modal-backdrop'
      type='button'
      data-project-modal-backdrop
      aria-label='Fechar modal do projeto'></button>

    <div
      class='project-modal-shell'
      data-project-modal-panel
      role='dialog'
      aria-modal='true'
      aria-labelledby='project-modal-title'>
      <div class='project-modal-head'>
        <p class='project-modal-kicker' data-project-modal-kicker></p>
        <button
          class='project-modal-close'
          type='button'
          data-project-modal-close
          aria-label='Fechar modal do projeto'>
          <span class='material-symbols-outlined'>close</span>
        </button>
      </div>

      <div class='project-modal-layout'>
        <div class='project-modal-primary'>
          <div class='project-modal-video-card'>
            <div class='project-modal-video-frame'>
              <video
                data-project-modal-video
                playsinline
                muted
                loop
                controls
                preload='none'
                poster=''>
                <source
                  data-project-modal-video-source
                  src=''
                  type='video/mp4'
                />
              </video>
              <span class='project-modal-video-badge'>Autoplay</span>
            </div>
          </div>

          <div class='project-modal-copy'>
            <h3 id='project-modal-title' data-project-modal-title></h3>
            <p data-project-modal-description></p>

            <div class='project-modal-actions'>
              <a
                class='button button-solid button-compact'
                data-project-modal-link
                href=''>
                Visitar projeto
              </a>
            </div>
          </div>
        </div>

        <aside class='project-modal-secondary'>
          <div class='project-modal-hero' data-project-modal-hero>
            <img data-project-modal-hero-image src='' alt='' />
          </div>

          <div class='project-modal-gallery'>
            <div class='project-modal-gallery-heading'>
              <span>Galeria</span>
              <span data-project-modal-gallery-count>1 / 3</span>
            </div>

            <div class='project-modal-gallery-stage'>
              <button
                class='project-modal-gallery-view'
                type='button'
                data-project-modal-gallery-open
                aria-label='Abrir imagem da galeria'>
                <span class='project-modal-gallery-overlay'></span>
                <img
                  data-project-modal-gallery-image
                  src=''
                  alt=''
                  loading='lazy'
                />
                <span class='project-modal-gallery-zoom'>Abrir</span>
              </button>

              <button
                class='project-modal-gallery-nav'
                type='button'
                data-project-modal-gallery-next
                aria-label='Próxima imagem da galeria'>
                <span class='material-symbols-outlined'>east</span>
              </button>

              <button
                class='project-modal-gallery-nav project-modal-gallery-nav--left'
                type='button'
                data-project-modal-gallery-prev
                aria-label='Imagem anterior da galeria'>
                <span class='material-symbols-outlined'>west</span>
              </button>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </div>

  <div class='project-lightbox' data-project-lightbox aria-hidden='true' hidden>
    <button
      class='project-lightbox-backdrop'
      type='button'
      data-project-lightbox-backdrop
      aria-label='Fechar imagem ampliada'></button>
    <div class='project-lightbox-shell'>
      <button
        class='project-lightbox-close'
        type='button'
        data-project-lightbox-close
        aria-label='Fechar imagem ampliada'>
        <span class='material-symbols-outlined'>close</span>
      </button>
      <img data-project-lightbox-image src='' alt='' />
    </div>
  </div>

  <SiteFooter links={navigation} />

  <script
    type='application/json'
    data-project-modal-data
    set:html={projectModalData}
  />
</BaseLayout>

