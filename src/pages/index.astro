---
import LandingMotion from "../components/LandingMotion.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { navigation, trustItems, services, projects, reasons } from "../data/site";

const whatsappHref = "https://wa.me/5511999999999";
const currentYear = new Date().getFullYear();
---

<BaseLayout>
  <div class="page-loader" data-loader aria-hidden="true">
    <div class="page-loader__backdrop hero-grid" aria-hidden="true"></div>
    <div class="page-loader__inner">
      <span class="page-loader__label" data-loader-label>Desenvolvimento Web Profissional</span>
      <div class="page-loader__brand" data-loader-brand>
        <span>Luan Alves</span>
        <span class="brand-dot" aria-hidden="true"></span>
      </div>
      <div class="page-loader__track" data-loader-progress>
        <span class="page-loader__line page-loader__line--base" aria-hidden="true"></span>
        <span class="page-loader__line page-loader__line--fill" data-loader-progress-fill aria-hidden="true"></span>
      </div>
    </div>
  </div>

  <nav class="site-nav" data-motion-nav data-motion-hidden="nav" data-header-nav>
    <a class="brand" href="#top" aria-label="Ir para o topo" data-header-brand>
      <span class="brand-stack" data-brand-stack aria-hidden="true">
        <span class="brand-text" data-brand-label>Luan Alves</span>
      </span>
      <span class="brand-dot" aria-hidden="true"></span>
    </a>

    <input class="nav-toggle" type="checkbox" id="site-nav-toggle" aria-label="Abrir menu" />
    <label class="nav-toggle-button" for="site-nav-toggle" aria-label="Abrir menu de navegação">
      <span class="nav-toggle-label">Menu</span>
      <span class="nav-toggle-icon" aria-hidden="true">
        <span></span>
        <span></span>
      </span>
    </label>

    <div class="nav-menu">
      <div class="nav-links">
        {
          navigation.map((item) => (
            <a href={item.href}>{item.label}</a>
          ))
        }
      </div>

      <a class="button button-outline button-compact" href={whatsappHref} target="_blank" rel="noreferrer">
        Falar no WhatsApp
      </a>
    </div>

    <div class="mobile-menu-shell" aria-hidden="true">
      <div class="mobile-menu-backdrop"></div>
      <div class="mobile-menu-panel hero-grid">
        <header class="mobile-menu-header">
          <span class="mobile-menu-brand">LUAN ALVES</span>
          <label class="mobile-menu-close" for="site-nav-toggle" aria-label="Fechar menu">
            <span class="material-symbols-outlined">close</span>
          </label>
        </header>

        <nav class="mobile-menu-nav" aria-label="Menu mobile">
          {
            navigation.map((item, index) => (
              <a class="mobile-menu-link" href={item.href} data-mobile-menu-link>
                <span class="mobile-menu-index">{String(index + 1).padStart(2, "0")}</span>
                <span class="mobile-menu-copy">
                  <span>{item.label}</span>
                  {item.href === "#contato" && <span class="mobile-menu-dot" aria-hidden="true"></span>}
                </span>
              </a>
            ))
          }
        </nav>

        <div class="mobile-menu-footer">
          <a class="mobile-menu-cta" href={whatsappHref} target="_blank" rel="noreferrer">
            <span>Falar no WhatsApp</span>
            <span class="material-symbols-outlined">arrow_right_alt</span>
          </a>

          <div class="mobile-menu-meta">
            <div class="mobile-menu-secondary-links">
              <a href={whatsappHref} target="_blank" rel="noreferrer">WhatsApp</a>
              <a href="#portfolio" data-mobile-menu-link>Portfólio</a>
              <a href="#contato" data-mobile-menu-link>Contato</a>
            </div>
            <p>© {currentYear} Luan Alves. Web editorial.</p>
          </div>
        </div>
      </div>
    </div>
  </nav>

  <main id="top">
    <section class="hero section hero-grid" data-motion="hero">
      <div class="hero-glow" aria-hidden="true" data-motion-glow></div>
      <div class="container hero-content">
        <span class="eyebrow" data-motion-hero-eyebrow data-motion-hidden="y-sm">
          Desenvolvimento Web Profissional
        </span>
        <h1 class="hero-title">
          <span data-motion-hero-title data-motion-hidden="y-lg">
            Seu negócio merece um <span>site que vende.</span>
          </span>
        </h1>
        <p class="hero-copy" data-motion-hero-copy data-motion-hidden="y-md">
          Crio sites, lojas virtuais e landing pages que transmitem credibilidade e convertem
          visitantes em clientes através de design estratégico e código impecável.
        </p>

        <div class="hero-actions" data-motion-hero-actions>
          <a
            class="button button-solid"
            href={whatsappHref}
            target="_blank"
            rel="noreferrer"
            data-motion-hidden="y-sm"
          >
            Solicitar orçamento
          </a>
          <a class="button button-ghost" href="#portfolio" data-motion-hidden="y-sm">
            Ver portfólio
          </a>
        </div>
      </div>
    </section>

    <section class="trust-bar" data-motion-section="trust">
      <div class="container trust-grid">
        {
          trustItems.map((item, index) => (
            <article
              class:list={["trust-item", index === 1 && "trust-item-bordered"]}
              data-motion-item="trust"
              data-motion-hidden="y-sm"
            >
              <div class="trust-icon">
                <span class="material-symbols-outlined">{item.icon}</span>
              </div>
              <p>
                {item.title}
                <br />
                {item.subtitle}
              </p>
            </article>
          ))
        }
      </div>
    </section>

    <section class="section" id="servicos" data-motion-section="services">
      <div class="container">
        <div class="section-heading">
          <span class="eyebrow" data-motion-heading data-motion-hidden="y-sm">Soluções</span>
          <h2 data-motion-heading data-motion-hidden="y-md">O que eu entrego</h2>
        </div>

        <div class="card-grid">
          {
            services.map((service) => (
              <article class="service-card" data-motion-item="service" data-motion-hidden="y-card">
                <div class="service-icon">
                  <span class="material-symbols-outlined">{service.icon}</span>
                </div>
                <h3>{service.title}</h3>
                <p>{service.description}</p>
                <div class="card-rule"></div>
                <ul class="service-list">
                  {service.bullets.map((item) => <li>{item}</li>)}
                </ul>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="section section-surface" id="portfolio" data-motion-section="portfolio">
      <div class="container">
        <div class="section-heading section-heading-spread">
          <div>
            <span class="eyebrow" data-motion-heading data-motion-hidden="y-sm">Curadoria</span>
            <h2 data-motion-heading data-motion-hidden="y-md">Projetos Realizados</h2>
          </div>
        </div>

        <div class="project-grid">
          {
            projects.map((project, index) => (
              <article
                class="project-card"
                data-motion-item="project"
                data-motion-hidden={index % 2 === 0 ? "x-left" : "x-right"}
              >
                <div class="project-media">
                  <img src={project.image} alt={project.alt} loading="lazy" data-motion-image />
                </div>
                <div class="project-meta">
                  <div>
                    <h3>{project.title}</h3>
                    <p>{project.subtitle}</p>
                  </div>
                  <a href="#contato" aria-label={`Abrir contato para ${project.title}`}>
                    <span class="material-symbols-outlined">north_east</span>
                  </a>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="section why-section" data-motion-section="why">
      <div class="why-grid-accent hero-grid" aria-hidden="true"></div>
      <div class="container why-layout">
        <div>
          <span class="eyebrow" data-motion-heading data-motion-hidden="y-sm">Diferenciais</span>
          <h2 data-motion-heading data-motion-hidden="y-md">Por que confiar seu projeto a mim?</h2>
          <p class="why-copy" data-motion-copy data-motion-hidden="y-md">
            Mais do que apenas um site, eu entrego uma ferramenta de negócios. Cada linha de código
            e cada pixel é pensado para que sua presença digital seja sua melhor vendedora.
          </p>

          <div class="reason-grid">
            {
              reasons.map((reason) => (
                <article class="reason-item" data-motion-item="reason" data-motion-hidden="y-sm">
                  <span class="material-symbols-outlined reason-check">check_circle</span>
                  <div>
                    <h3>{reason.title}</h3>
                    <p>{reason.subtitle}</p>
                  </div>
                </article>
              ))
            }
          </div>
        </div>

        <div class="experience-panel" data-motion-experience data-motion-hidden="scale">
          <div class="experience-card">
            <span class="experience-number">05+</span>
            <span class="experience-label">Anos de experiência</span>
          </div>
          <div class="experience-corner" aria-hidden="true"></div>
        </div>
      </div>
    </section>

    <section class="section" id="contato" data-motion-section="cta">
      <div class="container">
        <div class="cta-panel" data-motion-panel data-motion-hidden="y-lg">
          <div class="cta-accent" aria-hidden="true" data-motion-accent data-motion-hidden="scale-x"></div>
          <h2 data-motion-heading>Pronto para ter um site profissional?</h2>
          <p data-motion-copy>
            Me conte sobre seu projeto e vamos elevar o nível da sua presença digital. Respondo em
            até 24 horas.
          </p>
          <a
            class="button button-solid button-large"
            href={whatsappHref}
            target="_blank"
            rel="noreferrer"
            data-motion-button
            data-motion-hidden="y-sm"
          >
            <span class="material-symbols-outlined">forum</span>
            Falar no WhatsApp
          </a>
        </div>
      </div>
    </section>
  </main>

  <footer class="site-footer" data-motion-section="footer">
    <div class="container footer-layout">
      <a class="brand brand-footer" href="#top" data-motion-item="footer" data-motion-hidden="y-sm">
        Luan Alves
        <span class="brand-dot" aria-hidden="true"></span>
      </a>

      <div class="footer-links" data-motion-item="footer" data-motion-hidden="y-sm">
        {
          navigation.map((item) => (
            <a href={item.href}>{item.label}</a>
          ))
        }
        <a href={whatsappHref} target="_blank" rel="noreferrer">WhatsApp</a>
      </div>

      <p class="footer-copy" data-motion-item="footer" data-motion-hidden="y-sm">
        Luan Alves © {currentYear}
      </p>
    </div>
  </footer>

  <LandingMotion />
</BaseLayout>

<style>
  .nav-toggle {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  .nav-toggle-button {
    display: none;
  }

  .nav-menu {
    display: flex;
    align-items: center;
    gap: inherit;
  }

  .mobile-menu-shell {
    display: none;
  }

  @media (max-width: 767px) {
    .site-nav {
      position: fixed;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      overflow: visible;
    }

    .brand {
      flex: 1 1 auto;
      min-width: 0;
    }

    .nav-toggle-button {
      display: inline-flex;
      align-items: center;
      gap: 0.75rem;
      min-width: 8.25rem;
      padding: 0.8rem 1rem;
      border: 1px solid rgba(153, 143, 129, 0.24);
      border-radius: 999px;
      background: rgba(14, 14, 14, 0.72);
      color: var(--text);
      cursor: pointer;
      text-transform: uppercase;
      letter-spacing: 0.2em;
      font-size: 0.66rem;
      font-weight: 700;
      backdrop-filter: blur(16px);
      transition:
        border-color 180ms ease,
        color 180ms ease,
        transform 180ms ease,
        background-color 180ms ease;
    }

    .nav-toggle-button:hover {
      color: var(--primary);
      border-color: rgba(229, 196, 135, 0.4);
    }

    .nav-toggle-button:active {
      transform: scale(0.98);
    }

    .nav-toggle-label {
      line-height: 1;
    }

    .nav-toggle-icon {
      position: relative;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 1.1rem;
      height: 0.9rem;
    }

    .nav-toggle-icon span {
      position: absolute;
      left: 0;
      width: 1.1rem;
      height: 2px;
      background: currentColor;
      border-radius: 999px;
      transition: transform 0.25s ease, opacity 0.25s ease;
    }

    .nav-toggle-icon span:first-child {
      top: 0.1rem;
    }

    .nav-toggle-icon span:last-child {
      bottom: 0.1rem;
    }

    .nav-menu {
      display: none;
    }

    .mobile-menu-shell {
      position: fixed;
      inset: 0;
      z-index: 35;
      display: block;
      pointer-events: none;
    }

    .mobile-menu-backdrop {
      position: absolute;
      inset: 0;
      background: rgba(14, 14, 14, 0.7);
      opacity: 0;
      transition: opacity 320ms ease;
    }

    .mobile-menu-panel {
      position: absolute;
      inset: 0;
      display: flex;
      flex-direction: column;
      min-height: 100dvh;
      padding: 2rem 1.5rem 1.5rem;
      background:
        radial-gradient(circle at bottom right, rgba(200, 169, 110, 0.16), transparent 28%),
        rgba(14, 14, 14, 0.98);
      transform: translateY(-100%);
      opacity: 0;
      transition:
        transform 420ms cubic-bezier(0.22, 1, 0.36, 1),
        opacity 320ms ease;
      overflow-y: auto;
    }

    .mobile-menu-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      margin-bottom: 2.75rem;
    }

    .mobile-menu-brand {
      font-family: "Newsreader", serif;
      font-size: 1.1rem;
      font-weight: 300;
      letter-spacing: 0.22em;
      color: var(--text);
    }

    .mobile-menu-close {
      display: grid;
      place-items: center;
      width: 3.2rem;
      height: 3.2rem;
      border: 1px solid rgba(200, 169, 110, 0.32);
      border-radius: 999px;
      color: var(--primary);
      cursor: pointer;
      transition:
        transform 180ms ease,
        background-color 180ms ease,
        border-color 180ms ease;
    }

    .mobile-menu-close:active {
      transform: scale(0.96);
    }

    .mobile-menu-nav {
      display: flex;
      flex-direction: column;
      gap: 1.6rem;
      margin: auto 0;
      padding: 1.25rem 0 2rem;
    }

    .mobile-menu-link {
      display: grid;
      gap: 0.35rem;
      padding-bottom: 0.85rem;
      border-bottom: 1px solid rgba(77, 70, 58, 0.18);
    }

    .mobile-menu-index {
      color: var(--subtle);
      font-size: 0.62rem;
      font-weight: 700;
      letter-spacing: 0.3em;
      text-transform: uppercase;
    }

    .mobile-menu-copy {
      display: inline-flex;
      align-items: center;
      gap: 0.75rem;
      font-family: "Newsreader", serif;
      font-size: clamp(2.8rem, 12vw, 4.4rem);
      font-style: italic;
      line-height: 0.95;
      color: var(--muted);
      transition: color 220ms ease, transform 220ms ease;
    }

    .mobile-menu-dot {
      width: 0.5rem;
      height: 0.5rem;
      border-radius: 999px;
      background: var(--primary);
      flex: 0 0 auto;
    }

    .mobile-menu-link:hover .mobile-menu-copy,
    .mobile-menu-link:focus-visible .mobile-menu-copy {
      color: var(--primary);
      transform: translateX(0.35rem);
    }

    .mobile-menu-footer {
      display: grid;
      gap: 1.5rem;
      padding-top: 1.75rem;
    }

    .mobile-menu-cta {
      display: inline-flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      width: 100%;
      padding: 1.15rem 1.25rem;
      border: 1px solid rgba(200, 169, 110, 0.8);
      color: var(--primary);
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      transition:
        background-color 220ms ease,
        color 220ms ease,
        border-color 220ms ease;
    }

    .mobile-menu-cta:hover {
      background: var(--primary-strong);
      border-color: var(--primary-strong);
      color: var(--primary-ink);
    }

    .mobile-menu-meta {
      display: grid;
      gap: 1rem;
      padding-top: 1.25rem;
      border-top: 1px solid rgba(77, 70, 58, 0.14);
    }

    .mobile-menu-secondary-links {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem 1.5rem;
    }

    .mobile-menu-secondary-links a,
    .mobile-menu-meta p {
      color: var(--subtle);
      font-size: 0.62rem;
      font-weight: 700;
      letter-spacing: 0.22em;
      text-transform: uppercase;
    }

    .mobile-menu-meta p {
      margin: 0;
      color: rgba(153, 143, 129, 0.5);
    }

    .nav-toggle:checked + .nav-toggle-button {
      color: var(--primary);
      border-color: rgba(229, 196, 135, 0.48);
      background: rgba(14, 14, 14, 0.9);
    }

    .nav-toggle:checked + .nav-toggle-button .nav-toggle-icon span:first-child {
      transform: translateY(0.28rem) rotate(45deg);
    }

    .nav-toggle:checked + .nav-toggle-button .nav-toggle-icon span:last-child {
      transform: translateY(-0.28rem) rotate(-45deg);
    }

    .nav-toggle:checked ~ .mobile-menu-shell {
      pointer-events: auto;
    }

    .nav-toggle:checked ~ .mobile-menu-shell .mobile-menu-backdrop {
      opacity: 1;
    }

    .nav-toggle:checked ~ .mobile-menu-shell .mobile-menu-panel {
      transform: translateY(0);
      opacity: 1;
    }

    :global(body.menu-open) {
      overflow: hidden;
    }
  }

  @media (max-width: 420px) {
    .mobile-menu-panel {
      padding-inline: 1rem;
    }

    .mobile-menu-copy {
      font-size: clamp(2.35rem, 13vw, 3.2rem);
    }
  }
</style>

<script is:inline>
  const menuToggle = document.querySelector("#site-nav-toggle");
  const mobileLinks = document.querySelectorAll("[data-mobile-menu-link]");

  const syncMenuState = () => {
    if (!menuToggle) return;
    document.body.classList.toggle("menu-open", menuToggle.checked);
  };

  if (menuToggle instanceof HTMLInputElement) {
    menuToggle.addEventListener("change", syncMenuState);

    mobileLinks.forEach((link) => {
      link.addEventListener("click", () => {
        menuToggle.checked = false;
        syncMenuState();
      });
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && menuToggle.checked) {
        menuToggle.checked = false;
        syncMenuState();
      }
    });

    document.addEventListener("astro:before-swap", () => {
      menuToggle.checked = false;
      document.body.classList.remove("menu-open");
    });
  }
</script>
