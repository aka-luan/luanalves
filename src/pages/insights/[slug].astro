---
import SiteFooter from '../../components/SiteFooter.astro';
import SiteNav from '../../components/SiteNav.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { navigation } from '../../data/site';
import {
  getInsightPath,
  getInsightToc,
  insights,
  publishedInsights,
  type InsightArticleBlock,
  type InsightPublishedPost,
} from '../../data/insights';

export function getStaticPaths() {
  return publishedInsights.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props as { post: InsightPublishedPost };
const siteUrl = 'https://luanalves.com.br';
const canonicalPath = getInsightPath(post);
const canonicalUrl = `${siteUrl}${canonicalPath}`;
const whatsappMessage = encodeURIComponent(
  `Olá, Luan! Li o artigo "${post.title}" e quero entender qual estrutura faz sentido para o meu projeto.`,
);
const whatsappHref = `https://wa.me/5591982890565?text=${whatsappMessage}`;
const portfolioHref = '/portfolio/';
const authorLocation = 'Belém, PA';
const authorInitials = post.author.name
  .split(' ')
  .slice(0, 2)
  .map((part) => part[0]?.toUpperCase() ?? '')
  .join('');
const authorSocialLinks = [
  {
    href: 'https://instagram.com/luan.webdev',
    label: 'Instagram de Luan Alves',
    icon: 'photo_camera',
  },
  {
    href: 'https://linkedin.com/in/aka-luan',
    label: 'LinkedIn de Luan Alves',
    icon: 'work',
  },
];
const toc = getInsightToc(post);
const relatedPosts = insights
  .filter((item) => item.slug !== post.slug)
  .filter((item) => item.categorySlug === post.categorySlug || item.featured)
  .slice(0, 3);
const faqItems = post.content
  .filter(
    (
      block,
    ): block is Extract<InsightArticleBlock, { type: 'faq' }> =>
      block.type === 'faq',
  )
  .flatMap((block) => block.items);

const articleSchema = [
  {
    '@type': 'BreadcrumbList',
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        name: 'Início',
        item: siteUrl,
      },
      {
        '@type': 'ListItem',
        position: 2,
        name: 'Insights',
        item: `${siteUrl}/insights/`,
      },
      {
        '@type': 'ListItem',
        position: 3,
        name: post.title,
        item: canonicalUrl,
      },
    ],
  },
  {
    '@type': 'BlogPosting',
    '@id': `${canonicalUrl}#article`,
    headline: post.title,
    description: post.description,
    image: post.heroImage
      ? `${siteUrl}${post.heroImage}`
      : `${siteUrl}/assets/og-cover.webp`,
    datePublished: post.isoDate,
    dateModified: post.isoDate,
    author: { '@id': `${siteUrl}/#person` },
    publisher: { '@id': `${siteUrl}/#business` },
    mainEntityOfPage: canonicalUrl,
    url: canonicalUrl,
    inLanguage: 'pt-BR',
    articleSection: post.category,
    keywords: post.tags.join(', '),
  },
  ...(faqItems.length > 0
    ? [
        {
          '@type': 'FAQPage',
          '@id': `${canonicalUrl}#faq`,
          mainEntity: faqItems.map((item) => ({
            '@type': 'Question',
            name: item.question,
            acceptedAnswer: {
              '@type': 'Answer',
              text: item.answer,
            },
          })),
        },
      ]
    : []),
];

const renderInlineLinks = (text: string) => text;
---

<BaseLayout
  namespace='insight-post'
  title={`${post.title} | Luan Alves`}
  description={post.description}
  canonicalPath={canonicalPath}
  ogType='article'
  socialImage={post.heroImage ?? '/assets/og-cover.webp'}
  socialImageAlt={post.heroImageAlt ?? post.title}
  schema={articleSchema}>
  <main
    class='insight-post-page'
    id='top'
    data-insight-post
    data-url={canonicalUrl}>
    <div class='reading-progress' aria-hidden='true'>
      <span data-reading-progress></span>
    </div>

    <SiteNav
      items={navigation}
      whatsappHref={whatsappHref}
      brandHref='/'
      brandAriaLabel='Luan Alves, página inicial'
    />

    <article class='post-shell'>
      <nav class='post-breadcrumb' aria-label='Breadcrumb'>
        <a href='/'>Início</a>
        <span aria-hidden='true'>/</span>
        <a href='/insights/'>Insights</a>
        <span aria-hidden='true'>/</span>
        <span>{post.category}</span>
      </nav>

      <header class='post-hero'>
        <div class='post-hero__copy'>
          <p class='post-eyebrow'>{post.category}</p>
          <h1>{post.title}</h1>
          <p>{post.description}</p>
          <div class='post-meta' aria-label='Metadados do artigo'>
            <span>{post.date}</span>
            <span>{post.readTime}</span>
            <span>{`${post.category} / ${post.tags[0]}`}</span>
          </div>
        </div>

        <figure class='post-hero__visual'>
          {
            post.heroImage ? (
              <img
                src={post.heroImage}
                alt={post.heroImageAlt}
                width='1200'
                height='800'
                loading='eager'
                decoding='async'
              />
            ) : (
              <div class='post-hero__placeholder' aria-hidden='true' />
            )
          }
        </figure>
      </header>

      <div class='post-layout'>
        <div class='post-content' data-post-content>
          {
            post.content.map((block: InsightArticleBlock) => {
              if (block.type === 'heading') {
                const HeadingTag = `h${block.level}` as 'h2' | 'h3';
                return <HeadingTag id={block.id}>{block.text}</HeadingTag>;
              }

              if (block.type === 'paragraph') {
                return <p set:html={renderInlineLinks(block.text)} />;
              }

              if (block.type === 'list') {
                const ListTag = block.ordered ? 'ol' : 'ul';
                return (
                  <ListTag>
                    {block.items.map((item) => (
                      <li>{item}</li>
                    ))}
                  </ListTag>
                );
              }

              if (block.type === 'blockquote') {
                return (
                  <blockquote>
                    <p>{block.text}</p>
                    {block.cite && <cite>{block.cite}</cite>}
                  </blockquote>
                );
              }

              if (block.type === 'code') {
                return (
                  <figure class='post-code'>
                    {block.caption && <figcaption>{block.caption}</figcaption>}
                    <pre>
                      <code class={`language-${block.language}`}>
                        {block.code}
                      </code>
                    </pre>
                  </figure>
                );
              }

              if (block.type === 'image') {
                return (
                  <figure class='post-image'>
                    {block.src ? (
                      <img
                        src={block.src}
                        alt={block.alt}
                        width='1200'
                        height='760'
                        loading='lazy'
                        decoding='async'
                      />
                    ) : (
                      <div aria-label={block.alt} />
                    )}
                    {block.caption && <figcaption>{block.caption}</figcaption>}
                  </figure>
                );
              }

              if (block.type === 'table') {
                return (
                  <figure class='post-table'>
                    {block.caption && <figcaption>{block.caption}</figcaption>}
                    <div class='post-table__scroll'>
                      <table>
                        <thead>
                          <tr>
                            {block.columns.map((column) => (
                              <th scope='col'>{column}</th>
                            ))}
                          </tr>
                        </thead>
                        <tbody>
                          {block.rows.map((row) => (
                            <tr>
                              {row.map((cell) => (
                                <td>{cell}</td>
                              ))}
                            </tr>
                          ))}
                        </tbody>
                      </table>
                    </div>
                  </figure>
                );
              }

              if (block.type === 'faq') {
                return (
                  <div class='post-faq' id='faq'>
                    {block.items.map((item) => (
                      <section class='post-faq__item'>
                        <h3>{item.question}</h3>
                        <p>{item.answer}</p>
                      </section>
                    ))}
                  </div>
                );
              }

              if (block.type === 'links') {
                return (
                  <div class='post-links'>
                    {block.items.map((item) => (
                      <a href={item.href}>
                        <span>{item.label}</span>
                        <strong>{item.text}</strong>
                      </a>
                    ))}
                  </div>
                );
              }
            })
          }
        </div>

        <aside class='post-sidebar' aria-label='Navegação lateral do artigo'>
          <div class='post-sidebar__panel'>
            <p class='post-sidebar__title'>Neste artigo</p>
            <nav class='post-toc' aria-label='Sumário'>
              {
                toc.map((item) => (
                  <a
                    class:list={[{ 'is-nested': item.level === 3 }]}
                    href={`#${item.id}`}
                    data-insight-toc-link>
                    {item.text}
                  </a>
                ))
              }
            </nav>
          </div>

          <div class='post-sidebar__panel'>
            <p class='post-sidebar__title'>Compartilhar</p>
            <div class='post-share'>
              <button type='button' data-share-action='linkedin'>
                <span class='material-symbols-outlined' aria-hidden='true'
                  >work</span
                >
                LinkedIn
              </button>
              <button type='button' data-share-action='twitter'>
                <span class='material-symbols-outlined' aria-hidden='true'
                  >alternate_email</span
                >
                X
              </button>
              <button type='button' data-share-action='copy'>
                <span class='material-symbols-outlined' aria-hidden='true'
                  >content_copy</span
                >
                <span data-copy-label>Copiar</span>
              </button>
            </div>
          </div>

          <a
            class='post-whatsapp'
            href={whatsappHref}
            target='_blank'
            rel='noreferrer'>
            Pedir orientação de orçamento
            <span class='material-symbols-outlined' aria-hidden='true'
              >arrow_forward</span
            >
          </a>
        </aside>
      </div>

      <section class='author-card' aria-labelledby='author-title'>
        <div class='author-card__identity'>
          <div class='author-card__avatar' aria-hidden='true'>{authorInitials}</div>

          <div class='author-card__heading'>
            <p class='post-eyebrow'>Autor</p>
            <h2 id='author-title'>{post.author.name}</h2>
            <p class='author-card__meta'>
              <span>{post.author.role}</span>
              <span aria-hidden='true'>•</span>
              <span>{authorLocation}</span>
            </p>
          </div>
        </div>

        <p class='author-card__bio'>{post.author.bio}</p>

        <div class='author-card__actions'>
          <a
            class='author-card__action author-card__action--primary'
            href={whatsappHref}
            target='_blank'
            rel='noreferrer'>
            <span class='material-symbols-outlined' aria-hidden='true'>chat</span>
            Falar no WhatsApp
          </a>

          <a class='author-card__action' href={portfolioHref}>
            <span class='material-symbols-outlined' aria-hidden='true'>work</span>
            Ver portfólio
          </a>

          {
            authorSocialLinks.map((link) => (
              <a
                class='author-card__icon-link'
                href={link.href}
                target='_blank'
                rel='noreferrer'
                aria-label={link.label}>
                <span class='material-symbols-outlined' aria-hidden='true'>{link.icon}</span>
              </a>
            ))
          }
        </div>
      </section>
    </article>

    {
      relatedPosts.length > 0 && (
        <section class='related-section' aria-labelledby='related-title'>
          <div class='post-shell'>
            <div class='related-section__header'>
              <p class='post-eyebrow'>Continuar lendo</p>
              <h2 id='related-title'>Insights relacionados</h2>
            </div>
            <div class='related-grid'>
              {relatedPosts.map((item) => (
                <a class='related-card' href={getInsightPath(item)}>
                  <span>{item.category}</span>
                  <h3>{item.title}</h3>
                  <p>{item.excerpt}</p>
                </a>
              ))}
            </div>
          </div>
        </section>
      )
    }
  </main>

  <SiteFooter links={navigation} brandHref='/' />
</BaseLayout>

<style>
  :global(html) {
    scroll-padding-top: 7rem;
  }

  :global(html),
  :global(body) {
    overflow-x: clip;
  }

  .insight-post-page {
    min-height: 100svh;
    overflow-x: hidden;
    background:
      radial-gradient(
        circle at 12% 4%,
        rgba(229, 196, 135, 0.12),
        transparent 24rem
      ),
      radial-gradient(
        circle at 88% 18%,
        rgba(153, 143, 129, 0.12),
        transparent 28rem
      ),
      linear-gradient(
        180deg,
        var(--surface-lowest),
        var(--background) 46%,
        var(--surface-lowest)
      );
    color: var(--text);
  }

  .insight-post-page :global(.site-nav) {
    --nav-bg: rgba(14, 14, 14, 0.88);
    --nav-border: rgba(77, 70, 58, 0.34);
    --nav-blur: 16px;
  }

  .reading-progress {
    position: fixed;
    top: 0;
    left: 0;
    z-index: 80;
    width: 100%;
    height: 3px;
    background: rgba(77, 70, 58, 0.32);
  }

  .reading-progress span {
    display: block;
    width: 100%;
    height: 100%;
    background: var(--primary);
    transform: scaleX(0);
    transform-origin: left center;
  }

  .post-share button,
  .post-whatsapp {
    box-sizing: border-box;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    min-height: 2.6rem;
    border: 1px solid rgba(153, 143, 129, 0.26);
    background: transparent;
    color: var(--muted);
    font: inherit;
    font-size: 0.68rem;
    font-weight: 900;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    transition:
      border-color 180ms ease,
      background-color 180ms ease,
      color 180ms ease,
      transform 180ms ease;
  }

  .post-share button:hover,
  .post-share button:focus-visible {
    border-color: rgba(229, 196, 135, 0.48);
    background: rgba(229, 196, 135, 0.08);
    color: var(--primary);
  }

  .post-share button:active,
  .post-whatsapp:active {
    transform: scale(0.96);
  }

  .post-shell {
    width: min(1120px, calc(100vw - 3rem));
    margin: 0 auto;
  }

  .post-breadcrumb {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    padding-top: clamp(8.5rem, 12vw, 10rem);
    color: var(--subtle);
    font-size: 0.66rem;
    font-weight: 900;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .post-breadcrumb a {
    color: var(--muted);
  }

  .post-hero {
    display: grid;
    gap: clamp(1.5rem, 4vw, 2.7rem);
    padding: clamp(2rem, 5vw, 3.4rem) 0 clamp(2.2rem, 5vw, 3.6rem);
  }

  .post-eyebrow {
    margin: 0 0 1rem;
    color: var(--primary);
    font-size: 0.66rem;
    font-weight: 900;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }

  .post-hero h1,
  .author-card h2,
  .related-section h2,
  .related-card h3 {
    margin: 0;
    color: var(--text);
    font-family: 'Newsreader', serif;
    font-weight: 600;
    letter-spacing: -0.05em;
    line-height: 1.02;
    text-wrap: balance;
  }

  .post-hero h1 {
    font-size: clamp(2.9rem, 5.2vw, 4.45rem);
  }

  .post-hero__copy > p:not(.post-eyebrow) {
    max-width: 42rem;
    margin: 1.25rem 0 0;
    color: var(--muted);
    font-size: clamp(1rem, 1.45vw, 1.16rem);
    font-weight: 300;
    line-height: 1.78;
    text-wrap: pretty;
  }

  .post-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-top: 1.45rem;
  }

  .post-meta span,
  .related-card span {
    display: inline-flex;
    width: fit-content;
    min-height: 1.7rem;
    align-items: center;
    padding: 0.28rem 0.62rem;
    border: 1px solid rgba(229, 196, 135, 0.22);
    background: rgba(229, 196, 135, 0.06);
    color: var(--primary);
    font-size: 0.58rem;
    font-weight: 900;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .post-hero__visual {
    position: relative;
    margin: 0;
    overflow: hidden;
    aspect-ratio: 16 / 7;
    border: 1px solid rgba(229, 196, 135, 0.18);
    background: var(--surface);
    box-shadow:
      inset 0 0 0 1px rgba(255, 255, 255, 0.014),
      0 1.4rem 3rem rgba(0, 0, 0, 0.16),
      0 2.8rem 5.6rem rgba(0, 0, 0, 0.12);
  }

  .post-hero__visual img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    filter: saturate(0.86) contrast(1.05);
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.1);
    transform: scale(1.01);
    transition:
      transform 360ms ease,
      filter 220ms ease;
  }

  .post-hero__visual:hover img,
  .post-hero__visual:focus-within img {
    filter: saturate(0.92) contrast(1.07);
    transform: scale(1.03);
  }

  .post-hero__visual::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      transparent 48%,
      rgba(14, 14, 14, 0.42)
    );
    pointer-events: none;
  }

  .post-layout {
    display: grid;
    grid-template-columns: minmax(0, 46rem) 18rem;
    gap: clamp(2rem, 5vw, 4.5rem);
    align-items: start;
    padding: clamp(1.2rem, 3vw, 2rem) 0 clamp(2.4rem, 6vw, 4.2rem);
  }

  .post-content {
    min-width: 0;
    max-width: 46rem;
  }

  .post-content h2,
  .post-content h3 {
    color: var(--text);
    font-family: 'Newsreader', serif;
    font-weight: 600;
    letter-spacing: -0.035em;
    line-height: 1.08;
    text-wrap: balance;
  }

  .post-content h2 {
    margin: 3.3rem 0 1rem;
    font-size: clamp(2.1rem, 4.2vw, 3.25rem);
  }

  .post-content h3 {
    margin: 2.4rem 0 0.85rem;
    font-size: clamp(1.55rem, 3vw, 2.15rem);
  }

  .post-content p,
  .post-content li {
    color: var(--muted);
    font-size: clamp(1rem, 1.25vw, 1.08rem);
    line-height: 1.86;
  }

  .post-content p {
    margin: 1.05rem 0 0;
  }

  .post-content ul,
  .post-content ol {
    display: grid;
    gap: 0.72rem;
    margin: 1.3rem 0 0;
    padding-left: 1.35rem;
  }

  .post-content li::marker {
    color: var(--primary);
    font-weight: 900;
  }

  .post-content blockquote {
    margin: 2rem 0;
    padding: 1.35rem 1.5rem;
    border-left: 3px solid var(--primary);
    background: var(--surface-soft);
    color: var(--text);
  }

  .post-content blockquote p {
    margin: 0;
    color: var(--text);
    font-family: 'Newsreader', serif;
    font-size: clamp(1.45rem, 3vw, 2rem);
    line-height: 1.22;
  }

  .post-code,
  .post-image,
  .post-table,
  .post-faq {
    margin: 2rem 0;
  }

  .post-code figcaption,
  .post-image figcaption,
  .post-table figcaption {
    margin-bottom: 0.65rem;
    color: var(--subtle);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.08em;
  }

  .post-code pre {
    overflow-x: auto;
    margin: 0;
    padding: 1.2rem;
    border: 1px solid rgba(229, 196, 135, 0.16);
    background: #0b0d0e;
    color: #e9dac7;
    font-size: 0.9rem;
    line-height: 1.72;
  }

  .post-image img,
  .post-image div {
    display: block;
    width: 100%;
    min-height: 18rem;
    border: 1px solid rgba(229, 196, 135, 0.16);
    object-fit: cover;
    background:
      linear-gradient(135deg, rgba(229, 196, 135, 0.12), transparent 42%),
      var(--surface);
  }

  .post-table__scroll {
    overflow-x: auto;
    border: 1px solid rgba(229, 196, 135, 0.16);
    background: rgba(14, 14, 14, 0.52);
  }

  .post-table table {
    width: 100%;
    min-width: 38rem;
    border-collapse: collapse;
  }

  .post-table th,
  .post-table td {
    padding: 0.9rem 1rem;
    border-bottom: 1px solid rgba(77, 70, 58, 0.34);
    text-align: left;
    vertical-align: top;
  }

  .post-table th {
    color: var(--primary);
    font-size: 0.68rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .post-table td {
    color: var(--muted);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .post-table tr:last-child td {
    border-bottom: 0;
  }

  .post-table td:last-child {
    color: var(--text);
    font-weight: 700;
  }

  .post-faq {
    display: grid;
    gap: 0.85rem;
  }

  .post-faq__item {
    position: relative;
    padding: 1rem;
    border: 1px solid rgba(229, 218, 207, 0.13);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.02), transparent 40%),
      var(--surface-soft);
    box-shadow:
      inset 0 0 0 1px rgba(255, 255, 255, 0.014),
      0 0.9rem 1.9rem rgba(0, 0, 0, 0.1);
  }

  .post-faq__item h3 {
    margin: 0;
    color: var(--text);
    font-family: 'Newsreader', serif;
    font-size: clamp(1.35rem, 2.2vw, 1.85rem);
    font-weight: 600;
    letter-spacing: -0.035em;
    line-height: 1.12;
  }

  .post-faq__item p {
    margin-top: 0.7rem;
  }

  .post-links {
    display: grid;
    gap: 0.85rem;
    margin: 2rem 0;
  }

  .post-links a,
  .author-card,
  .related-card,
  .post-sidebar__panel {
    border: 1px solid rgba(229, 218, 207, 0.13);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.02), transparent 40%),
      var(--surface-soft);
    box-shadow:
      inset 0 0 0 1px rgba(255, 255, 255, 0.014),
      0 1rem 2.2rem rgba(0, 0, 0, 0.12),
      0 2rem 3.8rem rgba(0, 0, 0, 0.08);
  }

  .post-links a {
    position: relative;
    display: grid;
    gap: 0.4rem;
    padding: 1rem;
    transition:
      border-color 180ms ease,
      transform 180ms ease,
      box-shadow 180ms ease;
  }

