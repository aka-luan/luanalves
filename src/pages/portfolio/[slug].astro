---
import SiteFooter from '../../components/SiteFooter.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { navigation, portfolioProjects } from '../../data/site';

const siteUrl = 'https://luanalves.com.br';
const whatsappHref =
  'https://wa.me/5591982890565?text=Ol%C3%A1%2C%20Luan!%20Vi%20seu%20portf%C3%B3lio%20e%20quero%20solicitar%20um%20or%C3%A7amento%20para%20um%20site.';

export function getStaticPaths() {
  return portfolioProjects.map((project, index) => {
    const nextProject = portfolioProjects[(index + 1) % portfolioProjects.length];

    return {
      params: { slug: project.slug },
      props: { project, nextProject },
    };
  });
}

const { project, nextProject } = Astro.props;
const projectUrl = `${siteUrl}/portfolio/${project.slug}/`;
const pageTitle = `${project.title} | Case de Portfólio · Luan Alves`;
const pageDescription = `${project.lead} Conheça desafio, solução, entregas e resultados do projeto.`;
const heroTags = project.categories.map((category: string) =>
  category.replace(/^Site\s+/i, ''),
);
const gallery = project.gallery.length
  ? project.gallery
  : [
      {
        src: project.image,
        alt: project.alt,
        caption: 'Página principal',
      },
    ];
const phoneImage = project.mobileImage ?? project.image;
const externalUrl = project.externalUrl ?? project.url;

const caseSchema = [
  {
    '@type': 'BreadcrumbList',
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        name: 'Início',
        item: siteUrl,
      },
      {
        '@type': 'ListItem',
        position: 2,
        name: 'Portfólio',
        item: `${siteUrl}/portfolio/`,
      },
      {
        '@type': 'ListItem',
        position: 3,
        name: project.title,
        item: projectUrl,
      },
    ],
  },
  {
    '@type': 'CreativeWork',
    '@id': `${projectUrl}#creativework`,
    name: project.title,
    headline: project.lead,
    description: project.description,
    url: projectUrl,
    image: new URL(project.image, siteUrl).toString(),
    creator: { '@id': `${siteUrl}/#person` },
    about: project.categories,
    datePublished: `${project.year}-01-01`,
    inLanguage: 'pt-BR',
    sameAs: externalUrl,
  },
];
---

<BaseLayout
  namespace='portfolio-case'
  title={pageTitle}
  description={pageDescription}
  canonicalPath={`/portfolio/${project.slug}/`}
  ogType='article'
  socialImage={project.image}
  socialImageAlt={project.alt}
  schema={caseSchema}>
  <main class='case-page' id='top'>
    <nav class='case-nav' aria-label='Navegação do case' data-case-motion-nav>
      <a class='case-nav__back' href='/portfolio/'>
        <span class='material-symbols-outlined' aria-hidden='true'>arrow_back</span>
        Portfólio
      </a>
      <a class='case-nav__brand' href='/' aria-label='Luan Alves, página inicial'>
        Luan Alves
      </a>
      <a class='case-nav__cta' href={whatsappHref} target='_blank' rel='noreferrer'>
        WhatsApp
      </a>
    </nav>

    <section class='case-hero' aria-labelledby='case-title' data-motion='hero'>
      <div class='case-wrap'>
        <nav
          class='case-breadcrumb'
          aria-label='Breadcrumb'
          data-motion-hero-eyebrow
          data-motion-hidden='y-sm'>
          <a href='/'>Início</a>
          <span aria-hidden='true'>/</span>
          <a href='/portfolio/'>Portfólio</a>
          <span aria-hidden='true'>/</span>
          <span>{project.title}</span>
        </nav>

        <div class='case-hero__meta' data-motion-item='hero-feature' data-motion-hidden='y-sm'>
          {heroTags.map((tag: string) => <span class='case-tag'>{tag}</span>)}
          <span class='case-hero__year'>· {project.year}</span>
        </div>

        <h1 id='case-title' data-motion-hero-title data-motion-hidden='y-lg'>{project.title}</h1>
        <p data-motion-hero-copy data-motion-hidden='y-md'>{project.lead}</p>
      </div>
    </section>

    <section
      class='case-showcase'
      aria-label={`Captura principal do projeto ${project.title}`}
      data-motion-item='hero-media'
      data-motion-hidden='scale'>
      <div class='case-browser'>
        <div class='case-browser__bar' aria-hidden='true'>
          <span class='case-browser__dot case-browser__dot--red'></span>
          <span class='case-browser__dot case-browser__dot--yellow'></span>
          <span class='case-browser__dot case-browser__dot--green'></span>
          <span class='case-browser__url'>{project.siteLabel}</span>
        </div>
        <div class='case-browser__screen'>
          <img
            src={project.image}
            alt={project.alt}
            width='1200'
            height='820'
            loading='eager'
            decoding='async'
            fetchpriority='high'
          />
        </div>
      </div>

      <div class='case-phone' aria-hidden='true'>
        <img src={phoneImage} alt='' width='280' height='500' loading='eager' decoding='async' />
      </div>
    </section>

    <section
      class='case-overview'
      aria-label='Resumo do projeto'
      data-motion-section='case-overview'>
      <div class='case-overview__cell' data-motion-item='case-overview' data-motion-hidden='y-sm'>
        <span>Cliente</span>
        <strong>{project.client}</strong>
      </div>
      <div class='case-overview__cell' data-motion-item='case-overview' data-motion-hidden='y-sm'>
        <span>Segmento</span>
        <strong>{project.segment}</strong>
      </div>
      <div class='case-overview__cell' data-motion-item='case-overview' data-motion-hidden='y-sm'>
        <span>Entregue em</span>
        <strong>{project.deliveredAt}</strong>
      </div>
      <div class='case-overview__cell' data-motion-item='case-overview' data-motion-hidden='y-sm'>
        <span>Site</span>
        <a href={externalUrl} target='_blank' rel='noreferrer'>
          {project.siteLabel}
          <span class='material-symbols-outlined' aria-hidden='true'>north_east</span>
        </a>
      </div>
    </section>

    <section class='case-body' data-motion-section='case-body'>
      <div class='case-body__story' data-motion-item='case-story' data-motion-hidden='x-left'>
        <p class='case-section-label'>O projeto</p>

        <h2>O desafio</h2>
        <p>{project.challenge}</p>

        <h2>A solução</h2>
        <p>{project.solution}</p>
      </div>

      <div class='case-body__deliverables' data-motion-item='case-deliverables' data-motion-hidden='x-right'>
        <p class='case-section-label'>Entregas</p>
        <ol class='case-deliverables' aria-label='Lista de entregas do projeto'>
          {
            project.deliverables.map((item, index: number) => (
              <li data-motion-item='case-deliverable' data-motion-hidden='y-sm'>
                <span aria-hidden='true'>{String(index + 1).padStart(2, '0')}</span>
                <div>
                  <h3>{item.title}</h3>
                  <p>{item.description}</p>
                </div>
              </li>
            ))
          }
        </ol>
      </div>
    </section>

    <section
      class='case-gallery'
      aria-labelledby='case-gallery-title'
      data-motion-section='case-gallery'>
      <p class='case-section-label' data-motion-heading data-motion-hidden='y-sm'>Capturas do projeto</p>
      <h2 id='case-gallery-title' data-motion-heading data-motion-hidden='y-md'>Detalhes visuais da entrega</h2>

      <div class='case-gallery__grid'>
        {
          gallery.map((item) => (
            <figure class='case-gallery__item' data-motion-item='case-gallery' data-motion-hidden='y-card'>
              <span>
                <img
                  src={item.src}
                  alt={item.alt}
                  width='900'
                  height='620'
                  loading='lazy'
                  decoding='async'
                />
              </span>
              <figcaption>{item.caption}</figcaption>
            </figure>
          ))
        }
      </div>
    </section>

    <section
      class='case-results'
      aria-labelledby='case-results-title'
      data-motion-section='case-results'>
      <p class='case-section-label' data-motion-heading data-motion-hidden='y-sm'>Resultados</p>
      <h2 id='case-results-title' data-motion-heading data-motion-hidden='y-md'>O que a entrega resolveu</h2>

      <div class='case-results__grid'>
        {
          project.results.map((result) => (
            <article class='case-result-card' data-motion-item='case-result' data-motion-hidden='y-card'>
              <strong>{result.value}</strong>
              <p>{result.label}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section class='case-next' aria-label='Próximo projeto' data-motion-section='case-next'>
      <a
        class='case-next__card'
        href={`/portfolio/${nextProject.slug}/`}
        data-motion-item='case-next'
        data-motion-hidden='y-sm'>
        <span>
          <small>Próximo projeto</small>
          <strong>{nextProject.title}</strong>
          <em>{nextProject.categories.join(' · ')} · {nextProject.year}</em>
        </span>
        <span class='material-symbols-outlined' aria-hidden='true'>arrow_forward</span>
      </a>
    </section>
  </main>

  <SiteFooter links={navigation} brandHref='/' />
</BaseLayout>

<style>
  :global(html),
  :global(body) {
    overflow-x: clip;
  }

  .case-page {
    min-height: 100svh;
    background:
      radial-gradient(circle at 50% 0%, rgba(229, 196, 135, 0.08), transparent 31rem),
      linear-gradient(180deg, var(--surface-lowest) 0%, var(--background) 46%, var(--surface-lowest) 100%);
    color: var(--text);
  }

  .case-nav {
    position: sticky;
    top: 0;
    z-index: 30;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 1rem;
    padding: 0.95rem clamp(1rem, 4vw, 2rem);
    border-bottom: 1px solid rgba(77, 70, 58, 0.36);
    background: rgba(14, 14, 14, 0.9);
    backdrop-filter: blur(16px);
  }

  .case-nav__back,
  .case-nav__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    min-height: 2.35rem;
    color: var(--subtle);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    transition:
      color 180ms ease,
      border-color 180ms ease,
      background-color 180ms ease;
  }

  .case-nav__back:hover,
  .case-nav__back:focus-visible,
  .case-nav__cta:hover,
  .case-nav__cta:focus-visible {
    color: var(--primary);
  }

  .case-nav__back .material-symbols-outlined {
    font-size: 1rem;
  }

  .case-nav__brand {
    justify-self: center;
    color: var(--primary);
    font-family: 'Newsreader', serif;
    font-size: 1.24rem;
    font-weight: 700;
    letter-spacing: -0.04em;
  }

  .case-nav__cta {
    justify-self: end;
    padding: 0 0.9rem;
    border: 1px solid rgba(153, 143, 129, 0.28);
  }

  .case-wrap,
  .case-showcase,
  .case-overview,
  .case-body,
  .case-gallery,
  .case-results,
  .case-next {
    width: min(960px, calc(100vw - 4rem));
    margin: 0 auto;
  }

  .case-hero {
    padding: clamp(3.2rem, 7vw, 5.2rem) 0 2.25rem;
  }

  .case-breadcrumb {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.55rem;
    margin-bottom: clamp(2rem, 4vw, 3rem);
    color: var(--subtle);
    font-size: 0.62rem;
    font-weight: 800;
    letter-spacing: 0.18em;
    line-height: 1.6;
    text-transform: uppercase;
  }

  .case-breadcrumb a {
    color: var(--muted);
    transition: color 180ms ease;
  }

  .case-breadcrumb a:hover,
  .case-breadcrumb a:focus-visible {
    color: var(--primary);
  }

  .case-hero__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.1rem;
  }

  .case-tag {
    display: inline-flex;
    align-items: center;
    min-height: 1.65rem;
    padding: 0.24rem 0.72rem;
    border: 1px solid rgba(229, 196, 135, 0.22);
    background: rgba(229, 196, 135, 0.045);
    color: var(--primary);
    font-size: 0.56rem;
    font-weight: 900;
    letter-spacing: 0.11em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .case-hero__year {
    color: var(--subtle);
    font-size: 0.78rem;
    font-variant-numeric: tabular-nums;
  }

  .case-hero h1 {
    max-width: 12ch;
    margin: 0;
    color: var(--text);
    font-family: 'Newsreader', serif;
    font-size: clamp(3.35rem, 8vw, 5.8rem);
    font-weight: 600;
    letter-spacing: -0.055em;
    line-height: 0.98;
    text-wrap: balance;
  }

  .case-hero p {
    max-width: 40rem;
    margin: 1.2rem 0 0;
    color: var(--muted);
    font-size: clamp(1rem, 1.4vw, 1.12rem);
    font-weight: 300;
    line-height: 1.72;
    text-wrap: pretty;
  }

  .case-showcase {
    position: relative;
  }

  .case-browser {
    overflow: hidden;
    border: 1px solid rgba(229, 218, 207, 0.14);
    border-bottom: 0;
    background: var(--surface);
    box-shadow:
      0 1.8rem 4.8rem rgba(0, 0, 0, 0.26),
      inset 0 1px 0 rgba(255, 255, 255, 0.04);
  }

  .case-browser__bar {
    display: flex;
    align-items: center;
    gap: 0.38rem;
    min-height: 2.35rem;
    padding: 0 0.8rem;
    border-bottom: 1px solid rgba(229, 218, 207, 0.11);
    background: var(--surface-elevated);
  }

  .case-browser__dot {
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 999px;
  }

  .case-browser__dot--red {
    background: #ff5f57;
  }

  .case-browser__dot--yellow {
    background: #febc2e;
  }

  .case-browser__dot--green {
    background: #28c840;
  }

  .case-browser__url {
    display: flex;
    align-items: center;
    flex: 1;
    min-width: 0;
    height: 1.2rem;
    margin-left: 0.55rem;
    padding: 0 0.75rem;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.045);
    color: var(--subtle);
    font-size: 0.62rem;
    white-space: nowrap;
    text-overflow: ellipsis;
  }

  .case-browser__screen {
    position: relative;
    aspect-ratio: 1.9 / 1;
    overflow: hidden;
    background: var(--surface-lowest);
  }

  .case-browser__screen::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(0, 0, 0, 0.01), rgba(0, 0, 0, 0.16)),
      radial-gradient(circle at 50% 100%, rgba(229, 196, 135, 0.1), transparent 58%);
    pointer-events: none;
  }

  .case-browser__screen img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    filter: saturate(1.04) contrast(1.04) brightness(0.98);
  }

  .case-phone {
    position: absolute;
    right: 2.4rem;
    bottom: -1.2rem;
    width: 5.2rem;
    aspect-ratio: 9 / 16;
    overflow: hidden;
    border: 2px solid var(--surface-strong);
    background: var(--surface-lowest);
    box-shadow: -0.6rem 1.2rem 2.6rem rgba(0, 0, 0, 0.36);
  }

  .case-phone img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }

  .case-overview {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    border: 1px solid rgba(229, 218, 207, 0.14);
    border-top: 0;
  }

  .case-overview__cell {
    display: grid;
    gap: 0.35rem;
    min-width: 0;
    padding: 1.25rem 1.35rem;
    border-right: 1px solid rgba(229, 218, 207, 0.12);
  }

  .case-overview__cell:last-child {
    border-right: 0;
  }

  .case-overview span,
  .case-section-label,
  .case-next small {
    color: var(--subtle);
    font-size: 0.58rem;
    font-weight: 900;
    letter-spacing: 0.16em;
    line-height: 1.45;
    text-transform: uppercase;
  }

  .case-overview strong,
  .case-overview a {
    min-width: 0;
    color: var(--text);
    font-size: 0.82rem;
    font-weight: 800;
    line-height: 1.45;
  }

  .case-overview a {
    display: inline-flex;
    align-items: center;
    gap: 0.22rem;
    overflow-wrap: anywhere;
    color: var(--muted);
    transition: color 180ms ease;
  }

  .case-overview a:hover,
  .case-overview a:focus-visible {
    color: var(--primary);
  }

  .case-overview .material-symbols-outlined {
    flex: 0 0 auto;
    font-size: 0.95rem;
  }

  .case-body {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    border: 1px solid rgba(229, 218, 207, 0.14);
    border-top: 0;
  }

  .case-body__story,
  .case-body__deliverables {
    padding: clamp(2rem, 4vw, 2.8rem);
  }

  .case-body__story {
    border-right: 1px solid rgba(229, 218, 207, 0.12);
  }

  .case-section-label {
    margin: 0 0 1.35rem;
  }

  .case-body h2,
  .case-gallery h2,
  .case-results h2 {
    margin: 0;
    color: var(--text);
    font-family: 'Newsreader', serif;
    font-size: clamp(1.55rem, 3vw, 2.15rem);
    font-weight: 600;
    letter-spacing: -0.045em;
    line-height: 1.08;
  }

  .case-body h2:not(:first-of-type) {
    margin-top: 1.9rem;
  }

  .case-body p,
  .case-result-card p {
    margin: 0.75rem 0 0;
    color: var(--muted);
    font-size: 0.9rem;
    font-weight: 300;
    line-height: 1.78;
    text-wrap: pretty;
  }

  .case-deliverables {
    display: grid;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .case-deliverables li {
    display: grid;
    grid-template-columns: 2rem minmax(0, 1fr);
    gap: 0.85rem;
    padding: 1rem 0;
    border-bottom: 1px solid rgba(229, 218, 207, 0.1);
  }

  .case-deliverables li:first-child {
    padding-top: 0;
  }

  .case-deliverables li:last-child {
    border-bottom: 0;
    padding-bottom: 0;
  }

  .case-deliverables li > span {
    color: var(--subtle);
    font-size: 0.66rem;
    font-variant-numeric: tabular-nums;
  }

  .case-deliverables h3 {
    margin: 0;
    color: var(--text);
    font-size: 0.88rem;
    font-weight: 800;
    line-height: 1.35;
  }

  .case-deliverables p {
    margin-top: 0.28rem;
    font-size: 0.78rem;
    line-height: 1.58;
  }

  .case-gallery,
  .case-results {
    padding: clamp(2.1rem, 4vw, 2.7rem);
    border: 1px solid rgba(229, 218, 207, 0.14);
    border-top: 0;
  }

  .case-gallery__grid,
  .case-results__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.85rem;
    margin-top: 1.45rem;
  }

  .case-gallery__item {
    min-width: 0;
    margin: 0;
    overflow: hidden;
    border: 1px solid rgba(229, 218, 207, 0.12);
    background: var(--surface);
  }

  .case-gallery__item span {
    display: block;
    aspect-ratio: 1.32 / 1;
    overflow: hidden;
    background: var(--surface-lowest);
  }

  .case-gallery__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }

  .case-gallery__item figcaption {
    padding: 0.72rem 0.85rem;
    border-top: 1px solid rgba(229, 218, 207, 0.1);
    color: var(--subtle);
    font-size: 0.7rem;
    line-height: 1.4;
  }

  .case-result-card {
    display: grid;
    align-content: start;
    min-height: 10.5rem;
    padding: 1.25rem;
    border: 1px solid rgba(229, 196, 135, 0.18);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.02), transparent 42%),
      var(--surface);
  }

  .case-result-card strong {
    color: var(--primary);
    font-family: 'Newsreader', serif;
    font-size: clamp(1.75rem, 3vw, 2.35rem);
    font-weight: 600;
    letter-spacing: -0.045em;
    line-height: 0.98;
  }

  .case-next {
    padding: 1.6rem 0 clamp(3.5rem, 6vw, 5rem);
  }

  .case-next__card {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 1.2rem;
    align-items: center;
    padding: clamp(1.45rem, 3vw, 1.9rem);
    border: 1px solid rgba(229, 196, 135, 0.2);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.018), transparent 42%),
      var(--surface-elevated);
    transition:
      border-color 180ms ease,
      background-color 180ms ease,
      transform 180ms ease;
  }

  .case-next__card:hover,
  .case-next__card:focus-visible {
    border-color: rgba(229, 196, 135, 0.46);
    background-color: rgba(229, 196, 135, 0.04);
    transform: translateY(-2px);
  }

  .case-next__card span:first-child {
    display: grid;
    gap: 0.35rem;
    min-width: 0;
  }

  .case-next strong {
    color: var(--text);
    font-family: 'Newsreader', serif;
    font-size: clamp(1.85rem, 3.8vw, 2.55rem);
    font-weight: 600;
    letter-spacing: -0.045em;
    line-height: 1;
    text-wrap: balance;
  }

  .case-next em {
    color: var(--muted);
    font-size: 0.78rem;
    font-style: normal;
    line-height: 1.55;
  }

  .case-next .material-symbols-outlined {
    color: var(--primary);
    font-size: 1.55rem;
    transition: transform 180ms ease;
  }

  .case-next__card:hover .material-symbols-outlined,
  .case-next__card:focus-visible .material-symbols-outlined {
    transform: translateX(0.22rem);
  }

  @media (max-width: 840px) {
    .case-wrap,
    .case-showcase,
    .case-overview,
