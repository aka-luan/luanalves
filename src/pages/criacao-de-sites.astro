---
import FaqSection from '../components/FaqSection.astro';
import HomeCta from '../components/HomeCta.astro';
import PortfolioShowcase from '../components/PortfolioShowcase.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SiteNav from '../components/SiteNav.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { projects } from '../data/site';

const whatsappHref =
  'https://wa.me/5591982890565?text=Ol%C3%A1%2C%20Luan!%20Quero%20solicitar%20um%20or%C3%A7amento%20para%20cria%C3%A7%C3%A3o%20de%20site.';

const featureItems = [
  { icon: 'trending_up', label: 'SEO desde o início' },
  { icon: 'phone_iphone', label: 'Mobile first' },
  { icon: 'code', label: 'Código limpo' },
];

const solutionItems = [
  {
    icon: 'corporate_fare',
    title: 'Site Institucional',
    copy: 'Ideal para empresas que precisam apresentar serviços, diferenciais e autoridade.',
    image: '/assets/tresor-home.webp',
    tags: ['SEO', 'Credibilidade', 'Mobile first'],
  },
  {
    icon: 'ads_click',
    title: 'Landing Page',
    copy: 'Perfeita para campanhas, tráfego pago e captação de leads com foco total em conversão.',
    image: '/assets/skyrocket-home.webp',
    tags: ['Lead', 'Velocidade', 'Conversão'],
  },
  {
    icon: 'article',
    title: 'Blog Profissional',
    copy: 'Estrutura editorial preparada para conteúdo, ranqueamento e gestão simples.',
    image: '/assets/poliana-bentes-home.webp',
    tags: ['Editorial', 'CMS', 'Performance'],
  },
];

const resultCards = [
  {
    number: '01',
    icon: 'workspace_premium',
    title: 'Autoridade',
    copy: 'Design profissional que transmite confiança desde o primeiro acesso.',
  },
  {
    number: '02',
    icon: 'search',
    title: 'SEO técnico',
    copy: 'Estrutura preparada para indexação e boas práticas de busca.',
  },
  {
    number: '03',
    icon: 'speed',
    title: 'Performance',
    copy: 'Carregamento rápido em desktop e mobile.',
  },
  {
    number: '04',
    icon: 'chat_bubble',
    title: 'Conversão',
    copy: 'Páginas pensadas para gerar contatos, pedidos e orçamentos.',
  },
];

const resultStats = [
  {
    icon: 'trending_up',
    label: 'Mais visibilidade no Google',
  },
  {
    icon: 'person',
    label: 'Mais confiança do seu cliente',
  },
  {
    icon: 'monetization_on',
    label: 'Mais resultados para o seu negócio',
  },
];

const processSteps = [
  {
    number: '01',
    title: 'Diagnóstico',
    copy: 'Entendo o seu negócio, objetivos e referências.',
  },
  {
    number: '02',
    title: 'Arquitetura',
    copy: 'Organizo a estrutura, páginas e prioridades do projeto.',
  },
  {
    number: '03',
    title: 'Design & desenvolvimento',
    copy: 'Crio o layout e implemento com foco em performance.',
  },
  {
    number: '04',
    title: 'Revisão & lançamento',
    copy: 'Ajustes finais, publicação e orientação de uso.',
  },
];

const includedItems = [
  {
    icon: 'adjust',
    title: 'Estrutura estratégica',
    copy: 'Definição de páginas, seções e hierarquia de conteúdo.',
  },
  {
    icon: 'devices',
    title: 'Design responsivo',
    copy: 'Layout pensado para desktop, tablet e celular.',
  },
  {
    icon: 'code',
    title: 'Desenvolvimento sob medida',
    copy: 'Código limpo, rápido e bem organizado.',
  },
  {
    icon: 'search',
    title: 'SEO inicial',
    copy: 'Títulos, headings, metadados e base técnica otimizada.',
  },
  {
    icon: 'extension',
    title: 'Integrações essenciais',
    copy: 'WhatsApp, formulários, mapa, analytics ou CMS.',
  },
  {
    icon: 'menu_book',
    title: 'Orientação de uso',
    copy: 'Entrega com explicação para futuras atualizações.',
  },
];

const differentialItems = [
  {
    icon: 'forum',
    title: 'Comunicação direta',
    copy: 'Alinhamento rápido e sem ruído de agência.',
  },
  {
    icon: 'code',
    title: 'Código limpo',
    copy: 'Projetos rápidos, organizados e fáceis de manter.',
  },
  {
    icon: 'trending_up',
    title: 'Design para conversão',
    copy: 'Visual pensado para gerar confiança e ação.',
  },
  {
    icon: 'support_agent',
    title: 'Suporte pós-lançamento',
    copy: 'Acompanhamento depois que o site vai ao ar.',
  },
];

const faqItems = [
  {
    question: 'Em quanto tempo o site fica pronto?',
    answer:
      'O prazo varia conforme a complexidade, mas projetos mais enxutos costumam levar algumas semanas. Antes de começar, eu apresento um cronograma claro.',
  },
  {
    question: 'O site será responsivo?',
    answer:
      'Sim. O layout é pensado para desktop, tablet e celular, com atenção especial à leitura, velocidade e navegação no mobile.',
  },
  {
    question: 'Você faz SEO?',
    answer:
      'Sim. A entrega inclui base técnica de SEO, estrutura semântica, títulos, metadados e performance como prioridade desde o início.',
  },
  {
    question: 'Posso atualizar o conteúdo depois?',
    answer:
      'Sim. O projeto pode incluir orientação de uso, CMS ou uma estrutura preparada para atualizações futuras, conforme o escopo definido.',
  },
  {
    question: 'O domínio e a hospedagem estão inclusos?',
    answer:
      'Posso orientar a contratação e configurar tudo para publicação. Custos de domínio, hospedagem e ferramentas externas ficam separados do desenvolvimento.',
  },
];
---

<BaseLayout
  namespace='criacao-de-sites'
  title='Criação de Sites | Luan Alves'
  description='Criação de sites institucionais, blogs e landing pages para empresas que precisam vender mais com presença digital profissional.'
  canonicalPath='/criacao-de-sites/'>
  <main class='site-creation-page'>
    <SiteNav
      whatsappHref={whatsappHref}
      brandHref='/'
      brandAriaLabel='Luan Alves, página inicial'
    />

    <section
      class='creation-hero'
      aria-labelledby='creation-hero-title'
      data-motion='hero'>
      <div class='creation-hero__glow' aria-hidden='true' data-motion-glow>
      </div>
      <div class='creation-hero__grain' aria-hidden='true'></div>

      <div class='creation-hero__inner'>
        <div class='creation-hero__copy'>
          <p
            class='creation-eyebrow'
            data-motion-hero-eyebrow
            data-motion-hidden='y-sm'>
            Serviço • Criação de sites
          </p>

          <h1
            id='creation-hero-title'
            data-motion-hero-title
            data-motion-hidden='y-lg'>
            Seu site precisa
            <em>vender, não só</em>
            existir.
          </h1>

          <p
            class='creation-lead'
            data-motion-hero-copy
            data-motion-hidden='y-md'>
            Crio sites institucionais, blogs e landing pages para empresas que
            precisam de presença digital forte, carregamento rápido e estrutura
            pensada para conversão.
          </p>

          <div class='creation-actions' data-motion-hero-actions>
            <a
              class='creation-button creation-button--solid'
              href={whatsappHref}
              target='_blank'
              rel='noreferrer'
              data-motion-hidden='y-sm'>
              Solicitar orçamento
            </a>
            <a
              class='creation-button creation-button--outline'
              href='/#portfolio'
              data-motion-hidden='y-sm'>
              Ver projetos
            </a>
          </div>

          <div class='creation-features' aria-label='Diferenciais'>
            {
              featureItems.map((item) => (
                <article
                  class='creation-feature'
                  data-motion-item='hero-feature'
                  data-motion-hidden='y-sm'>
                  <span class='creation-feature__icon' aria-hidden='true'>
                    <span class='material-symbols-outlined'>{item.icon}</span>
                  </span>
                  <p>{item.label}</p>
                </article>
              ))
            }
          </div>
        </div>

        <div
          class='creation-hero__media'
          aria-hidden='true'
          data-motion-item='hero-media'
          data-motion-hidden='scale'>
          <div class='creation-orbit'></div>
          <img
            src='/assets/hero-img.webp'
            alt=''
            width='1448'
            height='1086'
            decoding='async'
            fetchpriority='high'
          />
        </div>
      </div>
    </section>

    <section
      class='solutions-section'
      id='solucoes'
      aria-labelledby='solutions-title'
      data-motion-section='services'>
      <div class='solutions-section__glow' aria-hidden='true'></div>

      <div class='solutions-section__inner'>
        <div class='solutions-copy'>
          <p
            class='creation-eyebrow solutions-eyebrow'
            data-motion-heading
            data-motion-hidden='y-sm'>
            Soluções
          </p>

          <h2
            id='solutions-title'
            data-motion-heading
            data-motion-hidden='y-md'>
            <span>O formato certo para</span>
            <em>cada objetivo.</em>
          </h2>

          <p data-motion-copy data-motion-hidden='y-md'>
            Cada projeto é desenhado de acordo com a meta do negócio, o estágio
            da empresa e a forma como você precisa gerar oportunidades.
          </p>
        </div>

        <div class='solutions-grid' aria-label='Formatos de site'>
          {
            solutionItems.map((item) => (
              <article
                class='solution-card'
                data-motion-item='service'
                data-motion-hidden='y-card'>
                <div class='solution-card__browser' aria-hidden='true'>
                  <span />
                  <span />
                  <span />
                </div>

                <div class='solution-card__media'>
                  <img
                    src={item.image}
                    alt=''
                    width='900'
                    height='650'
                    loading='lazy'
                    decoding='async'
                  />
                </div>

                <div class='solution-card__body'>
                  <div class='solution-card__title'>
                    <span class='solution-card__icon' aria-hidden='true'>
                      <span class='material-symbols-outlined'>{item.icon}</span>
                    </span>
                    <h3>{item.title}</h3>
                  </div>

                  <p>{item.copy}</p>

                  <div class='solution-card__tags'>
                    {item.tags.map((tag) => (
                      <span>{tag}</span>
                    ))}
                  </div>
                </div>
              </article>
            ))
          }
        </div>

        <p
          class='solutions-note'
          data-motion-item='service'
          data-motion-hidden='y-sm'>
          <span class='material-symbols-outlined' aria-hidden='true'>
            check_circle
          </span>
          Todos os formatos são desenvolvidos com foco em performance, SEO técnico,
          experiência do usuário e resultados reais.
        </p>
      </div>
    </section>

    <section
      class='results-section'
      id='resultados'
      aria-labelledby='results-title'
      data-motion-section='results'>
      <div class='results-section__glow' aria-hidden='true'></div>

      <div class='results-section__inner'>
        <div class='results-copy'>
          <p
            class='creation-eyebrow results-eyebrow'
            data-motion-heading
            data-motion-hidden='y-sm'>
            Resultados
          </p>

          <h2 id='results-title' data-motion-heading data-motion-hidden='y-md'>
            <span>Um bom site</span>
            <span>precisa <em>trabalhar</em></span>
            <em>por você.</em>
          </h2>

          <p class='results-lead' data-motion-copy data-motion-hidden='y-md'>
            Mais do que presença digital, o seu site deve transmitir confiança,
            aparecer no Google, carregar rápido e facilitar o contato com a sua
            empresa.
          </p>
        </div>

        <div
          class='results-media'
          aria-hidden='true'
          data-motion-item='visual'
          data-motion-hidden='scale'>
          <img
            src='/assets/resultados-img.webp'
            alt=''
            width='1448'
            height='1086'
            loading='lazy'
            decoding='async'
          />
        </div>

        <div class='results-card-grid'>
          {
            resultCards.map((item) => (
              <article
                class='results-card'
                data-motion-item='result'
                data-motion-hidden='y-card'>
                <div class='results-card__head'>
                  <span class='results-card__number'>{item.number}</span>
                  <span class='results-card__rule' aria-hidden='true' />
                </div>

                <span class='results-card__icon' aria-hidden='true'>
                  <span class='material-symbols-outlined'>{item.icon}</span>
                </span>

                <h3>{item.title}</h3>
                <p>{item.copy}</p>
              </article>
            ))
          }
        </div>

        <div class='results-benefits' aria-label='Benefícios esperados'>
          {
            resultStats.map((item) => (
              <article
                class='results-benefit'
                data-motion-item='result'
                data-motion-hidden='y-sm'>
                <span class='results-benefit__icon' aria-hidden='true'>
                  <span class='material-symbols-outlined'>{item.icon}</span>
                </span>
                <p>{item.label}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section
      class='process-section'
      id='processo'
      aria-labelledby='process-title'
      data-motion-section='process'>
      <div class='process-section__glow' aria-hidden='true'></div>

      <div class='process-section__inner'>
        <div class='process-copy'>
          <p
            class='creation-eyebrow process-eyebrow'
            data-motion-heading
            data-motion-hidden='y-sm'>
            Processo
          </p>

          <h2 id='process-title' data-motion-heading data-motion-hidden='y-md'>
            <span>Como funciona</span>
            <span><em>a criação</em> do seu site</span>
          </h2>

          <p class='process-lead' data-motion-copy data-motion-hidden='y-md'>
            Um processo claro reduz retrabalho, acelera a entrega e garante que
            cada etapa faça sentido para o seu negócio.
          </p>
        </div>

        <div class='process-timeline' aria-label='Etapas do processo'>
          {
            processSteps.map((item) => (
              <article
                class='process-step'
                data-motion-item='process'
                data-motion-hidden='x-left'>
                <span class='process-step__number'>{item.number}</span>
                <span class='process-step__marker' aria-hidden='true'>
                  <span />
                </span>
                <div class='process-step__copy'>
                  <h3>{item.title}</h3>
                  <p>{item.copy}</p>
                </div>
              </article>
            ))
          }
        </div>

        <div
          class='process-media'
          aria-hidden='true'
          data-motion-item='visual'
          data-motion-hidden='scale'>
          <img
            src='/assets/processo-img.webp'
            alt=''
            width='1448'
            height='1086'
            loading='lazy'
            decoding='async'
          />
        </div>
      </div>
    </section>

    <section
      class='included-section'
      id='incluso'
      aria-labelledby='included-title'
      data-motion-section='included'>
      <div class='included-section__glow' aria-hidden='true'></div>

      <div class='included-section__inner'>
        <div class='included-copy'>
          <p
            class='creation-eyebrow included-eyebrow'
            data-motion-heading
            data-motion-hidden='y-sm'>
            Incluso
          </p>

          <h2 id='included-title' data-motion-heading data-motion-hidden='y-md'>
            <span>O que está incluso</span>
            <em>no projeto.</em>
          </h2>

          <p class='included-lead' data-motion-copy data-motion-hidden='y-md'>
            Cada entrega combina estratégia, design e desenvolvimento para que o
            site já nasça pronto para performar.
          </p>
        </div>

        <div class='included-grid' aria-label='Itens inclusos no projeto'>
          {
            includedItems.map((item) => (
              <article
                class='included-card'
                data-motion-item='included'
                data-motion-hidden='y-card'>
                <span class='included-card__icon' aria-hidden='true'>
                  <span class='material-symbols-outlined'>{item.icon}</span>
                </span>

                <h3>{item.title}</h3>
                <p>{item.copy}</p>
              </article>
            ))
          }
        </div>

        <div
          class='included-media'
          aria-hidden='true'
          data-motion-item='visual'
          data-motion-hidden='scale'>
          <div class='included-orbit'></div>
          <img
            src='/assets/incluso-img.webp'
            alt=''
            width='1448'
            height='1086'
            loading='lazy'
            decoding='async'
          />
        </div>
      </div>
    </section>

    <section
      class='differentials-section'
      id='diferenciais'
      aria-labelledby='differentials-title'
      data-motion-section='differentials'>
      <div class='differentials-section__glow' aria-hidden='true'></div>

      <div class='differentials-section__inner'>
        <div class='differentials-content'>
          <div class='differentials-copy'>
            <p
              class='creation-eyebrow differentials-eyebrow'
              data-motion-heading
              data-motion-hidden='y-sm'>
              Diferenciais
            </p>

            <h2
              id='differentials-title'
              data-motion-heading
              data-motion-hidden='y-md'>
              <span>Por que trabalhar</span>
              <span><em>diretamente</em> comigo.</span>
            </h2>

            <p
              class='differentials-lead'
              data-motion-copy
              data-motion-hidden='y-md'>
              Você fala com quem planeja, desenha e desenvolve o site, sem
              intermediários, com mais clareza e mais agilidade.
            </p>
          </div>

          <div class='differentials-grid' aria-label='Diferenciais da entrega'>
            {
              differentialItems.map((item) => (
                <article
                  class='differential-card'
                  data-motion-item='differential'
                  data-motion-hidden='y-card'>
                  <span class='differential-card__icon' aria-hidden='true'>
                    <span class='material-symbols-outlined'>{item.icon}</span>
                  </span>

                  <h3>{item.title}</h3>
                  <p>{item.copy}</p>
                </article>
              ))
            }
          </div>
        </div>

        <div
          class='differentials-media'
          aria-hidden='true'
          data-motion-item='visual'
          data-motion-hidden='scale'>
          <span class='differentials-orbit'></span>
          <img
            src='/assets/diferenciais-img.webp'
            alt=''
            width='1448'
            height='1086'
            loading='lazy'
            decoding='async'
          />
        </div>
      </div>
    </section>

    <PortfolioShowcase projects={projects} />

    <FaqSection items={faqItems} />

    <HomeCta whatsappHref={whatsappHref} />
  </main>

  <SiteFooter brandHref='/' />
</BaseLayout>

<style>
  :global(body) {
    background: #0f1010;
  }

  :global(html),
  :global(body) {
    overflow-x: clip;
  }

  .site-creation-page {
    min-height: 100svh;
    overflow-x: hidden;
    background:
      radial-gradient(
        circle at 73% 42%,
        rgba(218, 176, 101, 0.2),
        transparent 27rem
      ),
      radial-gradient(
        circle at 43% 103%,
        rgba(229, 196, 135, 0.1),
        transparent 28rem
      ),
      linear-gradient(115deg, rgba(7, 8, 8, 0.99) 0%, #151514 52%, #0d0e0e 100%);
    color: #f4f1ee;
  }

  .site-creation-page > section {
    scroll-margin-top: 5.7rem;
  }

  .creation-nav {
    position: fixed;
    top: 0;
    left: 0;
    z-index: 10;
    display: grid;
    grid-template-columns: minmax(8rem, 1fr) auto auto;
    align-items: center;
    gap: clamp(1.75rem, 2vw, 1.95rem);
    width: 100%;
    min-width: 0;
    padding: clamp(1.35rem, 2vw, 1.7rem) clamp(1.75rem, 1.9vw, 1.95rem)
      clamp(1.35rem, 2vw, 1.7rem) clamp(2rem, 2.65vw, 2.5rem);
  }

  .creation-brand {
    display: inline-flex;
    align-items: center;
    justify-self: start;
    gap: 0.42rem;
    font-family: 'Newsreader', serif;
    font-size: clamp(1.35rem, 1.85vw, 1.7rem);
    font-weight: 700;
    letter-spacing: -0.055em;
    line-height: 1;
    color: #e1bf7a;
  }

  .creation-brand span {
    width: 0.42rem;
    height: 0.42rem;
    margin-top: 0.2rem;
    border-radius: 999px;
    background: currentColor;
  }

  .creation-nav-links {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(1.2rem, 2vw, 2rem);
  }

  .creation-nav-links a,
  .creation-nav-cta,
  .creation-button,
  .creation-eyebrow {
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.26em;
    text-transform: uppercase;
  }

  .creation-nav-links a {
    min-height: 2.8rem;
    display: inline-flex;
    align-items: center;
    color: rgba(229, 218, 207, 0.78);
    transition:
      color 180ms ease,
      transform 180ms ease;
  }

  .creation-nav-links a,
  .creation-nav-cta {
    font-size: 0.7rem;
    letter-spacing: 0.24em;
  }

  .creation-nav-links a:hover,
  .creation-nav-links a:focus-visible {
    color: #e5c487;
    transform: translateY(-1px);
  }

  .creation-nav-cta {
    justify-self: end;
    min-width: 0;
    min-height: 3.1rem;
    padding: 1rem 1.1rem;
    border: 1px solid rgba(229, 218, 207, 0.2);
    color: #f4f1ee;
    transition:
      border-color 180ms ease,
      color 180ms ease,
      background-color 180ms ease,
      transform 180ms ease;
  }

  .creation-nav-cta:hover,
  .creation-nav-cta:focus-visible {
    border-color: rgba(229, 196, 135, 0.55);
    background: rgba(229, 196, 135, 0.06);
    color: #e5c487;
    transform: translateY(-1px);
  }

  .creation-hero {
    position: relative;
    min-height: 100svh;
    padding: clamp(7.2rem, 9.7vw, 9.1rem) clamp(1.5rem, 6.25vw, 5.85rem) 3.2rem;
    isolation: isolate;
  }

  .creation-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -3;
    background:
      linear-gradient(
        to right,
        rgba(255, 255, 255, 0.025) 1px,
        transparent 1px
      ),
      linear-gradient(
        to bottom,
        rgba(255, 255, 255, 0.018) 1px,
        transparent 1px
      );
    background-size: 4rem 4rem;
    mask-image: radial-gradient(circle at 62% 42%, black, transparent 68%);
    opacity: 0.11;
  }

  .creation-hero__glow {
    position: absolute;
    inset: 0;
    z-index: -2;
    background:
      linear-gradient(
        90deg,
        rgba(8, 8, 8, 0.9),
        rgba(8, 8, 8, 0.22) 56%,
        rgba(8, 8, 8, 0.54)
      ),
