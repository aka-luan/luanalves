---
import BaseLayout from '../layouts/BaseLayout.astro';

const whatsappHref =
  'https://wa.me/5591982890565?text=Ol%C3%A1%2C%20Luan!%20Quero%20solicitar%20um%20or%C3%A7amento%20para%20cria%C3%A7%C3%A3o%20de%20site.';

const navItems = [
  { href: '/#servicos', label: 'Serviços' },
  { href: '/#portfolio', label: 'Portfólio' },
  { href: '/#contato', label: 'Contato' },
];

const featureItems = [
  { icon: 'trending_up', label: 'SEO desde o início' },
  { icon: 'phone_iphone', label: 'Mobile first' },
  { icon: 'code', label: 'Código limpo' },
];

const resultCards = [
  {
    number: '01',
    icon: 'workspace_premium',
    title: 'Autoridade',
    copy: 'Design profissional que transmite confiança desde o primeiro acesso.',
  },
  {
    number: '02',
    icon: 'search',
    title: 'SEO técnico',
    copy: 'Estrutura preparada para indexação e boas práticas de busca.',
  },
  {
    number: '03',
    icon: 'speed',
    title: 'Performance',
    copy: 'Carregamento rápido em desktop e mobile.',
  },
  {
    number: '04',
    icon: 'chat_bubble',
    title: 'Conversão',
    copy: 'Páginas pensadas para gerar contatos, pedidos e orçamentos.',
  },
];

const resultStats = [
  {
    icon: 'trending_up',
    label: 'Mais visibilidade no Google',
  },
  {
    icon: 'person',
    label: 'Mais confiança do seu cliente',
  },
  {
    icon: 'monetization_on',
    label: 'Mais resultados para o seu negócio',
  },
];

const processSteps = [
  {
    number: '01',
    title: 'Diagnóstico',
    copy: 'Entendo o seu negócio, objetivos e referências.',
  },
  {
    number: '02',
    title: 'Arquitetura',
    copy: 'Organizo a estrutura, páginas e prioridades do projeto.',
  },
  {
    number: '03',
    title: 'Design & desenvolvimento',
    copy: 'Crio o layout e implemento com foco em performance.',
  },
  {
    number: '04',
    title: 'Revisão & lançamento',
    copy: 'Ajustes finais, publicação e orientação de uso.',
  },
];

const includedItems = [
  {
    icon: 'adjust',
    title: 'Estrutura estratégica',
    copy: 'Definição de páginas, seções e hierarquia de conteúdo.',
  },
  {
    icon: 'devices',
    title: 'Design responsivo',
    copy: 'Layout pensado para desktop, tablet e celular.',
  },
  {
    icon: 'code',
    title: 'Desenvolvimento sob medida',
    copy: 'Código limpo, rápido e bem organizado.',
  },
  {
    icon: 'search',
    title: 'SEO inicial',
    copy: 'Títulos, headings, metadados e base técnica otimizada.',
  },
  {
    icon: 'extension',
    title: 'Integrações essenciais',
    copy: 'WhatsApp, formulários, mapa, analytics ou CMS.',
  },
  {
    icon: 'menu_book',
    title: 'Orientação de uso',
    copy: 'Entrega com explicação para futuras atualizações.',
  },
];
---

<BaseLayout
  title='Criação de Sites | Luan Alves'
  description='Criação de sites institucionais, blogs e landing pages para empresas que precisam vender mais com presença digital profissional.'>
  <main class='site-creation-page'>
    <header class='creation-nav' aria-label='Navegação principal'>
      <a
        class='creation-brand'
        href='/'
        aria-label='Luan Alves, página inicial'>
        Luan Alves
        <span aria-hidden='true'></span>
      </a>

      <nav class='creation-nav-links' aria-label='Seções do site'>
        {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
      </nav>

      <a
        class='creation-nav-cta'
        href={whatsappHref}
        target='_blank'
        rel='noreferrer'>
        Falar no WhatsApp
      </a>
    </header>

    <section class='creation-hero' aria-labelledby='creation-hero-title'>
      <div class='creation-hero__glow' aria-hidden='true'></div>
      <div class='creation-hero__grain' aria-hidden='true'></div>

      <div class='creation-hero__inner'>
        <div class='creation-hero__copy'>
          <p class='creation-eyebrow'>Serviço • Criação de sites</p>

          <h1 id='creation-hero-title'>
            Seu site precisa
            <em>vender, não só</em>
            existir.
          </h1>

          <p class='creation-lead'>
            Crio sites institucionais, blogs e landing pages para empresas que
            precisam de presença digital forte, carregamento rápido e estrutura
            pensada para conversão.
          </p>

          <div class='creation-actions'>
            <a
              class='creation-button creation-button--solid'
              href={whatsappHref}
              target='_blank'
              rel='noreferrer'>
              Solicitar orçamento
            </a>
            <a
              class='creation-button creation-button--outline'
              href='/#portfolio'>
              Ver projetos
            </a>
          </div>

          <div class='creation-features' aria-label='Diferenciais'>
            {
              featureItems.map((item) => (
                <article class='creation-feature'>
                  <span class='creation-feature__icon' aria-hidden='true'>
                    <span class='material-symbols-outlined'>{item.icon}</span>
                  </span>
                  <p>{item.label}</p>
                </article>
              ))
            }
          </div>
        </div>

        <div class='creation-hero__media' aria-hidden='true'>
          <div class='creation-orbit'></div>
          <img
            src='/assets/hero-img.png'
            alt=''
            width='1448'
            height='1086'
            decoding='async'
            fetchpriority='high'
          />
        </div>
      </div>
    </section>

    <section class='results-section' id='resultados' aria-labelledby='results-title'>
      <div class='results-section__glow' aria-hidden='true'></div>

      <div class='results-section__inner'>
        <div class='results-copy'>
          <p class='creation-eyebrow results-eyebrow'>Resultados</p>

          <h2 id='results-title'>
            <span>Um bom site</span>
            <span>precisa <em>trabalhar</em></span>
            <em>por você.</em>
          </h2>

          <p class='results-lead'>
            Mais do que presença digital, o seu site deve transmitir confiança,
            aparecer no Google, carregar rápido e facilitar o contato com a sua
            empresa.
          </p>
        </div>

        <div class='results-media' aria-hidden='true'>
          <img
            src='/assets/resultados-img.png'
            alt=''
            width='1448'
            height='1086'
            loading='lazy'
            decoding='async'
          />
        </div>

        <div class='results-card-grid'>
          {
            resultCards.map((item) => (
              <article class='results-card'>
                <div class='results-card__head'>
                  <span class='results-card__number'>{item.number}</span>
                  <span class='results-card__rule' aria-hidden='true'></span>
                </div>

                <span class='results-card__icon' aria-hidden='true'>
                  <span class='material-symbols-outlined'>{item.icon}</span>
                </span>

                <h3>{item.title}</h3>
                <p>{item.copy}</p>
              </article>
            ))
          }
        </div>

        <div class='results-benefits' aria-label='Benefícios esperados'>
          {
            resultStats.map((item) => (
              <article class='results-benefit'>
                <span class='results-benefit__icon' aria-hidden='true'>
                  <span class='material-symbols-outlined'>{item.icon}</span>
                </span>
                <p>{item.label}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class='process-section' id='processo' aria-labelledby='process-title'>
      <div class='process-section__glow' aria-hidden='true'></div>

      <div class='process-section__inner'>
        <div class='process-copy'>
          <p class='creation-eyebrow process-eyebrow'>Processo</p>

          <h2 id='process-title'>
            <span>Como funciona</span>
            <span><em>a criação</em> do seu site</span>
          </h2>

          <p class='process-lead'>
            Um processo claro reduz retrabalho, acelera a entrega e garante que
            cada etapa faça sentido para o seu negócio.
          </p>
        </div>

        <div class='process-timeline' aria-label='Etapas do processo'>
          {
            processSteps.map((item) => (
              <article class='process-step'>
                <span class='process-step__number'>{item.number}</span>
                <span class='process-step__marker' aria-hidden='true'>
                  <span></span>
                </span>
                <div class='process-step__copy'>
                  <h3>{item.title}</h3>
                  <p>{item.copy}</p>
                </div>
              </article>
            ))
          }
        </div>

        <div class='process-media' aria-hidden='true'>
          <img
            src='/assets/processo-img.png'
            alt=''
            width='1448'
            height='1086'
            loading='lazy'
            decoding='async'
          />
        </div>

      </div>
    </section>

    <section class='included-section' id='incluso' aria-labelledby='included-title'>
      <div class='included-section__glow' aria-hidden='true'></div>

      <div class='included-section__inner'>
        <div class='included-copy'>
          <p class='creation-eyebrow included-eyebrow'>Incluso</p>

          <h2 id='included-title'>
            <span>O que está incluso</span>
            <em>no projeto.</em>
          </h2>

          <p class='included-lead'>
            Cada entrega combina estratégia, design e desenvolvimento para que
            o site já nasça pronto para performar.
          </p>
        </div>

        <div class='included-grid' aria-label='Itens inclusos no projeto'>
          {
            includedItems.map((item) => (
              <article class='included-card'>
                <span class='included-card__icon' aria-hidden='true'>
                  <span class='material-symbols-outlined'>{item.icon}</span>
                </span>

                <h3>{item.title}</h3>
                <p>{item.copy}</p>
              </article>
            ))
          }
        </div>

        <div class='included-media' aria-hidden='true'>
          <div class='included-orbit'></div>
          <img
            src='/assets/incluso-img.png'
            alt=''
            width='1448'
            height='1086'
            loading='lazy'
            decoding='async'
          />
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  :global(body) {
    background: #0f1010;
  }

  .site-creation-page {
    min-height: 100svh;
    overflow-x: hidden;
    background:
      radial-gradient(
        circle at 73% 42%,
        rgba(218, 176, 101, 0.2),
        transparent 27rem
      ),
      radial-gradient(
        circle at 43% 103%,
        rgba(229, 196, 135, 0.1),
        transparent 28rem
      ),
      linear-gradient(115deg, rgba(7, 8, 8, 0.99) 0%, #151514 52%, #0d0e0e 100%);
    color: #f4f1ee;
  }

  .creation-nav {
    position: fixed;
    top: 0;
    left: 0;
    z-index: 10;
    display: grid;
    grid-template-columns: minmax(8rem, 1fr) auto auto;
    align-items: center;
    gap: clamp(1.75rem, 2vw, 1.95rem);
    width: 100%;
    padding: clamp(1.35rem, 2vw, 1.7rem) clamp(1.75rem, 1.9vw, 1.95rem)
      clamp(1.35rem, 2vw, 1.7rem) clamp(2rem, 2.65vw, 2.5rem);
  }

  .creation-brand {
    display: inline-flex;
    align-items: center;
    justify-self: start;
    gap: 0.42rem;
    font-family: 'Newsreader', serif;
    font-size: clamp(1.35rem, 1.85vw, 1.7rem);
    font-weight: 700;
    letter-spacing: -0.055em;
    line-height: 1;
    color: #e1bf7a;
  }

  .creation-brand span {
    width: 0.42rem;
    height: 0.42rem;
    margin-top: 0.2rem;
    border-radius: 999px;
    background: currentColor;
  }

  .creation-nav-links {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(1.6rem, 2.6vw, 2.55rem);
  }

  .creation-nav-links a,
  .creation-nav-cta,
  .creation-button,
  .creation-eyebrow {
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.26em;
    text-transform: uppercase;
  }

  .creation-nav-links a {
    min-height: 2.8rem;
    display: inline-flex;
    align-items: center;
    color: rgba(229, 218, 207, 0.78);
    transition:
      color 180ms ease,
      transform 180ms ease;
  }

  .creation-nav-links a:hover,
  .creation-nav-links a:focus-visible {
    color: #e5c487;
    transform: translateY(-1px);
  }

  .creation-nav-cta {
    justify-self: end;
    min-height: 3.1rem;
    padding: 1rem 1.1rem;
    border: 1px solid rgba(229, 218, 207, 0.2);
    color: #f4f1ee;
    transition:
      border-color 180ms ease,
      color 180ms ease,
      background-color 180ms ease,
      transform 180ms ease;
  }

  .creation-nav-cta:hover,
  .creation-nav-cta:focus-visible {
    border-color: rgba(229, 196, 135, 0.55);
    background: rgba(229, 196, 135, 0.06);
    color: #e5c487;
    transform: translateY(-1px);
  }

  .creation-hero {
    position: relative;
    min-height: 100svh;
    padding: clamp(7.2rem, 9.7vw, 9.1rem) clamp(1.5rem, 6.25vw, 5.85rem) 3.2rem;
    isolation: isolate;
  }

  .creation-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -3;
    background:
      linear-gradient(
        to right,
        rgba(255, 255, 255, 0.025) 1px,
        transparent 1px
      ),
      linear-gradient(
        to bottom,
        rgba(255, 255, 255, 0.018) 1px,
        transparent 1px
      );
    background-size: 4rem 4rem;
    mask-image: radial-gradient(circle at 62% 42%, black, transparent 68%);
    opacity: 0.11;
  }

  .creation-hero__glow {
    position: absolute;
    inset: 0;
    z-index: -2;
    background:
      linear-gradient(
        90deg,
        rgba(8, 8, 8, 0.9),
        rgba(8, 8, 8, 0.22) 56%,
        rgba(8, 8, 8, 0.54)
      ),
      radial-gradient(
        circle at 64% 53%,
        rgba(235, 194, 116, 0.2),
        transparent 32rem
      );
    pointer-events: none;
  }

  .creation-hero__grain {
    position: absolute;
    inset: 0;
    z-index: -1;
    opacity: 0.38;
    pointer-events: none;
    background-image:
      linear-gradient(125deg, rgba(255, 255, 255, 0.035), transparent 22%),
      radial-gradient(
        circle at 20% 20%,
        rgba(255, 255, 255, 0.025) 0 1px,
        transparent 1px
      );
    background-size:
      auto,
      3px 3px;
    mix-blend-mode: overlay;
  }

  .creation-hero__inner {
    display: grid;
    grid-template-columns: minmax(29.5rem, 0.74fr) minmax(38rem, 1.26fr);
    align-items: center;
    gap: 0;
    width: min(100%, 84.8rem);
    min-height: calc(100svh - 12.3rem);
    margin: 0 auto;
  }

  .creation-hero__copy {
    position: relative;
    z-index: 2;
    display: grid;
    justify-items: start;
    align-content: center;
    padding-top: clamp(0rem, 0.5vw, 0.35rem);
  }

  .creation-eyebrow {
    margin: 0 0 1.9rem;
    color: #d9ae5f;
  }

  .creation-hero h1 {
    max-width: 9.9ch;
    margin: 0;
    font-family: 'Newsreader', serif;
    font-size: clamp(4.35rem, 5vw, 5rem);
    font-weight: 600;
    letter-spacing: -0.058em;
    line-height: 0.96;
    color: #f5f2ef;
    text-wrap: balance;
  }

  .creation-hero h1 em {
    display: block;
    color: #dfbd79;
    font-style: italic;
    font-weight: 600;
  }

  .creation-lead {
    max-width: 32.4rem;
    margin: 0.75rem 0 0;
    color: rgba(226, 218, 208, 0.82);
    font-size: clamp(1.02rem, 1.18vw, 1.09rem);
    font-weight: 300;
    line-height: 1.68;
    text-wrap: pretty;
  }

  .creation-actions {
    display: flex;
    flex-wrap: nowrap;
    gap: 1.5rem;
    margin-top: 2.55rem;
  }

  .creation-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 12.55rem;
    min-height: 3.45rem;
    padding: 1.05rem 1.7rem;
    border: 1px solid rgba(230, 222, 211, 0.2);
    color: #f5f2ef;
    white-space: nowrap;
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      color 180ms ease,
      background-color 180ms ease,
      box-shadow 180ms ease;
  }

  .creation-button:hover,
  .creation-button:focus-visible {
    transform: translateY(-2px);
  }

  .creation-button--solid {
    min-width: 15.8rem;
    border-color: #d9b66d;
    background: linear-gradient(180deg, #edcf8b, #cfa967);
    color: #382600;
    box-shadow: 0 20px 42px rgba(207, 169, 103, 0.16);
  }

  .creation-button--solid:hover,
  .creation-button--solid:focus-visible {
    background: linear-gradient(180deg, #f0d899, #dab56f);
    box-shadow: 0 24px 52px rgba(207, 169, 103, 0.22);
  }

  .creation-button--outline:hover,
  .creation-button--outline:focus-visible {
    border-color: rgba(229, 196, 135, 0.55);
    background: rgba(229, 196, 135, 0.055);
    color: #e5c487;
  }

  .creation-features {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    width: min(100%, 34rem);
    margin-top: clamp(3.7rem, 6.6vw, 4.95rem);
  }

  .creation-feature {
    display: grid;
    justify-items: center;
    gap: 1rem;
    min-width: 0;
    padding-inline: clamp(0.9rem, 1.8vw, 1.65rem);
    text-align: center;
  }

  .creation-feature + .creation-feature {
    border-left: 1px solid rgba(229, 218, 207, 0.11);
  }

  .creation-feature__icon {
    display: grid;
    place-items: center;
    width: 3.1rem;
    height: 3.1rem;
    border: 1px solid rgba(229, 196, 135, 0.58);
    border-radius: 999px;
    color: #d9ae5f;
    background: rgba(12, 12, 12, 0.24);
    box-shadow: inset 0 0 18px rgba(229, 196, 135, 0.035);
  }

  .creation-feature__icon .material-symbols-outlined {
    font-size: 1.45rem;
    font-variation-settings:
      'FILL' 0,
      'wght' 260,
      'GRAD' 0,
      'opsz' 24;
  }

  .creation-feature p {
    margin: 0;
    color: rgba(226, 218, 208, 0.86);
    font-size: 0.92rem;
    font-weight: 300;
    line-height: 1.35;
  }

  .creation-hero__media {
    position: relative;
    z-index: 1;
    align-self: center;
    min-width: 0;
    margin-right: clamp(-7rem, -7vw, -4rem);
    transform: translate(-7.6rem, -0.05rem);
  }

  .creation-orbit {
    position: absolute;
    top: 6.5%;
    left: 13%;
    z-index: -1;
    width: 53%;
    aspect-ratio: 1;
    border: 1px solid rgba(211, 169, 98, 0.3);
    border-radius: 999px;
    filter: drop-shadow(0 0 24px rgba(211, 169, 98, 0.1));
  }

  .creation-hero__media img {
    width: min(77vw, 72.25rem);
    max-width: none;
    height: auto;
    margin-left: auto;
    filter: drop-shadow(0 3rem 5rem rgba(0, 0, 0, 0.36))
      drop-shadow(0 0 2.6rem rgba(202, 159, 86, 0.12));
  }

  .results-section {
    position: relative;
    padding: clamp(7.5rem, 9vw, 9.2rem) clamp(1.5rem, 6.25vw, 5.85rem)
      clamp(5.8rem, 7vw, 7rem);
    isolation: isolate;
  }

  .results-section::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -4;
    background:
      radial-gradient(
        circle at 30% 57%,
        rgba(223, 189, 121, 0.17),
        transparent 22rem
      ),
      radial-gradient(
        circle at 79% 46%,
        rgba(223, 189, 121, 0.08),
        transparent 28rem
      ),
      linear-gradient(115deg, #101111 0%, #181817 48%, #0d0e0e 100%);
  }

  .results-section::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -3;
    background:
      linear-gradient(
        to right,
        rgba(255, 255, 255, 0.019) 1px,
        transparent 1px
      ),
      linear-gradient(
        to bottom,
        rgba(255, 255, 255, 0.014) 1px,
        transparent 1px
      );
    background-size: 4rem 4rem;
    mask-image: linear-gradient(90deg, transparent, black 22%, black 82%, transparent);
    opacity: 0.24;
  }

  .results-section__glow {
    position: absolute;
    inset: 0;
    z-index: -2;
    pointer-events: none;
    background:
      linear-gradient(
        180deg,
        rgba(9, 9, 9, 0.36),
        transparent 16rem,
        rgba(7, 7, 7, 0.35)
      ),
      radial-gradient(
        ellipse at 25% 70%,
        rgba(218, 176, 101, 0.18),
        transparent 31rem
      );
  }

  .results-section__inner {
    position: relative;
    display: grid;
    grid-template-columns: minmax(24rem, 0.83fr) minmax(38rem, 1.17fr);
    grid-template-areas:
      'copy cards'
      'media cards'
      'media benefits';
    gap: 1.65rem clamp(3rem, 5.7vw, 5.4rem);
    width: min(100%, 84.8rem);
    margin: 0 auto;
  }

  .results-copy {
    grid-area: copy;
    align-self: end;
    padding-top: clamp(0rem, 0.6vw, 0.5rem);
  }

  .results-eyebrow {
    margin-bottom: 1.75rem;
  }

  .results-copy h2 {
    max-width: 12.8ch;
    margin: 0;
    color: #f5f2ef;
    font-family: 'Newsreader', serif;
    font-size: clamp(3.49rem, 4.42vw, 4.46rem);
    font-weight: 600;
    letter-spacing: -0.058em;
    line-height: 0.94;
    text-wrap: balance;
  }

  .results-copy h2 > span,
  .results-copy h2 > em {
    display: block;
  }

  .results-copy h2 > span {
    white-space: nowrap;
  }

  .results-copy h2 em {
    color: #dfbd79;
    font-style: italic;
    font-weight: 600;
  }

  .results-lead {
    max-width: 32.2rem;
