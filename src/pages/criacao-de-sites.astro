---
import BaseLayout from '../layouts/BaseLayout.astro';

const whatsappHref =
  'https://wa.me/5591982890565?text=Ol%C3%A1%2C%20Luan!%20Quero%20solicitar%20um%20or%C3%A7amento%20para%20cria%C3%A7%C3%A3o%20de%20site.';

const navItems = [
  { href: '/#servicos', label: 'Serviços' },
  { href: '/#portfolio', label: 'Portfólio' },
  { href: '/#contato', label: 'Contato' },
];

const featureItems = [
  { icon: 'trending_up', label: 'SEO desde o início' },
  { icon: 'phone_iphone', label: 'Mobile first' },
  { icon: 'code', label: 'Código limpo' },
];
---

<BaseLayout
  title='Criação de Sites | Luan Alves'
  description='Criação de sites institucionais, blogs e landing pages para empresas que precisam vender mais com presença digital profissional.'>
  <main class='site-creation-page'>
    <header class='creation-nav' aria-label='Navegação principal'>
      <a class='creation-brand' href='/' aria-label='Luan Alves, página inicial'>
        Luan Alves
        <span aria-hidden='true'></span>
      </a>

      <nav class='creation-nav-links' aria-label='Seções do site'>
        {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
      </nav>

      <a
        class='creation-nav-cta'
        href={whatsappHref}
        target='_blank'
        rel='noreferrer'>
        Falar no WhatsApp
      </a>
    </header>

    <section class='creation-hero' aria-labelledby='creation-hero-title'>
      <div class='creation-hero__glow' aria-hidden='true'></div>
      <div class='creation-hero__grain' aria-hidden='true'></div>

      <div class='creation-hero__inner'>
        <div class='creation-hero__copy'>
          <p class='creation-eyebrow'>Serviço • Criação de sites</p>

          <h1 id='creation-hero-title'>
            Seu site precisa
            <em>vender, não só</em>
            existir.
          </h1>

          <p class='creation-lead'>
            Crio sites institucionais, blogs e landing pages para empresas que
            precisam de presença digital forte, carregamento rápido e estrutura
            pensada para conversão.
          </p>

          <div class='creation-actions'>
            <a
              class='creation-button creation-button--solid'
              href={whatsappHref}
              target='_blank'
              rel='noreferrer'>
              Solicitar orçamento
            </a>
            <a class='creation-button creation-button--outline' href='/#portfolio'>
              Ver projetos
            </a>
          </div>

          <div class='creation-features' aria-label='Diferenciais'>
            {
              featureItems.map((item) => (
                <article class='creation-feature'>
                  <span class='creation-feature__icon' aria-hidden='true'>
                    <span class='material-symbols-outlined'>{item.icon}</span>
                  </span>
                  <p>{item.label}</p>
                </article>
              ))
            }
          </div>
        </div>

        <div class='creation-hero__media' aria-hidden='true'>
          <div class='creation-orbit'></div>
          <img
            src='/assets/hero-img.png'
            alt=''
            width='1448'
            height='1086'
            decoding='async'
            fetchpriority='high'
          />
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  :global(body) {
    background: #0f1010;
  }

  .site-creation-page {
    min-height: 100svh;
    overflow: hidden;
    background:
      radial-gradient(circle at 74% 45%, rgba(214, 171, 96, 0.24), transparent 25rem),
      radial-gradient(circle at 40% 108%, rgba(229, 196, 135, 0.12), transparent 28rem),
      linear-gradient(115deg, rgba(7, 8, 8, 0.98) 0%, #151514 52%, #0d0e0e 100%);
    color: #f4f1ee;
  }

  .creation-nav {
    position: fixed;
    top: 0;
    left: 0;
    z-index: 10;
    display: grid;
    grid-template-columns: minmax(8rem, 1fr) auto minmax(8rem, 1fr);
    align-items: center;
    gap: 2rem;
    width: 100%;
    padding: clamp(1.25rem, 2.4vw, 2rem) clamp(1.5rem, 3.9vw, 3.2rem);
  }

  .creation-brand {
    display: inline-flex;
    align-items: center;
    justify-self: start;
    gap: 0.42rem;
    font-family: "Newsreader", serif;
    font-size: clamp(1.35rem, 2vw, 1.9rem);
    font-weight: 700;
    letter-spacing: -0.055em;
    line-height: 1;
    color: #e1bf7a;
  }

  .creation-brand span {
    width: 0.42rem;
    height: 0.42rem;
    margin-top: 0.2rem;
    border-radius: 999px;
    background: currentColor;
  }

  .creation-nav-links {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(1.6rem, 3vw, 3rem);
  }

  .creation-nav-links a,
  .creation-nav-cta,
  .creation-button,
  .creation-eyebrow {
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.26em;
    text-transform: uppercase;
  }

  .creation-nav-links a {
    min-height: 2.8rem;
    display: inline-flex;
    align-items: center;
    color: rgba(229, 218, 207, 0.78);
    transition:
      color 180ms ease,
      transform 180ms ease;
  }

  .creation-nav-links a:hover,
  .creation-nav-links a:focus-visible {
    color: #e5c487;
    transform: translateY(-1px);
  }

  .creation-nav-cta {
    justify-self: end;
    padding: 1.15rem 1.6rem;
    border: 1px solid rgba(229, 218, 207, 0.2);
    color: #f4f1ee;
    transition:
      border-color 180ms ease,
      color 180ms ease,
      background-color 180ms ease,
      transform 180ms ease;
  }

  .creation-nav-cta:hover,
  .creation-nav-cta:focus-visible {
    border-color: rgba(229, 196, 135, 0.55);
    background: rgba(229, 196, 135, 0.06);
    color: #e5c487;
    transform: translateY(-1px);
  }

  .creation-hero {
    position: relative;
    min-height: 100svh;
    padding: clamp(7rem, 10vw, 9.7rem) clamp(1.5rem, 6.3vw, 6rem) 4rem;
    isolation: isolate;
  }

  .creation-hero::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -3;
    background:
      linear-gradient(to right, rgba(255, 255, 255, 0.025) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(255, 255, 255, 0.018) 1px, transparent 1px);
    background-size: 4rem 4rem;
    mask-image: radial-gradient(circle at 62% 42%, black, transparent 68%);
    opacity: 0.16;
  }

  .creation-hero__glow {
    position: absolute;
    inset: 0;
    z-index: -2;
    background:
      linear-gradient(90deg, rgba(8, 8, 8, 0.86), rgba(8, 8, 8, 0.24) 56%, rgba(8, 8, 8, 0.58)),
      radial-gradient(circle at 64% 54%, rgba(235, 194, 116, 0.23), transparent 32rem);
    pointer-events: none;
  }

  .creation-hero__grain {
    position: absolute;
    inset: 0;
    z-index: -1;
    opacity: 0.38;
    pointer-events: none;
    background-image:
      linear-gradient(125deg, rgba(255, 255, 255, 0.035), transparent 22%),
      radial-gradient(circle at 20% 20%, rgba(255, 255, 255, 0.025) 0 1px, transparent 1px);
    background-size: auto, 3px 3px;
    mix-blend-mode: overlay;
  }

  .creation-hero__inner {
    display: grid;
    grid-template-columns: minmax(28rem, 0.78fr) minmax(38rem, 1.22fr);
    align-items: center;
    gap: clamp(1.5rem, 4vw, 4rem);
    width: min(100%, 92rem);
    min-height: calc(100svh - 13rem);
    margin: 0 auto;
  }

  .creation-hero__copy {
    position: relative;
    z-index: 2;
    display: grid;
    justify-items: start;
    align-content: center;
    padding-top: clamp(0rem, 3vw, 2.3rem);
  }

  .creation-eyebrow {
    margin: 0 0 1.95rem;
    color: #d9ae5f;
  }

  .creation-hero h1 {
    max-width: 9.4ch;
    margin: 0;
    font-family: "Newsreader", serif;
    font-size: clamp(4.3rem, 6.1vw, 6.3rem);
    font-weight: 600;
    letter-spacing: -0.062em;
    line-height: 0.94;
    color: #f5f2ef;
    text-wrap: balance;
  }

  .creation-hero h1 em {
    display: block;
    color: #dfbd79;
    font-style: italic;
    font-weight: 600;
  }

  .creation-lead {
    max-width: 35.8rem;
    margin: 2.05rem 0 0;
    color: rgba(226, 218, 208, 0.82);
    font-size: clamp(1.02rem, 1.34vw, 1.22rem);
    font-weight: 300;
    line-height: 1.72;
    text-wrap: pretty;
  }

  .creation-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    margin-top: 2.65rem;
  }

  .creation-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 12.8rem;
    min-height: 3.55rem;
    padding: 1.1rem 1.8rem;
    border: 1px solid rgba(230, 222, 211, 0.2);
    color: #f5f2ef;
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      color 180ms ease,
      background-color 180ms ease,
      box-shadow 180ms ease;
  }

  .creation-button:hover,
  .creation-button:focus-visible {
    transform: translateY(-2px);
  }

  .creation-button--solid {
    min-width: 16rem;
    border-color: #d9b66d;
    background: linear-gradient(180deg, #edcf8b, #cfa967);
    color: #382600;
    box-shadow: 0 20px 42px rgba(207, 169, 103, 0.16);
  }

  .creation-button--solid:hover,
  .creation-button--solid:focus-visible {
    background: linear-gradient(180deg, #f0d899, #dab56f);
    box-shadow: 0 24px 52px rgba(207, 169, 103, 0.22);
  }

  .creation-button--outline:hover,
  .creation-button--outline:focus-visible {
    border-color: rgba(229, 196, 135, 0.55);
    background: rgba(229, 196, 135, 0.055);
    color: #e5c487;
  }

  .creation-features {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    width: min(100%, 36rem);
    margin-top: clamp(3.6rem, 7vw, 5rem);
  }

  .creation-feature {
    display: grid;
    justify-items: center;
    gap: 1rem;
    min-width: 0;
    padding-inline: clamp(1rem, 2vw, 2rem);
    text-align: center;
  }

  .creation-feature + .creation-feature {
    border-left: 1px solid rgba(229, 218, 207, 0.11);
  }

  .creation-feature__icon {
    display: grid;
    place-items: center;
    width: 3.1rem;
    height: 3.1rem;
    border: 1px solid rgba(229, 196, 135, 0.58);
    border-radius: 999px;
    color: #d9ae5f;
    background: rgba(12, 12, 12, 0.24);
    box-shadow: inset 0 0 18px rgba(229, 196, 135, 0.035);
  }

  .creation-feature__icon .material-symbols-outlined {
    font-size: 1.45rem;
    font-variation-settings: "FILL" 0, "wght" 260, "GRAD" 0, "opsz" 24;
  }

  .creation-feature p {
    margin: 0;
    color: rgba(226, 218, 208, 0.86);
    font-size: 0.92rem;
    font-weight: 300;
    line-height: 1.35;
  }

  .creation-hero__media {
    position: relative;
    z-index: 1;
    align-self: center;
    min-width: 0;
    margin-right: clamp(-5rem, -4vw, -2rem);
    transform: translateY(1.5rem);
  }

  .creation-orbit {
    position: absolute;
    top: 7%;
    left: 12%;
    z-index: -1;
    width: 53%;
    aspect-ratio: 1;
    border: 1px solid rgba(211, 169, 98, 0.3);
    border-radius: 999px;
    filter: drop-shadow(0 0 24px rgba(211, 169, 98, 0.1));
  }

  .creation-hero__media img {
    width: min(68vw, 58rem);
    max-width: none;
    height: auto;
    margin-left: auto;
    filter:
      drop-shadow(0 3rem 5rem rgba(0, 0, 0, 0.36))
      drop-shadow(0 0 2.6rem rgba(202, 159, 86, 0.12));
  }

  @media (max-width: 1180px) {
    .creation-hero__inner {
      grid-template-columns: minmax(24rem, 0.9fr) minmax(30rem, 1.1fr);
    }

    .creation-hero h1 {
      font-size: clamp(3.7rem, 6vw, 5.2rem);
    }

    .creation-hero__media img {
      width: min(64vw, 50rem);
    }
  }

  @media (max-width: 900px) {
    .creation-nav {
      grid-template-columns: 1fr auto;
      padding: 1.1rem 1.2rem;
      background: rgba(12, 12, 12, 0.64);
      border-bottom: 1px solid rgba(229, 218, 207, 0.08);
      backdrop-filter: blur(16px);
    }

    .creation-nav-links {
      display: none;
    }

    .creation-nav-cta {
      padding: 0.9rem 1rem;
      font-size: 0.62rem;
      letter-spacing: 0.18em;
    }

    .creation-hero {
      padding: 7rem 1.15rem 3rem;
    }

    .creation-hero__inner {
      grid-template-columns: 1fr;
      min-height: auto;
      gap: 2.5rem;
    }

    .creation-hero__copy {
      justify-items: center;
      text-align: center;
    }

    .creation-hero h1 {
      max-width: 10ch;
      font-size: clamp(3.55rem, 13vw, 5.7rem);
    }

    .creation-lead {
      max-width: 36rem;
      margin-top: 1.5rem;
    }

    .creation-actions {
      justify-content: center;
      width: min(100%, 34rem);
      gap: 0.9rem;
      margin-top: 2rem;
    }

    .creation-button {
      flex: 1 1 14rem;
      min-width: 0;
    }

    .creation-features {
      width: min(100%, 34rem);
      margin-top: 2.4rem;
    }

    .creation-hero__media {
      order: -1;
      width: min(100%, 42rem);
      margin: 0 auto -1rem;
      transform: none;
    }

    .creation-hero__media img {
      width: 100%;
      margin: 0 auto;
    }

    .creation-orbit {
      top: 0;
      left: 19%;
      width: 54%;
    }
  }

  @media (max-width: 560px) {
    .creation-nav {
      gap: 0.75rem;
    }

    .creation-brand {
      font-size: 1.28rem;
    }

    .creation-nav-cta {
      max-width: 10rem;
      text-align: center;
      line-height: 1.35;
    }

    .creation-hero {
      padding-inline: 0.9rem;
    }

    .creation-eyebrow {
      margin-bottom: 1.35rem;
      font-size: 0.64rem;
      letter-spacing: 0.2em;
    }

    .creation-hero h1 {
      font-size: clamp(3.1rem, 16vw, 4.25rem);
      letter-spacing: -0.055em;
    }

    .creation-lead {
      font-size: 1rem;
      line-height: 1.68;
    }

    .creation-actions {
      display: grid;
      grid-template-columns: 1fr;
    }

    .creation-button {
      width: 100%;
      min-height: 3.35rem;
      padding-inline: 1rem;
      font-size: 0.68rem;
      letter-spacing: 0.18em;
    }

    .creation-features {
      grid-template-columns: 1fr;
      gap: 1.15rem;
      margin-top: 2.15rem;
    }

    .creation-feature {
      grid-template-columns: 3.1rem 1fr;
      justify-items: start;
      align-items: center;
      gap: 0.9rem;
      padding: 0;
      text-align: left;
    }

    .creation-feature + .creation-feature {
      padding-top: 1.15rem;
      border-top: 1px solid rgba(229, 218, 207, 0.11);
      border-left: 0;
    }
  }
</style>
